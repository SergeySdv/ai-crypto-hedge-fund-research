   646	def _normalize_market_frame(
   647	    frame: pd.DataFrame,
   648	    *,
   649	    symbol: str,
   650	    end: pd.Timestamp,
   651	) -> pd.DataFrame:
   652	    source = frame.copy()
   653	    if isinstance(source.index, pd.MultiIndex) and "bar_start_utc" in source.index.names:
   654	        source = source.reset_index()
   655	    if "bar_start_utc" not in source.columns or "symbol" not in source.columns:
   656	        msg = "market frame must contain bar_start_utc and symbol columns"
   657	        raise ValueError(msg)
   658	    source["bar_start_utc"] = pd.to_datetime(source["bar_start_utc"], utc=True)
   659	    source["bar_end_utc"] = (
   660	        pd.to_datetime(source["bar_end_utc"], utc=True)
   661	        if "bar_end_utc" in source.columns
   662	        else source["bar_start_utc"] + pd.Timedelta(days=1)
   663	    )
   664	    source["symbol"] = source["symbol"].astype(str)
   665	    source = source.loc[(source["symbol"] == symbol) & (source["bar_start_utc"] <= end)]
   666	    source = source.sort_values("bar_start_utc", kind="mergesort").reset_index(drop=True)
   667	    if source["bar_start_utc"].duplicated().any():
   668	        msg = f"duplicate bars for {symbol}"
   669	        raise ValueError(msg)
   670	    return source
   671
