  1045	def _two_sided_p_value(observed: float, shifted: list[float]) -> float:
  1046	    if not shifted:
  1047	        return 1.0
  1048	    extreme = sum(abs(value) >= abs(observed) for value in shifted)
  1049	    return float((extreme + 1) / (len(shifted) + 1))
