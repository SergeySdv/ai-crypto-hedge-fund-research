  1031	def _score_return_correlation(traces: tuple[DecisionTrace, ...], features: pd.DataFrame) -> float:
  1032	    by_bar = features.set_index("bar_start_utc")["forward_return"]
  1033	    scores = []
  1034	    returns = []
  1035	    for trace in traces:
  1036	        bar_start = pd.Timestamp(trace.clock.bar_start)
  1037	        if bar_start in by_bar.index and trace.aggregated_signals:
  1038	            scores.append(float(trace.aggregated_signals[0].score))
  1039	            returns.append(float(by_bar.loc[bar_start]))
  1040	    if len(scores) < 3 or np.std(scores) <= 0 or np.std(returns) <= 0:
  1041	        return 0.0
  1042	    return float(np.corrcoef(scores, returns)[0, 1])
