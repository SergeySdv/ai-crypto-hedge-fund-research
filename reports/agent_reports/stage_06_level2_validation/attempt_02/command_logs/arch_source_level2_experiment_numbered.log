   503	def _minimum_fit_cutoff(
   504	    agents: tuple[Any, ...],
   505	    bar_start: pd.Timestamp,
   506	    *,
   507	    fallback: pd.Timestamp,
   508	) -> pd.Timestamp:
   509	    cutoffs: list[pd.Timestamp] = []
   510	    for agent in agents:
   511	        table = getattr(agent, "predictions", None)
   512	        if isinstance(table, pd.DataFrame) and not table.empty:
   513	            normalized = table.copy()
   514	            normalized["bar_start_utc"] = pd.to_datetime(normalized["bar_start_utc"], utc=True)
   515	            rows = normalized.loc[normalized["bar_start_utc"] == bar_start]
   516	            if not rows.empty and pd.notna(rows.iloc[-1].get("fit_cutoff")):
   517	                cutoffs.append(pd.Timestamp(rows.iloc[-1]["fit_cutoff"]))
   518	    return min(cutoffs) if cutoffs else fallback
