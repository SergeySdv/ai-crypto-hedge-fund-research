   330	def build_level_2_target_schedule(
   331	    *,
   332	    frame: pd.DataFrame,
   333	    features: pd.DataFrame,
   334	    symbol: str,
   335	    agents: tuple[Any, ...],
   336	    agent_weights: dict[str, float],
   337	    config: dict[str, Any],
   338	    approach_name: str,
   339	) -> tuple[pd.DataFrame, tuple[DecisionTrace, ...]]:
   340	    """Create risk-approved target weights through the Stage 4 orchestrator path."""
   341
   342	    normalized = _normalize_market_frame(
   343	        frame,
   344	        symbol=symbol,
   345	        end=pd.Timestamp(ensure_utc(config["splits"]["validation_end"])),
   346	    )
   347	    validation_start = pd.Timestamp(ensure_utc(config["splits"]["validation_start"]))
   348	    validation_end = pd.Timestamp(ensure_utc(config["splits"]["validation_end"]))
   349	    first_decision_bar = validation_start - pd.Timedelta(days=1)
   350	    orchestrator = TypedAgentOrchestrator(
   351	        agents,
   352	        aggregator=SignalAggregator(
   353	            agent_weights=agent_weights,
   354	            disagreement_threshold=float(config["risk"]["max_agent_disagreement"]),
   355	        ),
   356	    )
   357	    level_config = dict(config.get("level_2", {}))
   358	    pre_risk = PreAllocationRiskPolicy(
   359	        max_gross_exposure=float(config["portfolio"]["max_gross_exposure"]),
   360	        max_per_asset_weight=float(level_config.get("max_weight", 1.0)),
   361	        cost_buffer_weight=float(level_config.get("cost_buffer_weight", 0.005)),
   362	        min_dollar_volume=float(level_config.get("min_dollar_volume", 0.0)),
   363	        max_stale_data_days=0,
   364	        max_model_age_days=int(level_config.get("max_model_age_days", 60)),
   365	        max_agent_disagreement=float(config["risk"]["max_agent_disagreement"]),
   366	        volatility_target=None,
   367	        turnover_cap=None,
   368	    )
   369	    allocator = _RiskScaledSingleAssetAllocator(
   370	        max_weight=float(level_config.get("max_weight", 1.0)),
   371	        min_confidence=float(level_config.get("min_confidence", 0.0)),
   372	    )
   373	    rebalance_policy = AlwaysRebalancePolicy(trigger_code=approach_name)
   374	    post_risk = PostAllocationRiskPolicy(
   375	        max_drawdown_stop=float(config["risk"]["max_drawdown_stop"]),
   376	        high_volatility_threshold=float(config["risk"]["high_volatility_threshold_annual"]),
   377	        min_cash_buffer=float(level_config.get("min_cash_buffer", 0.005)),
   378	        annualization_periods=int(config["backtest"]["annualization_periods"]),
   379	    )
   380
   381	    rows: list[dict[str, float]] = []
   382	    index: list[pd.Timestamp] = []
   383	    traces: list[DecisionTrace] = []
   384	    current_weights = pd.Series({symbol: 0.0}, dtype="float64")
   385	    feature_rows = features.loc[
   386	        (features["bar_start_utc"] >= first_decision_bar)
   387	        & (features["execution_time"] >= validation_start)
   388	        & (features["execution_time"] <= validation_end)
   389	    ]
   390	    feature_by_bar = {
   391	        pd.Timestamp(row.bar_start_utc): row for row in feature_rows.itertuples(index=False)
   392	    }
   393	    for bar_start, feature_row in feature_by_bar.items():
   394	        clock = build_daily_research_clock(bar_start.to_pydatetime())
   395	        execution_time = pd.Timestamp(clock.execution_time)
   396	        history = normalized.loc[normalized["bar_start_utc"] <= bar_start].set_index(
   397	            "bar_start_utc"
   398	        )
   399	        model_fit_cutoff = _minimum_fit_cutoff(agents, bar_start, fallback=clock.feature_cutoff)
   400	        context = AgentContext(
   401	            clock=clock,
   402	            symbols=(symbol,),
   403	            model_fit_cutoff=pd.Timestamp(model_fit_cutoff).to_pydatetime(),
   404	            portfolio_nav=float(config["backtest"]["initial_capital_usd"]),
   405	            current_weights=current_weights.to_dict(),
   406	            health_state={
   407	                "realized_volatility": float(getattr(feature_row, "realized_vol_20", 0.0))
   408	            },
   409	            metadata={
   410	                "level": LEVEL_NAME,
   411	                "split": "validation",
   412	                "approach": approach_name,
   413	                "execution_convention": "completed_bar_next_open",
   414	            },
   415	        )
   416	        run = orchestrator.run(history, context)
   417	        constraints = pre_risk.constraints(
   418	            list(run.aggregated_signals),
   419	            context,
   420	            _snapshot_for_bar(normalized, symbol=symbol, bar_start=bar_start),
   421	        )
   422	        signal_series = pd.Series(
   423	            {signal.symbol: signal.score for signal in run.aggregated_signals},
   424	            dtype="float64",
   425	        )
   426	        confidence_by_symbol = {
   427	            f"confidence:{signal.symbol}": signal.confidence for signal in run.aggregated_signals
   428	        }
   429	        current_weights.attrs.update(confidence_by_symbol)
   430	        returns = _historical_open_returns(normalized, through=bar_start)
   431	        proposal = allocator.allocate(signal_series, returns, constraints, current_weights)
   432	        rebalance = rebalance_policy.decide(proposal, current_weights, context)
   433	        approval = post_risk.approve(proposal, rebalance, constraints, context, returns)
   434	        executable = resolve_risk_approval_targets(approval, context)
   435	        target = pd.Series(executable.risky_weights, dtype="float64").reindex(
   436	            [symbol], fill_value=0.0
   437	        )
   438	        rows.append({symbol: float(target.get(symbol, 0.0))})
   439	        index.append(bar_start)
   440	        current_weights = target
   441	        traces.append(
   442	            DecisionTrace(
   443	                clock=clock,
   444	                signals=run.signals,
   445	                aggregated_signals=run.aggregated_signals,
   446	                constraints=constraints,
   447	                proposal=proposal,
   448	                approval=approval,
   449	                events=run.events,
   450	                metadata={
   451	                    "level": LEVEL_NAME,
   452	                    "split": "validation",
   453	                    "approach": approach_name,
   454	                    "execution_time": execution_time.isoformat(),
   455	                    "resolved_action": executable.action,
   456	                    "resolved_weights": dict(executable.risky_weights),
   457	                    "resolved_cash_weight": executable.cash_weight,
   458	                    "forward_return": float(feature_row.forward_return),
   459	                },
   460	            )
   461	        )
   462
   463	    if not rows:
   464	        msg = f"Level 2 {approach_name} produced no executable target-weight rows"
   465	        raise ValueError(msg)
   466	    return pd.DataFrame(rows, index=pd.DatetimeIndex(index, tz="UTC")), tuple(traces)
   467
