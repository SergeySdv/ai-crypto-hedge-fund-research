   469	def _approach_agents(
   470	    *,
   471	    config: dict[str, Any],
   472	    symbol: str,
   473	    prediction_tables: dict[str, pd.DataFrame],
   474	) -> list[tuple[str, tuple[Any, ...], dict[str, float]]]:
   475	    level_config = dict(config.get("level_2", {}))
   476	    technical = SMACrossoverSignalAgent(
   477	        fast_window=int(level_config.get("technical_fast_window", 10)),
   478	        slow_window=int(level_config.get("technical_slow_window", 50)),
   479	    )
   480	    econometric = PredictionTableSignalAgent(
   481	        "econometric_ar_garch", prediction_tables["econometric_ar_garch"]
   482	    )
   483	    logistic = PredictionTableSignalAgent("ml_logistic", prediction_tables["ml_logistic"])
   484	    hgb = PredictionTableSignalAgent(
   485	        "ml_hist_gradient_boosting", prediction_tables["ml_hist_gradient_boosting"]
   486	    )
   487	    del symbol
   488	    ensemble_weights = {
   489	        "sma_crossover": float(level_config.get("technical_weight", 0.25)),
   490	        "econometric_ar_garch": float(level_config.get("econometric_weight", 0.25)),
   491	        "ml_logistic": float(level_config.get("logistic_weight", 0.25)),
   492	        "ml_hist_gradient_boosting": float(level_config.get("hgb_weight", 0.25)),
   493	    }
   494	    return [
   495	        ("technical_sma", (technical,), {"sma_crossover": 1.0}),
   496	        ("econometric_ar_garch", (econometric,), {"econometric_ar_garch": 1.0}),
   497	        ("ml_logistic", (logistic,), {"ml_logistic": 1.0}),
   498	        ("ml_hist_gradient_boosting", (hgb,), {"ml_hist_gradient_boosting": 1.0}),
   499	        ("agent_ensemble", (technical, econometric, logistic, hgb), ensemble_weights),
   500	    ]
   501
