   740	def _combined_metrics(
   741	    net_result: BacktestRunResult,
   742	    gross_result: BacktestRunResult,
   743	    *,
   744	    benchmark_nav: pd.Series,
   745	    config: dict[str, Any],
   746	) -> dict[str, float]:
   747	    net = calculate_performance_metrics(
   748	        net_result.equity,
   749	        periods_per_year=int(config["backtest"]["annualization_periods"]),
   750	        risk_free_rate=float(config["backtest"]["risk_free_rate"]),
   751	        weights=net_result.weights,
   752	        benchmark_nav=benchmark_nav,
   753	    )
   754	    gross = calculate_performance_metrics(
   755	        gross_result.equity,
   756	        periods_per_year=int(config["backtest"]["annualization_periods"]),
   757	        risk_free_rate=float(config["backtest"]["risk_free_rate"]),
   758	        weights=gross_result.weights,
   759	        benchmark_nav=benchmark_nav,
   760	    )
   761	    metrics = dict(net)
   762	    metrics.update({f"net_{key}": value for key, value in net.items()})
   763	    metrics.update({f"gross_{key}": value for key, value in gross.items()})
   764	    metrics["gross_to_net_total_return_decay"] = gross["total_return"] - net["total_return"]
   765	    return metrics
