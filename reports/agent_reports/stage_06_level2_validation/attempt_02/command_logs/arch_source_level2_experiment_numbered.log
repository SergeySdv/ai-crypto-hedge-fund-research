   723	def _trim_result(
   724	    result: BacktestRunResult, *, start: pd.Timestamp, end: pd.Timestamp
   725	) -> BacktestRunResult:
   726	    def trim(frame: pd.DataFrame) -> pd.DataFrame:
   727	        if frame.empty or "timestamp" not in frame.columns:
   728	            return frame.copy()
   729	        timestamps = pd.to_datetime(frame["timestamp"], utc=True)
   730	        return frame.loc[(timestamps >= start) & (timestamps <= end)].reset_index(drop=True)
   731
   732	    return BacktestRunResult(
   733	        equity=trim(result.equity),
   734	        weights=trim(result.weights),
   735	        orders=trim(result.orders),
   736	        fills=trim(result.fills),
   737	    )
