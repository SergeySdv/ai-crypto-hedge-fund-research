  1101	def _write_json_artifact(path: Path, payload: dict[str, Any]) -> Path:
  1102	    path.parent.mkdir(parents=True, exist_ok=True)
  1103	    with path.open("w", encoding="utf-8") as handle:
  1104	        json.dump(payload, handle, indent=2, sort_keys=True)
  1105	        handle.write("\n")
  1106	    return path
