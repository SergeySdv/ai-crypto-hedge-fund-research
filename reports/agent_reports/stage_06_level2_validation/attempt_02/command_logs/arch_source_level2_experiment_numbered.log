   937	def _robustness_checks(
   938	    *,
   939	    selected: _ApproachResult,
   940	    features: pd.DataFrame,
   941	    config: dict[str, Any],
   942	    cadence: dict[str, str],
   943	) -> dict[str, Any]:
   944	    returns = selected.net_result.equity["nav"].astype("float64").pct_change().dropna()
   945	    repetitions = int(config["statistics"]["bootstrap_repetitions"])
   946	    permutation_repetitions = int(config["statistics"]["permutation_repetitions"])
   947	    block_length = int(config["statistics"]["block_length_days"])
   948	    rng = np.random.default_rng(int(config["project"]["seed"]))
   949	    boot_means = []
   950	    boot_sharpes = []
   951	    values = returns.to_numpy()
   952	    if len(values) > 0:
   953	        for _ in range(repetitions):
   954	            sample = _moving_block_sample(values, block_length=block_length, rng=rng)
   955	            boot_means.append(float(np.mean(sample)))
   956	            boot_sharpes.append(_sharpe(sample))
   957	    observed_score_return_corr = _score_return_correlation(selected.traces, features)
   958	    shifted = []
   959	    returns_by_bar = features.set_index("bar_start_utc")["forward_return"].to_numpy()
   960	    scores = np.array(
   961	        [
   962	            trace.aggregated_signals[0].score if trace.aggregated_signals else 0.0
   963	            for trace in selected.traces
   964	        ],
   965	        dtype="float64",
   966	    )
   967	    n = min(len(scores), len(returns_by_bar))
   968	    if n > 2:
   969	        for _ in range(permutation_repetitions):
   970	            shift = int(rng.integers(1, n))
   971	            shifted.append(float(np.corrcoef(scores[:n], np.roll(returns_by_bar[:n], shift))[0, 1]))
   972	    cost_stress = {
   973	        "1x_recorded_net_roi": float(selected.metrics["net_roi"]),
   974	        "gross_to_net_total_return_decay": float(
   975	            selected.metrics["gross_to_net_total_return_decay"]
   976	        ),
   977	        "reported_as_validation_only": 1.0,
   978	    }
   979	    return {
   980	        "block_bootstrap": {
   981	            "repetitions": repetitions,
   982	            "block_length_days": block_length,
   983	            "mean_return_ci_95": _percentiles(boot_means),
   984	            "sharpe_ci_95": _percentiles(boot_sharpes),
   985	        },
   986	        "circular_shift_randomization": {
   987	            "repetitions": permutation_repetitions,
   988	            "observed_score_forward_return_correlation": observed_score_return_corr,
   989	            "two_sided_p_value": _two_sided_p_value(observed_score_return_corr, shifted),
   990	        },
   991	        "multiple_seeds": {
   992	            "seeds": [int(seed) for seed in config["statistics"]["random_seeds"]],
   993	            "purpose": (
   994	                "ML walk-forward fitting repeated across configured seeds; first seed drives "
   995	                "trading artifacts"
   996	            ),
   997	        },
   998	        "cost_sensitivity": cost_stress,
   999	        "cadence": cadence,
  1000	    }
  1001
  1002
  1003	def _moving_block_sample(
  1004	    values: np.ndarray, *, block_length: int, rng: np.random.Generator
  1005	) -> np.ndarray:
  1006	    if len(values) == 0:
  1007	        return values
  1008	    block = max(1, min(block_length, len(values)))
  1009	    samples: list[float] = []
  1010	    while len(samples) < len(values):
  1011	        start = int(rng.integers(0, len(values)))
  1012	        for offset in range(block):
  1013	            samples.append(float(values[(start + offset) % len(values)]))
  1014	            if len(samples) >= len(values):
  1015	                break
  1016	    return np.array(samples, dtype="float64")
  1017
  1018
  1019	def _sharpe(values: np.ndarray) -> float:
  1020	    std = float(np.std(values, ddof=1)) if len(values) > 1 else 0.0
  1021	    return float(np.mean(values) / std * np.sqrt(365.0)) if std > 0 else 0.0
  1022
  1023
  1024	def _percentiles(values: list[float]) -> list[float]:
  1025	    if not values:
  1026	        return [0.0, 0.0]
  1027	    low, high = np.percentile(np.array(values, dtype="float64"), [2.5, 97.5])
  1028	    return [float(low), float(high)]
  1029
