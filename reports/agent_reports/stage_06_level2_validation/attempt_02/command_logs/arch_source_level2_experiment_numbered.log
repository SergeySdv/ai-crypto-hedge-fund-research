   521	def _econometric_predictions(
   522	    features: pd.DataFrame,
   523	    *,
   524	    validation_mask: pd.Series,
   525	    refit_frequency: str,
   526	) -> pd.DataFrame:
   527	    if refit_frequency not in {"daily", "daily_causal", "daily_expanding_validation"}:
   528	        msg = f"unsupported econometric refit frequency: {refit_frequency}"
   529	        raise ValueError(msg)
   530	    rows: list[dict[str, object]] = []
   531	    validation_rows = features.loc[validation_mask].copy()
   532	    open_returns = features.set_index("bar_start_utc")["open_return_1d"]
   533	    for row in validation_rows.itertuples(index=False):
   534	        execution_time = pd.Timestamp(row.execution_time)
   535	        available = features.loc[features["label_observation_time"] < execution_time]
   536	        history = open_returns.reindex(available["bar_start_utc"]).dropna()
   537	        forecast = fit_econometric_forecast(history)
   538	        if forecast.status == "ok" and forecast.volatility > 0:
   539	            risk_adjusted = forecast.expected_return / max(forecast.volatility, 1e-8)
   540	            score = float(np.tanh(risk_adjusted * 3.0))
   541	            confidence = float(min(1.0, abs(risk_adjusted) * 4.0))
   542	            status = "ok"
   543	        else:
   544	            score = 0.0
   545	            confidence = 0.0
   546	            status = "abstain"
   547	        rows.append(
   548	            {
   549	                "bar_start_utc": pd.Timestamp(row.bar_start_utc),
   550	                "execution_time": execution_time,
   551	                "feature_cutoff": pd.Timestamp(row.feature_cutoff),
   552	                "fit_cutoff": pd.Timestamp(available["label_observation_time"].max())
   553	                if not available.empty
   554	                else pd.NaT,
   555	                "probability": 0.5 + score / 2.0,
   556	                "score": score,
   557	                "confidence": confidence,
   558	                "expected_return": forecast.expected_return,
   559	                "forecast_volatility": forecast.volatility,
   560	                "target_label": int(row.target_label),
   561	                "forward_return": float(row.forward_return),
   562	                "method": forecast.method,
   563	                "status": status,
   564	                "reason": forecast.reason,
   565	                "refit_frequency": "daily_causal",
   566	                "train_samples": len(history),
   567	                "used_future_labels": bool(
   568	                    not available.empty
   569	                    and (available["label_observation_time"] >= execution_time).any()
   570	                ),
   571	            }
   572	        )
   573	    return pd.DataFrame(rows)
   574
   575
   576	def _directional_prediction_metrics(predictions: pd.DataFrame) -> dict[str, float]:
   577	    if predictions.empty:
   578	        return {"directional_accuracy": 0.0, "coverage": 0.0}
   579	    active = predictions.loc[predictions["status"] == "ok"].copy()
   580	    if active.empty:
   581	        return {"directional_accuracy": 0.0, "coverage": 0.0}
   582	    predicted = active["expected_return"] > 0
   583	    actual = active["forward_return"] > active.get("target_threshold_return", 0.0)
   584	    return {
   585	        "directional_accuracy": float((predicted == actual).mean()),
   586	        "coverage": float(len(active) / len(predictions)),
   587	        "mean_forecast_volatility": float(active["forecast_volatility"].mean()),
   588	    }
