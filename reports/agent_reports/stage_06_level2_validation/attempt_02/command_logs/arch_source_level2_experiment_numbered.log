   813	def _write_level2_artifacts(
   814	    approaches: list[_ApproachResult],
   815	    *,
   816	    output_dir: Path,
   817	    provenance: ArtifactProvenance,
   818	) -> dict[str, Path]:
   819	    paths = {
   820	        "metrics": output_dir / "metrics" / "level_2.csv",
   821	        "equity": output_dir / "equity" / "level_2.parquet",
   822	        "weights": output_dir / "weights" / "level_2.parquet",
   823	        "orders": output_dir / "orders" / "level_2.parquet",
   824	        "fills": output_dir / "fills" / "level_2.parquet",
   825	    }
   826	    for path in paths.values():
   827	        path.parent.mkdir(parents=True, exist_ok=True)
   828	    metric_rows: list[dict[str, object]] = []
   829	    equity_frames: list[pd.DataFrame] = []
   830	    weight_frames: list[pd.DataFrame] = []
   831	    order_frames: list[pd.DataFrame] = []
   832	    fill_frames: list[pd.DataFrame] = []
   833	    metadata_columns = BacktestArtifactWriter._provenance_columns(provenance)
   834	    for approach in approaches:
   835	        metric_rows.append(
   836	            {
   837	                "approach": approach.name,
   838	                "selected_for_level_2": approach.name == "agent_ensemble",
   839	                **approach.metrics,
   840	                **metadata_columns,
   841	            }
   842	        )
   843	        equity_frames.append(_tag_frame(approach.net_result.equity, approach.name))
   844	        weight_frames.append(_tag_frame(approach.net_result.weights, approach.name))
   845	        order_frames.append(_tag_frame(approach.net_result.orders, approach.name))
   846	        fill_frames.append(_tag_frame(approach.net_result.fills, approach.name))
   847	    pd.DataFrame(metric_rows).to_csv(paths["metrics"], index=False)
   848	    for key, frames in (
   849	        ("equity", equity_frames),
   850	        ("weights", weight_frames),
   851	        ("orders", order_frames),
   852	        ("fills", fill_frames),
   853	    ):
   854	        frame = pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()
   855	        for meta_key, meta_value in metadata_columns.items():
   856	            frame[meta_key] = meta_value
   857	        frame.to_parquet(paths[key], index=False)
   858	    for path in paths.values():
   859	        _write_metadata_sidecar(path, provenance)
   860	    return paths
