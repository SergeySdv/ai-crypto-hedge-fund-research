   138	def run_level_2_validation(
   139	    *,
   140	    config_path: str | Path = Path("configs/default.yaml"),
   141	    artifacts_dir: str | Path | None = None,
   142	    market_frame: pd.DataFrame | None = None,
   143	) -> Level2ValidationResult:
   144	    """Run validation-only Level 2 and write required comparison artifacts."""
   145
   146	    config = load_config(config_path, resolve_paths=True)
   147	    level_config = dict(config.get("level_2", {}))
   148	    cadence = _level2_cadence(config)
   149	    symbol = str(level_config.get("symbol", config["level_1"]["symbol"]))
   150	    validation_start = pd.Timestamp(ensure_utc(config["splits"]["validation_start"]))
   151	    validation_end = pd.Timestamp(ensure_utc(config["splits"]["validation_end"]))
   152	    train_start = pd.Timestamp(ensure_utc(config["splits"]["train_start"]))
   153	    test_start = pd.Timestamp(ensure_utc(config["splits"]["test_start"]))
   154	    if validation_end >= test_start:
   155	        msg = "validation_end must be before test_start for validation-only Level 2"
   156	        raise ValueError(msg)
   157
   158	    output_dir = (
   159	        Path(artifacts_dir) if artifacts_dir is not None else Path(config["paths"]["artifacts"])
   160	    )
   161	    frame = (
   162	        _load_symbol_frame(config, symbol=symbol, validation_end=validation_end)
   163	        if market_frame is None
   164	        else _normalize_market_frame(market_frame, symbol=symbol, end=validation_end)
   165	    )
   166	    threshold_return = _target_threshold(config)
   167	    features = build_level2_feature_frame(
   168	        frame,
   169	        symbol=symbol,
   170	        horizon_open_days=int(level_config.get("prediction_horizon_open_days", 1)),
   171	        threshold_return=threshold_return,
   172	    )
   173	    validation_mask = (features["execution_time"] >= validation_start) & (
   174	        features["execution_time"] <= validation_end
   175	    )
   176	    if not bool(validation_mask.any()):
   177	        msg = "Level 2 validation feature frame has no validation decisions"
   178	        raise ValueError(msg)
   179
   180	    seeds = tuple(int(seed) for seed in config["statistics"]["random_seeds"])
   181	    ml_outputs = walk_forward_ml_predictions(
   182	        features,
   183	        feature_columns=LEVEL2_FEATURE_COLUMNS,
   184	        validation_mask=validation_mask,
   185	        seeds=seeds,
   186	        min_train_samples=int(level_config.get("min_train_samples", 120)),
   187	        refit_frequency=cadence["ml_refit_frequency"],
   188	    )
   189	    econometric_predictions = _econometric_predictions(
   190	        features,
   191	        validation_mask=validation_mask,
   192	        refit_frequency=cadence["econometric_refit_frequency"],
   193	    )
   194	    prediction_tables = {
   195	        "econometric_ar_garch": econometric_predictions,
   196	        **{output.model_name: output.predictions for output in ml_outputs},
   197	    }
   198	    predictive_metrics = {output.model_name: output.predictive_metrics for output in ml_outputs}
   199	    predictive_metrics["econometric_ar_garch"] = _directional_prediction_metrics(
   200	        econometric_predictions
   201	    )
   202
   203	    market = PanelMarketData.from_ohlcv(frame)
   204	    cost_assumptions = _cost_assumptions(config)
   205	    benchmark = _run_buy_and_hold_benchmark(
   206	        market,
   207	        symbol=symbol,
   208	        decision_bar=validation_start - pd.Timedelta(days=1),
   209	        validation_start=validation_start,
   210	        validation_end=validation_end,
   211	        config=config,
   212	        cost_assumptions=cost_assumptions,
   213	    )
   214	    benchmark_nav = benchmark.equity.set_index("timestamp")["nav"]
   215
   216	    approaches: list[_ApproachResult] = []
   217	    for approach_name, agents, weights in _approach_agents(
   218	        config=config,
   219	        symbol=symbol,
   220	        prediction_tables=prediction_tables,
   221	    ):
   222	        schedule, traces = build_level_2_target_schedule(
   223	            frame=frame,
   224	            features=features,
   225	            symbol=symbol,
   226	            agents=agents,
   227	            agent_weights=weights,
   228	            config=config,
   229	            approach_name=approach_name,
   230	        )
   231	        net_result = _trim_result(
   232	            SimulatedBroker(
   233	                market,
   234	                initial_capital=float(config["backtest"]["initial_capital_usd"]),
   235	                cost_assumptions=cost_assumptions,
   236	            ).run(schedule, end_time=validation_end, run_label=f"{RUN_LABEL}_{approach_name}"),
   237	            start=validation_start,
   238	            end=validation_end,
   239	        )
   240	        gross_result = _trim_result(
   241	            SimulatedBroker(
   242	                market,
   243	                initial_capital=float(config["backtest"]["initial_capital_usd"]),
   244	                cost_assumptions=CostAssumptions(fee_bps_one_way=0.0, slippage_bps_one_way=0.0),
   245	            ).run(
   246	                schedule, end_time=validation_end, run_label=f"{RUN_LABEL}_{approach_name}_gross"
   247	            ),
   248	            start=validation_start,
   249	            end=validation_end,
   250	        )
   251	        metrics = _combined_metrics(
   252	            net_result,
   253	            gross_result,
   254	            benchmark_nav=benchmark_nav,
   255	            config=config,
   256	        )
   257	        if approach_name in predictive_metrics:
   258	            metrics.update(
   259	                {
   260	                    f"predictive_{key}": value
   261	                    for key, value in predictive_metrics[approach_name].items()
   262	                }
   263	            )
   264	        approaches.append(
   265	            _ApproachResult(
   266	                name=approach_name,
   267	                schedule=schedule,
   268	                traces=traces,
   269	                net_result=net_result,
   270	                gross_result=gross_result,
   271	                metrics=metrics,
   272	            )
   273	        )
   274
   275	    selected = next(item for item in approaches if item.name == "agent_ensemble")
   276	    provenance = _provenance(
   277	        config=config,
   278	        symbol=symbol,
   279	        train_start=train_start,
   280	        validation_start=validation_start,
   281	        validation_end=validation_end,
   282	        cost_assumptions=cost_assumptions,
   283	        threshold_return=threshold_return,
   284	        selected_approach=selected.name,
   285	        cadence=cadence,
   286	    )
   287	    artifact_paths = _write_level2_artifacts(
   288	        approaches,
   289	        output_dir=output_dir,
   290	        provenance=provenance,
   291	    )
   292	    figure_path = _write_equity_figure(approaches, output_dir, provenance)
   293	    trace_path = _write_trace(
   294	        traces=selected.traces,
   295	        path=output_dir / "monitoring" / "level_2_decision_trace.json",
   296	        provenance=provenance,
   297	        predictive_metrics=predictive_metrics,
   298	        feature_columns=LEVEL2_FEATURE_COLUMNS,
   299	        cadence=cadence,
   300	    )
   301	    robustness = _robustness_checks(
   302	        selected=selected,
   303	        features=features.loc[validation_mask].copy(),
   304	        config=config,
   305	        cadence=cadence,
   306	    )
   307	    robustness_path = _write_json_artifact(
   308	        output_dir / "monitoring" / "level_2_robustness.json",
   309	        {"provenance": provenance.metadata(), "robustness": robustness},
   310	    )
   311	    prediction_paths = _write_prediction_artifacts(
   312	        output_dir,
   313	        provenance=provenance,
   314	        prediction_tables=prediction_tables,
   315	        ml_outputs=ml_outputs,
   316	        cadence=cadence,
   317	    )
   318	    return Level2ValidationResult(
   319	        metrics={f"{selected.name}_{key}": value for key, value in selected.metrics.items()},
   320	        artifact_paths=artifact_paths,
   321	        figure_path=figure_path,
   322	        trace_path=trace_path,
   323	        robustness_path=robustness_path,
   324	        selected_approach=selected.name,
   325	        feature_columns=LEVEL2_FEATURE_COLUMNS,
   326	        prediction_paths=prediction_paths,
   327	    )
