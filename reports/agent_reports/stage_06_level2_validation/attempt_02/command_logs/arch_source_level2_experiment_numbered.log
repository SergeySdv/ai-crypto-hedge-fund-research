  1052	def _write_prediction_artifacts(
  1053	    output_dir: Path,
  1054	    *,
  1055	    provenance: ArtifactProvenance,
  1056	    prediction_tables: dict[str, pd.DataFrame],
  1057	    ml_outputs: list[Any],
  1058	    cadence: dict[str, str],
  1059	) -> dict[str, Path]:
  1060	    monitoring = output_dir / "monitoring"
  1061	    monitoring.mkdir(parents=True, exist_ok=True)
  1062	    predictions_path = monitoring / "level_2_model_predictions.parquet"
  1063	    audit_path = monitoring / "level_2_fit_audit.parquet"
  1064	    prediction_frames: list[pd.DataFrame] = []
  1065	    for model, table in prediction_tables.items():
  1066	        tagged = _tag_frame(table, model)
  1067	        if "refit_frequency" not in tagged.columns or tagged["refit_frequency"].isna().any():
  1068	            frequency = (
  1069	                cadence["ml_refit_frequency"]
  1070	                if model.startswith("ml_")
  1071	                else cadence["econometric_refit_frequency"]
  1072	            )
  1073	            tagged["refit_frequency"] = tagged.get("refit_frequency", frequency)
  1074	            tagged["refit_frequency"] = tagged["refit_frequency"].fillna(frequency)
  1075	        prediction_frames.append(tagged)
  1076	    predictions = pd.concat(prediction_frames, ignore_index=True)
  1077	    audits = [output.fit_audit for output in ml_outputs]
  1078	    audits.append(
  1079	        prediction_tables["econometric_ar_garch"][
  1080	            [
  1081	                "bar_start_utc",
  1082	                "execution_time",
  1083	                "fit_cutoff",
  1084	                "train_samples",
  1085	                "used_future_labels",
  1086	                "status",
  1087	                "refit_frequency",
  1088	            ]
  1089	        ].assign(model="econometric_ar_garch", seed=0)
  1090	    )
  1091	    prediction_columns = BacktestArtifactWriter._provenance_columns(provenance)
  1092	    for key, value in prediction_columns.items():
  1093	        predictions[key] = value
  1094	    predictions.to_parquet(predictions_path, index=False)
  1095	    pd.concat(audits, ignore_index=True).to_parquet(audit_path, index=False)
  1096	    _write_metadata_sidecar(predictions_path, provenance)
  1097	    _write_metadata_sidecar(audit_path, provenance)
  1098	    return {"predictions": predictions_path, "fit_audit": audit_path}
