     1	"""Educational AutoReg plus GARCH(1,1)-style forecasting helpers."""
     2
     3	from __future__ import annotations
     4
     5	import math
     6	from dataclasses import dataclass
     7
     8	import numpy as np
     9	import pandas as pd
    10	from statsmodels.tsa.ar_model import AutoReg
    11
    12
    13	@dataclass(frozen=True)
    14	class EconometricForecast:
    15	    """One-step expected-return and conditional-volatility forecast."""
    16
    17	    expected_return: float
    18	    volatility: float
    19	    method: str
    20	    status: str
    21	    reason: str
    22
    23
    24	def fit_econometric_forecast(
    25	    returns: pd.Series,
    26	    *,
    27	    max_lags: int = 5,
    28	) -> EconometricForecast:
    29	    """Fit an AutoReg mean and GARCH-style volatility forecast on past returns only."""
    30
    31	    clean = pd.Series(returns, dtype="float64").replace([np.inf, -np.inf], np.nan).dropna()
    32	    if len(clean) < 80 or clean.std(ddof=0) <= 0:
    33	        return EconometricForecast(0.0, 0.0, "insufficient_history", "abstain", "warmup")
    34	    expected = _autoregressive_mean(clean, max_lags=max_lags)
    35	    volatility, method = _garch_volatility(clean - clean.mean())
    36	    if not math.isfinite(expected) or not math.isfinite(volatility) or volatility <= 0:
    37	        return EconometricForecast(0.0, 0.0, method, "abstain", "model_failure")
    38	    return EconometricForecast(float(expected), float(volatility), method, "ok", "ok")
    39
    40
    41	def _autoregressive_mean(returns: pd.Series, *, max_lags: int) -> float:
    42	    lags = min(max_lags, max(1, len(returns) // 40))
    43	    try:
    44	        model = AutoReg(returns.to_numpy(), lags=lags, old_names=False).fit()
    45	        forecast = float(model.predict(start=len(returns), end=len(returns))[0])
    46	    except Exception:
    47	        forecast = float(returns.tail(20).mean())
    48	    return forecast
    49
    50
    51	def _garch_volatility(residuals: pd.Series) -> tuple[float, str]:
    52	    """Forecast daily conditional volatility with arch when available, else EWMA GARCH."""
    53
    54	    clean = residuals.replace([np.inf, -np.inf], np.nan).dropna()
    55	    if len(clean) < 80:
    56	        return 0.0, "insufficient_history"
    57	    try:
    58	        from arch import arch_model
    59
    60	        scaled = clean.to_numpy() * 100.0
    61	        model = arch_model(scaled, mean="Zero", vol="GARCH", p=1, q=1, rescale=False)
    62	        fit = model.fit(disp="off", show_warning=False)
    63	        variance = float(fit.forecast(horizon=1).variance.iloc[-1, 0]) / 10_000.0
    64	        if math.isfinite(variance) and variance > 0:
    65	            return math.sqrt(variance), "arch_garch_1_1"
    66	    except Exception:
    67	        pass
    68	    return _educational_garch_fallback(clean), "educational_garch_1_1_fallback"
    69
    70
    71	def _educational_garch_fallback(residuals: pd.Series) -> float:
    72	    """Deterministic GARCH(1,1)-style EWMA recursion without external solvers."""
    73
    74	    clean = residuals.to_numpy(dtype="float64")
    75	    unconditional = float(np.var(clean, ddof=0))
    76	    if not math.isfinite(unconditional) or unconditional <= 0:
    77	        return 0.0
    78	    alpha = 0.08
    79	    beta = 0.90
    80	    omega = max(1e-12, unconditional * (1.0 - alpha - beta))
    81	    variance = unconditional
    82	    for value in clean:
    83	        variance = omega + alpha * float(value * value) + beta * variance
    84	    return math.sqrt(max(variance, 1e-12))
