     1	"""Level 2 one-pair causal features and next-open targets."""
     2
     3	from __future__ import annotations
     4
     5	import numpy as np
     6	import pandas as pd
     7
     8	LEVEL2_FEATURE_COLUMNS = (
     9	    "open_return_1d",
    10	    "close_return_1d",
    11	    "return_5d",
    12	    "return_10d",
    13	    "return_20d",
    14	    "sma_ratio_10_50",
    15	    "ema_ratio_12_26",
    16	    "rsi_14",
    17	    "macd",
    18	    "macd_signal",
    19	    "atr_14_norm",
    20	    "realized_vol_7",
    21	    "realized_vol_20",
    22	    "realized_vol_60",
    23	    "range_norm",
    24	    "close_open_return",
    25	    "gap_return",
    26	    "drawdown_60",
    27	    "volume_z_20",
    28	    "dollar_volume_z_20",
    29	)
    30
    31
    32	def build_level2_feature_frame(
    33	    frame: pd.DataFrame,
    34	    *,
    35	    symbol: str,
    36	    horizon_open_days: int = 1,
    37	    threshold_return: float = 0.0,
    38	) -> pd.DataFrame:
    39	    """Return one causal row per completed bar with aligned open-to-open target.
    40
    41	    Features use data available at ``bar_start_utc`` after that daily bar has
    42	    completed. The label starts at the next open and ends after the requested
    43	    open-day horizon. ``label_observation_time`` records when that target return
    44	    is knowable and is used by the walk-forward model code to prevent leakage.
    45	    """
    46
    47	    if horizon_open_days != 1:
    48	        msg = "Level 2 currently supports the required one open-day horizon"
    49	        raise ValueError(msg)
    50	    data = _normalize(frame, symbol=symbol)
    51	    close = data["close"].astype("float64")
    52	    open_ = data["open"].astype("float64")
    53	    high = data["high"].astype("float64")
    54	    low = data["low"].astype("float64")
    55	    volume = data["volume"].astype("float64")
    56	    dollar_volume = data["dollar_volume"].astype("float64")
    57
    58	    out = data[
    59	        [
    60	            "bar_start_utc",
    61	            "bar_end_utc",
    62	            "symbol",
    63	            "open",
    64	            "high",
    65	            "low",
    66	            "close",
    67	            "volume",
    68	            "dollar_volume",
    69	            "exchange",
    70	            "market_type",
    71	            "timeframe",
    72	        ]
    73	    ].copy()
    74	    open_returns = open_.pct_change()
    75	    close_returns = close.pct_change()
    76	    out["open_return_1d"] = open_returns
    77	    out["close_return_1d"] = close_returns
    78	    out["return_5d"] = close.pct_change(5)
    79	    out["return_10d"] = close.pct_change(10)
    80	    out["return_20d"] = close.pct_change(20)
    81	    out["sma_ratio_10_50"] = (
    82	        close.rolling(10, min_periods=10).mean() / close.rolling(50, min_periods=50).mean() - 1.0
    83	    )
    84	    out["ema_ratio_12_26"] = (
    85	        close.ewm(span=12, adjust=False, min_periods=12).mean()
    86	        / close.ewm(span=26, adjust=False, min_periods=26).mean()
    87	        - 1.0
    88	    )
    89	    rsi = _rsi(close, window=14)
    90	    out["rsi_14"] = rsi / 100.0
    91	    macd = (
    92	        close.ewm(span=12, adjust=False, min_periods=12).mean()
    93	        - close.ewm(span=26, adjust=False, min_periods=26).mean()
    94	    )
    95	    macd_signal = macd.ewm(span=9, adjust=False, min_periods=9).mean()
    96	    out["macd"] = macd / close
    97	    out["macd_signal"] = macd_signal / close
    98	    out["atr_14_norm"] = _atr(high, low, close, window=14) / close
    99	    out["realized_vol_7"] = close_returns.rolling(7, min_periods=7).std(ddof=0) * np.sqrt(365.0)
   100	    out["realized_vol_20"] = close_returns.rolling(20, min_periods=20).std(ddof=0) * np.sqrt(365.0)
   101	    out["realized_vol_60"] = close_returns.rolling(60, min_periods=60).std(ddof=0) * np.sqrt(365.0)
   102	    out["range_norm"] = (high - low) / close
   103	    out["close_open_return"] = close / open_ - 1.0
   104	    out["gap_return"] = open_ / close.shift(1) - 1.0
   105	    out["drawdown_60"] = close / close.rolling(60, min_periods=60).max() - 1.0
   106	    out["volume_z_20"] = _rolling_zscore(volume, window=20)
   107	    out["dollar_volume_z_20"] = _rolling_zscore(dollar_volume, window=20)
   108
   109	    execution_open = open_.shift(-1)
   110	    future_open = open_.shift(-2)
   111	    out["execution_time"] = out["bar_start_utc"] + pd.Timedelta(days=1)
   112	    out["future_open_time"] = out["bar_start_utc"] + pd.Timedelta(days=2)
   113	    out["feature_cutoff"] = out["bar_end_utc"]
   114	    out["forward_return"] = future_open / execution_open - 1.0
   115	    out["target_label"] = (out["forward_return"] > threshold_return).astype("int64")
   116	    out["target_threshold_return"] = float(threshold_return)
   117	    out["label_observation_time"] = out["future_open_time"]
   118	    out["feature_set"] = "level2_daily_causal_v1"
   119	    out = out.replace([np.inf, -np.inf], np.nan)
   120	    return out.dropna(subset=[*LEVEL2_FEATURE_COLUMNS, "forward_return"]).reset_index(drop=True)
   121
   122
   123	def _normalize(frame: pd.DataFrame, *, symbol: str) -> pd.DataFrame:
   124	    source = frame.copy()
   125	    if isinstance(source.index, pd.MultiIndex) and "bar_start_utc" in source.index.names:
   126	        source = source.reset_index()
   127	    if "bar_start_utc" not in source.columns or "symbol" not in source.columns:
   128	        msg = "Level 2 feature input requires bar_start_utc and symbol columns"
   129	        raise ValueError(msg)
   130	    source["bar_start_utc"] = pd.to_datetime(source["bar_start_utc"], utc=True)
   131	    source["bar_end_utc"] = (
   132	        pd.to_datetime(source["bar_end_utc"], utc=True)
   133	        if "bar_end_utc" in source.columns
   134	        else source["bar_start_utc"] + pd.Timedelta(days=1)
   135	    )
   136	    source["symbol"] = source["symbol"].astype(str)
   137	    source = source.loc[source["symbol"] == symbol].sort_values("bar_start_utc", kind="mergesort")
   138	    if source["bar_start_utc"].duplicated().any():
   139	        msg = f"duplicate bars for {symbol}"
   140	        raise ValueError(msg)
   141	    required = ("open", "high", "low", "close", "volume", "dollar_volume")
   142	    missing = [column for column in required if column not in source.columns]
   143	    if missing:
   144	        msg = f"Level 2 feature input is missing columns: {missing}"
   145	        raise ValueError(msg)
   146	    for column in required:
   147	        source[column] = pd.to_numeric(source[column], errors="coerce")
   148	    if not ((source[["open", "high", "low", "close"]] > 0).all().all()):
   149	        msg = "Level 2 feature input prices must be positive"
   150	        raise ValueError(msg)
   151	    for optional in ("exchange", "market_type", "timeframe"):
   152	        if optional not in source.columns:
   153	            source[optional] = ""
   154	    return source.reset_index(drop=True)
   155
   156
   157	def _rsi(close: pd.Series, *, window: int) -> pd.Series:
   158	    delta = close.diff()
   159	    gains = delta.clip(lower=0.0).rolling(window, min_periods=window).mean()
   160	    losses = (-delta.clip(upper=0.0)).rolling(window, min_periods=window).mean()
   161	    rs = gains / losses.replace(0.0, np.nan)
   162	    return 100.0 - 100.0 / (1.0 + rs)
   163
   164
   165	def _atr(high: pd.Series, low: pd.Series, close: pd.Series, *, window: int) -> pd.Series:
   166	    previous_close = close.shift(1)
   167	    true_range = pd.concat(
   168	        [
   169	            high - low,
   170	            (high - previous_close).abs(),
   171	            (low - previous_close).abs(),
   172	        ],
   173	        axis=1,
   174	    ).max(axis=1)
   175	    return true_range.rolling(window, min_periods=window).mean()
   176
   177
   178	def _rolling_zscore(series: pd.Series, *, window: int) -> pd.Series:
   179	    mean = series.rolling(window, min_periods=window).mean()
   180	    std = series.rolling(window, min_periods=window).std(ddof=0)
   181	    return (series - mean) / std.replace(0.0, np.nan)
