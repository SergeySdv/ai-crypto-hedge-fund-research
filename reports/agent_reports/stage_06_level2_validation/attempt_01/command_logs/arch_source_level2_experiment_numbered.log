   694	def _trim_result(
   695	    result: BacktestRunResult, *, start: pd.Timestamp, end: pd.Timestamp
   696	) -> BacktestRunResult:
   697	    def trim(frame: pd.DataFrame) -> pd.DataFrame:
   698	        if frame.empty or "timestamp" not in frame.columns:
   699	            return frame.copy()
   700	        timestamps = pd.to_datetime(frame["timestamp"], utc=True)
   701	        return frame.loc[(timestamps >= start) & (timestamps <= end)].reset_index(drop=True)
   702
   703	    return BacktestRunResult(
   704	        equity=trim(result.equity),
   705	        weights=trim(result.weights),
   706	        orders=trim(result.orders),
   707	        fills=trim(result.fills),
   708	    )
