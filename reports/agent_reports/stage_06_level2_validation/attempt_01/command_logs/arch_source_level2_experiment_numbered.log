   617	def _normalize_market_frame(
   618	    frame: pd.DataFrame,
   619	    *,
   620	    symbol: str,
   621	    end: pd.Timestamp,
   622	) -> pd.DataFrame:
   623	    source = frame.copy()
   624	    if isinstance(source.index, pd.MultiIndex) and "bar_start_utc" in source.index.names:
   625	        source = source.reset_index()
   626	    if "bar_start_utc" not in source.columns or "symbol" not in source.columns:
   627	        msg = "market frame must contain bar_start_utc and symbol columns"
   628	        raise ValueError(msg)
   629	    source["bar_start_utc"] = pd.to_datetime(source["bar_start_utc"], utc=True)
   630	    source["bar_end_utc"] = (
   631	        pd.to_datetime(source["bar_end_utc"], utc=True)
   632	        if "bar_end_utc" in source.columns
   633	        else source["bar_start_utc"] + pd.Timedelta(days=1)
   634	    )
   635	    source["symbol"] = source["symbol"].astype(str)
   636	    source = source.loc[(source["symbol"] == symbol) & (source["bar_start_utc"] <= end)]
   637	    source = source.sort_values("bar_start_utc", kind="mergesort").reset_index(drop=True)
   638	    if source["bar_start_utc"].duplicated().any():
   639	        msg = f"duplicate bars for {symbol}"
   640	        raise ValueError(msg)
   641	    return source
   642
