   138	def run_level_2_validation(
   139	    *,
   140	    config_path: str | Path = Path("configs/default.yaml"),
   141	    artifacts_dir: str | Path | None = None,
   142	    market_frame: pd.DataFrame | None = None,
   143	) -> Level2ValidationResult:
   144	    """Run validation-only Level 2 and write required comparison artifacts."""
   145
   146	    config = load_config(config_path, resolve_paths=True)
   147	    level_config = dict(config.get("level_2", {}))
   148	    symbol = str(level_config.get("symbol", config["level_1"]["symbol"]))
   149	    validation_start = pd.Timestamp(ensure_utc(config["splits"]["validation_start"]))
   150	    validation_end = pd.Timestamp(ensure_utc(config["splits"]["validation_end"]))
   151	    train_start = pd.Timestamp(ensure_utc(config["splits"]["train_start"]))
   152	    test_start = pd.Timestamp(ensure_utc(config["splits"]["test_start"]))
   153	    if validation_end >= test_start:
   154	        msg = "validation_end must be before test_start for validation-only Level 2"
   155	        raise ValueError(msg)
   156
   157	    output_dir = (
   158	        Path(artifacts_dir) if artifacts_dir is not None else Path(config["paths"]["artifacts"])
   159	    )
   160	    frame = (
   161	        _load_symbol_frame(config, symbol=symbol, validation_end=validation_end)
   162	        if market_frame is None
   163	        else _normalize_market_frame(market_frame, symbol=symbol, end=validation_end)
   164	    )
   165	    threshold_return = _target_threshold(config)
   166	    features = build_level2_feature_frame(
   167	        frame,
   168	        symbol=symbol,
   169	        horizon_open_days=int(level_config.get("prediction_horizon_open_days", 1)),
   170	        threshold_return=threshold_return,
   171	    )
   172	    validation_mask = (features["execution_time"] >= validation_start) & (
   173	        features["execution_time"] <= validation_end
   174	    )
   175	    if not bool(validation_mask.any()):
   176	        msg = "Level 2 validation feature frame has no validation decisions"
   177	        raise ValueError(msg)
   178
   179	    seeds = tuple(int(seed) for seed in config["statistics"]["random_seeds"])
   180	    ml_outputs = walk_forward_ml_predictions(
   181	        features,
   182	        feature_columns=LEVEL2_FEATURE_COLUMNS,
   183	        validation_mask=validation_mask,
   184	        seeds=seeds,
   185	        min_train_samples=int(level_config.get("min_train_samples", 120)),
   186	        refit_frequency=str(level_config.get("default_retrain", "monthly")),
   187	    )
   188	    econometric_predictions = _econometric_predictions(features, validation_mask=validation_mask)
   189	    prediction_tables = {
   190	        "econometric_ar_garch": econometric_predictions,
   191	        **{output.model_name: output.predictions for output in ml_outputs},
   192	    }
   193	    predictive_metrics = {output.model_name: output.predictive_metrics for output in ml_outputs}
   194	    predictive_metrics["econometric_ar_garch"] = _directional_prediction_metrics(
   195	        econometric_predictions
   196	    )
   197
   198	    market = PanelMarketData.from_ohlcv(frame)
   199	    cost_assumptions = _cost_assumptions(config)
   200	    benchmark = _run_buy_and_hold_benchmark(
   201	        market,
   202	        symbol=symbol,
   203	        decision_bar=validation_start - pd.Timedelta(days=1),
   204	        validation_start=validation_start,
   205	        validation_end=validation_end,
   206	        config=config,
   207	        cost_assumptions=cost_assumptions,
   208	    )
   209	    benchmark_nav = benchmark.equity.set_index("timestamp")["nav"]
   210
   211	    approaches: list[_ApproachResult] = []
   212	    for approach_name, agents, weights in _approach_agents(
   213	        config=config,
   214	        symbol=symbol,
   215	        prediction_tables=prediction_tables,
   216	    ):
   217	        schedule, traces = build_level_2_target_schedule(
   218	            frame=frame,
   219	            features=features,
   220	            symbol=symbol,
   221	            agents=agents,
   222	            agent_weights=weights,
   223	            config=config,
   224	            approach_name=approach_name,
   225	        )
   226	        net_result = _trim_result(
   227	            SimulatedBroker(
   228	                market,
   229	                initial_capital=float(config["backtest"]["initial_capital_usd"]),
   230	                cost_assumptions=cost_assumptions,
   231	            ).run(schedule, end_time=validation_end, run_label=f"{RUN_LABEL}_{approach_name}"),
   232	            start=validation_start,
   233	            end=validation_end,
   234	        )
   235	        gross_result = _trim_result(
   236	            SimulatedBroker(
   237	                market,
   238	                initial_capital=float(config["backtest"]["initial_capital_usd"]),
   239	                cost_assumptions=CostAssumptions(fee_bps_one_way=0.0, slippage_bps_one_way=0.0),
   240	            ).run(
   241	                schedule, end_time=validation_end, run_label=f"{RUN_LABEL}_{approach_name}_gross"
   242	            ),
   243	            start=validation_start,
   244	            end=validation_end,
   245	        )
   246	        metrics = _combined_metrics(
   247	            net_result,
   248	            gross_result,
   249	            benchmark_nav=benchmark_nav,
   250	            config=config,
   251	        )
   252	        if approach_name in predictive_metrics:
   253	            metrics.update(
   254	                {
   255	                    f"predictive_{key}": value
   256	                    for key, value in predictive_metrics[approach_name].items()
   257	                }
   258	            )
   259	        approaches.append(
   260	            _ApproachResult(
   261	                name=approach_name,
   262	                schedule=schedule,
   263	                traces=traces,
   264	                net_result=net_result,
   265	                gross_result=gross_result,
   266	                metrics=metrics,
   267	            )
   268	        )
   269
   270	    selected = next(item for item in approaches if item.name == "agent_ensemble")
   271	    provenance = _provenance(
   272	        config=config,
   273	        symbol=symbol,
   274	        train_start=train_start,
   275	        validation_start=validation_start,
   276	        validation_end=validation_end,
   277	        cost_assumptions=cost_assumptions,
   278	        threshold_return=threshold_return,
   279	        selected_approach=selected.name,
   280	    )
   281	    artifact_paths = _write_level2_artifacts(
   282	        approaches,
   283	        output_dir=output_dir,
   284	        provenance=provenance,
   285	    )
   286	    figure_path = _write_equity_figure(approaches, output_dir, provenance)
   287	    trace_path = _write_trace(
   288	        traces=selected.traces,
   289	        path=output_dir / "monitoring" / "level_2_decision_trace.json",
   290	        provenance=provenance,
   291	        predictive_metrics=predictive_metrics,
   292	        feature_columns=LEVEL2_FEATURE_COLUMNS,
   293	    )
   294	    robustness = _robustness_checks(
   295	        selected=selected,
   296	        features=features.loc[validation_mask].copy(),
   297	        config=config,
   298	    )
   299	    robustness_path = _write_json_artifact(
   300	        output_dir / "monitoring" / "level_2_robustness.json",
   301	        {"provenance": provenance.metadata(), "robustness": robustness},
   302	    )
   303	    prediction_paths = _write_prediction_artifacts(
   304	        output_dir,
   305	        provenance=provenance,
   306	        prediction_tables=prediction_tables,
   307	        ml_outputs=ml_outputs,
   308	    )
   309	    return Level2ValidationResult(
   310	        metrics={f"{selected.name}_{key}": value for key, value in selected.metrics.items()},
   311	        artifact_paths=artifact_paths,
   312	        figure_path=figure_path,
   313	        trace_path=trace_path,
   314	        robustness_path=robustness_path,
   315	        selected_approach=selected.name,
   316	        feature_columns=LEVEL2_FEATURE_COLUMNS,
   317	        prediction_paths=prediction_paths,
   318	    )
