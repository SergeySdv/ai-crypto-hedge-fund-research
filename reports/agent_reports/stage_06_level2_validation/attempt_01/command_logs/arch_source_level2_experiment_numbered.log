   321	def build_level_2_target_schedule(
   322	    *,
   323	    frame: pd.DataFrame,
   324	    features: pd.DataFrame,
   325	    symbol: str,
   326	    agents: tuple[Any, ...],
   327	    agent_weights: dict[str, float],
   328	    config: dict[str, Any],
   329	    approach_name: str,
   330	) -> tuple[pd.DataFrame, tuple[DecisionTrace, ...]]:
   331	    """Create risk-approved target weights through the Stage 4 orchestrator path."""
   332
   333	    normalized = _normalize_market_frame(
   334	        frame,
   335	        symbol=symbol,
   336	        end=pd.Timestamp(ensure_utc(config["splits"]["validation_end"])),
   337	    )
   338	    validation_start = pd.Timestamp(ensure_utc(config["splits"]["validation_start"]))
   339	    validation_end = pd.Timestamp(ensure_utc(config["splits"]["validation_end"]))
   340	    first_decision_bar = validation_start - pd.Timedelta(days=1)
   341	    orchestrator = TypedAgentOrchestrator(
   342	        agents,
   343	        aggregator=SignalAggregator(
   344	            agent_weights=agent_weights,
   345	            disagreement_threshold=float(config["risk"]["max_agent_disagreement"]),
   346	        ),
   347	    )
   348	    level_config = dict(config.get("level_2", {}))
   349	    pre_risk = PreAllocationRiskPolicy(
   350	        max_gross_exposure=float(config["portfolio"]["max_gross_exposure"]),
   351	        max_per_asset_weight=float(level_config.get("max_weight", 1.0)),
   352	        cost_buffer_weight=float(level_config.get("cost_buffer_weight", 0.005)),
   353	        min_dollar_volume=float(level_config.get("min_dollar_volume", 0.0)),
   354	        max_stale_data_days=0,
   355	        max_model_age_days=int(level_config.get("max_model_age_days", 60)),
   356	        max_agent_disagreement=float(config["risk"]["max_agent_disagreement"]),
   357	        volatility_target=None,
   358	        turnover_cap=None,
   359	    )
   360	    allocator = _RiskScaledSingleAssetAllocator(
   361	        max_weight=float(level_config.get("max_weight", 1.0)),
   362	        min_confidence=float(level_config.get("min_confidence", 0.0)),
   363	    )
   364	    rebalance_policy = AlwaysRebalancePolicy(trigger_code=approach_name)
   365	    post_risk = PostAllocationRiskPolicy(
   366	        max_drawdown_stop=float(config["risk"]["max_drawdown_stop"]),
   367	        high_volatility_threshold=float(config["risk"]["high_volatility_threshold_annual"]),
   368	        min_cash_buffer=float(level_config.get("min_cash_buffer", 0.005)),
   369	        annualization_periods=int(config["backtest"]["annualization_periods"]),
   370	    )
   371
   372	    rows: list[dict[str, float]] = []
   373	    index: list[pd.Timestamp] = []
   374	    traces: list[DecisionTrace] = []
   375	    current_weights = pd.Series({symbol: 0.0}, dtype="float64")
   376	    feature_rows = features.loc[
   377	        (features["bar_start_utc"] >= first_decision_bar)
   378	        & (features["execution_time"] >= validation_start)
   379	        & (features["execution_time"] <= validation_end)
   380	    ]
   381	    feature_by_bar = {
   382	        pd.Timestamp(row.bar_start_utc): row for row in feature_rows.itertuples(index=False)
   383	    }
   384	    for bar_start, feature_row in feature_by_bar.items():
   385	        clock = build_daily_research_clock(bar_start.to_pydatetime())
   386	        execution_time = pd.Timestamp(clock.execution_time)
   387	        history = normalized.loc[normalized["bar_start_utc"] <= bar_start].set_index(
   388	            "bar_start_utc"
   389	        )
   390	        model_fit_cutoff = _minimum_fit_cutoff(agents, bar_start, fallback=clock.feature_cutoff)
   391	        context = AgentContext(
   392	            clock=clock,
   393	            symbols=(symbol,),
   394	            model_fit_cutoff=pd.Timestamp(model_fit_cutoff).to_pydatetime(),
   395	            portfolio_nav=float(config["backtest"]["initial_capital_usd"]),
   396	            current_weights=current_weights.to_dict(),
   397	            health_state={
   398	                "realized_volatility": float(getattr(feature_row, "realized_vol_20", 0.0))
   399	            },
   400	            metadata={
   401	                "level": LEVEL_NAME,
   402	                "split": "validation",
   403	                "approach": approach_name,
   404	                "execution_convention": "completed_bar_next_open",
   405	            },
   406	        )
   407	        run = orchestrator.run(history, context)
   408	        constraints = pre_risk.constraints(
   409	            list(run.aggregated_signals),
   410	            context,
   411	            _snapshot_for_bar(normalized, symbol=symbol, bar_start=bar_start),
   412	        )
   413	        signal_series = pd.Series(
   414	            {signal.symbol: signal.score for signal in run.aggregated_signals},
   415	            dtype="float64",
   416	        )
   417	        confidence_by_symbol = {
   418	            f"confidence:{signal.symbol}": signal.confidence for signal in run.aggregated_signals
   419	        }
   420	        current_weights.attrs.update(confidence_by_symbol)
   421	        returns = _historical_open_returns(normalized, through=bar_start)
   422	        proposal = allocator.allocate(signal_series, returns, constraints, current_weights)
   423	        rebalance = rebalance_policy.decide(proposal, current_weights, context)
   424	        approval = post_risk.approve(proposal, rebalance, constraints, context, returns)
   425	        executable = resolve_risk_approval_targets(approval, context)
   426	        target = pd.Series(executable.risky_weights, dtype="float64").reindex(
   427	            [symbol], fill_value=0.0
   428	        )
   429	        rows.append({symbol: float(target.get(symbol, 0.0))})
   430	        index.append(bar_start)
   431	        current_weights = target
   432	        traces.append(
   433	            DecisionTrace(
   434	                clock=clock,
   435	                signals=run.signals,
   436	                aggregated_signals=run.aggregated_signals,
   437	                constraints=constraints,
   438	                proposal=proposal,
   439	                approval=approval,
   440	                events=run.events,
   441	                metadata={
   442	                    "level": LEVEL_NAME,
   443	                    "split": "validation",
   444	                    "approach": approach_name,
   445	                    "execution_time": execution_time.isoformat(),
   446	                    "resolved_action": executable.action,
   447	                    "resolved_weights": dict(executable.risky_weights),
   448	                    "resolved_cash_weight": executable.cash_weight,
   449	                    "forward_return": float(feature_row.forward_return),
   450	                },
   451	            )
   452	        )
   453
   454	    if not rows:
   455	        msg = f"Level 2 {approach_name} produced no executable target-weight rows"
   456	        raise ValueError(msg)
   457	    return pd.DataFrame(rows, index=pd.DatetimeIndex(index, tz="UTC")), tuple(traces)
   458
