   577	def _target_threshold(config: dict[str, Any]) -> float:
   578	    one_way_bps = float(config["backtest"]["fee_bps_one_way"]) + float(
   579	        config["backtest"]["slippage_bps_one_way"]
   580	    )
   581	    safety_bps = float(config.get("level_2", {}).get("safety_margin_bps", 5.0))
   582	    return (one_way_bps + safety_bps) / 10_000.0
