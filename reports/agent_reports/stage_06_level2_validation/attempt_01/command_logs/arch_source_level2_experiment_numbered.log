   494	def _minimum_fit_cutoff(
   495	    agents: tuple[Any, ...],
   496	    bar_start: pd.Timestamp,
   497	    *,
   498	    fallback: pd.Timestamp,
   499	) -> pd.Timestamp:
   500	    cutoffs: list[pd.Timestamp] = []
   501	    for agent in agents:
   502	        table = getattr(agent, "predictions", None)
   503	        if isinstance(table, pd.DataFrame) and not table.empty:
   504	            normalized = table.copy()
   505	            normalized["bar_start_utc"] = pd.to_datetime(normalized["bar_start_utc"], utc=True)
   506	            rows = normalized.loc[normalized["bar_start_utc"] == bar_start]
   507	            if not rows.empty and pd.notna(rows.iloc[-1].get("fit_cutoff")):
   508	                cutoffs.append(pd.Timestamp(rows.iloc[-1]["fit_cutoff"]))
   509	    return min(cutoffs) if cutoffs else fallback
