    86	class _RiskScaledSingleAssetAllocator:
    87	    name = "level2_risk_scaled_single_asset"
    88
    89	    def __init__(self, *, max_weight: float, min_confidence: float) -> None:
    90	        self.max_weight = float(max_weight)
    91	        self.min_confidence = float(min_confidence)
    92
    93	    def allocate(
    94	        self,
    95	        signals: pd.Series,
    96	        historical_returns: pd.DataFrame,
    97	        constraints: RiskConstraints,
    98	        previous_weights: pd.Series,
    99	    ) -> PortfolioProposal:
   100	        del historical_returns
   101	        clean = signals.astype("float64").replace([math.inf, -math.inf], math.nan).dropna()
   102	        weights: dict[str, float] = {}
   103	        for symbol, score in clean.items():
   104	            symbol = str(symbol)
   105	            confidence = float(previous_weights.attrs.get(f"confidence:{symbol}", 1.0))
   106	            if (
   107	                score > 0
   108	                and confidence >= self.min_confidence
   109	                and symbol not in constraints.blocked_symbols
   110	                and constraints.per_asset_caps.get(symbol, 0.0) > 0
   111	            ):
   112	                raw_weight = min(1.0, max(0.0, float(score) * confidence)) * self.max_weight
   113	                weights[symbol] = min(
   114	                    raw_weight,
   115	                    constraints.max_gross_exposure,
   116	                    constraints.per_asset_caps.get(symbol, 0.0),
   117	                )
   118	        target = pd.Series(weights, dtype="float64")
   119	        previous = previous_weights.astype("float64").reindex(target.index, fill_value=0.0)
   120	        expected_turnover = (
   121	            float((target - previous).abs().sum())
   122	            if not target.empty
   123	            else float(previous_weights.abs().sum())
   124	        )
   125	        risky_sum = sum(weights.values())
   126	        return PortfolioProposal(
   127	            decision_time=constraints.decision_time,
   128	            target_weights=weights,
   129	            cash_weight=1.0 - risky_sum,
   130	            optimizer_status="ok",
   131	            expected_turnover=expected_turnover,
   132	            objective_value=None,
   133	            reason_codes=(ReasonCode.OK,),
   134	            metadata={"allocator": self.name, "min_confidence": self.min_confidence},
   135	        )
   136
