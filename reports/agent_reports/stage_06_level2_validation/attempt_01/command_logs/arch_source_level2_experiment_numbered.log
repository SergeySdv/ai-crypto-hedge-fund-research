  1012	def _write_prediction_artifacts(
  1013	    output_dir: Path,
  1014	    *,
  1015	    provenance: ArtifactProvenance,
  1016	    prediction_tables: dict[str, pd.DataFrame],
  1017	    ml_outputs: list[Any],
  1018	) -> dict[str, Path]:
  1019	    monitoring = output_dir / "monitoring"
  1020	    monitoring.mkdir(parents=True, exist_ok=True)
  1021	    predictions_path = monitoring / "level_2_model_predictions.parquet"
  1022	    audit_path = monitoring / "level_2_fit_audit.parquet"
  1023	    predictions = pd.concat(
  1024	        [_tag_frame(table, model) for model, table in prediction_tables.items()],
  1025	        ignore_index=True,
