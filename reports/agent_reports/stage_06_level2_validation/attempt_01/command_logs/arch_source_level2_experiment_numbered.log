   802	    for approach in approaches:
   803	        metric_rows.append(
   804	            {
   805	                "approach": approach.name,
   806	                "selected_for_level_2": approach.name == "agent_ensemble",
   807	                **approach.metrics,
   808	                **metadata_columns,
   809	            }
   810	        )
   811	        equity_frames.append(_tag_frame(approach.net_result.equity, approach.name))
   812	        weight_frames.append(_tag_frame(approach.net_result.weights, approach.name))
   813	        order_frames.append(_tag_frame(approach.net_result.orders, approach.name))
   814	        fill_frames.append(_tag_frame(approach.net_result.fills, approach.name))
   815	    pd.DataFrame(metric_rows).to_csv(paths["metrics"], index=False)
   816	    for key, frames in (
   817	        ("equity", equity_frames),
   818	        ("weights", weight_frames),
   819	        ("orders", order_frames),
   820	        ("fills", fill_frames),
   821	    ):
   822	        frame = pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()
   823	        for meta_key, meta_value in metadata_columns.items():
   824	            frame[meta_key] = meta_value
   825	        frame.to_parquet(paths[key], index=False)
   826	    for path in paths.values():
   827	        _write_metadata_sidecar(path, provenance)
   828	    return paths
