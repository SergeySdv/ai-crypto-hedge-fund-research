   711	def _combined_metrics(
   712	    net_result: BacktestRunResult,
   713	    gross_result: BacktestRunResult,
   714	    *,
   715	    benchmark_nav: pd.Series,
   716	    config: dict[str, Any],
   717	) -> dict[str, float]:
   718	    net = calculate_performance_metrics(
   719	        net_result.equity,
   720	        periods_per_year=int(config["backtest"]["annualization_periods"]),
   721	        risk_free_rate=float(config["backtest"]["risk_free_rate"]),
   722	        weights=net_result.weights,
   723	        benchmark_nav=benchmark_nav,
   724	    )
   725	    gross = calculate_performance_metrics(
   726	        gross_result.equity,
   727	        periods_per_year=int(config["backtest"]["annualization_periods"]),
   728	        risk_free_rate=float(config["backtest"]["risk_free_rate"]),
   729	        weights=gross_result.weights,
   730	        benchmark_nav=benchmark_nav,
   731	    )
   732	    metrics = dict(net)
   733	    metrics.update({f"net_{key}": value for key, value in net.items()})
   734	    metrics.update({f"gross_{key}": value for key, value in gross.items()})
   735	    metrics["gross_to_net_total_return_decay"] = gross["total_return"] - net["total_return"]
   736	    return metrics
