   512	def _econometric_predictions(
   513	    features: pd.DataFrame,
   514	    *,
   515	    validation_mask: pd.Series,
   516	) -> pd.DataFrame:
   517	    rows: list[dict[str, object]] = []
   518	    validation_rows = features.loc[validation_mask].copy()
   519	    open_returns = features.set_index("bar_start_utc")["open_return_1d"]
   520	    for row in validation_rows.itertuples(index=False):
   521	        execution_time = pd.Timestamp(row.execution_time)
   522	        available = features.loc[features["label_observation_time"] < execution_time]
   523	        history = open_returns.reindex(available["bar_start_utc"]).dropna()
   524	        forecast = fit_econometric_forecast(history)
   525	        if forecast.status == "ok" and forecast.volatility > 0:
   526	            risk_adjusted = forecast.expected_return / max(forecast.volatility, 1e-8)
   527	            score = float(np.tanh(risk_adjusted * 3.0))
   528	            confidence = float(min(1.0, abs(risk_adjusted) * 4.0))
   529	            status = "ok"
   530	        else:
   531	            score = 0.0
   532	            confidence = 0.0
   533	            status = "abstain"
   534	        rows.append(
   535	            {
   536	                "bar_start_utc": pd.Timestamp(row.bar_start_utc),
   537	                "execution_time": execution_time,
   538	                "feature_cutoff": pd.Timestamp(row.feature_cutoff),
   539	                "fit_cutoff": pd.Timestamp(available["label_observation_time"].max())
   540	                if not available.empty
   541	                else pd.NaT,
   542	                "probability": 0.5 + score / 2.0,
   543	                "score": score,
   544	                "confidence": confidence,
   545	                "expected_return": forecast.expected_return,
   546	                "forecast_volatility": forecast.volatility,
   547	                "target_label": int(row.target_label),
   548	                "forward_return": float(row.forward_return),
   549	                "method": forecast.method,
   550	                "status": status,
   551	                "reason": forecast.reason,
   552	                "train_samples": len(history),
   553	                "used_future_labels": bool(
   554	                    not available.empty
   555	                    and (available["label_observation_time"] >= execution_time).any()
   556	                ),
   557	            }
   558	        )
   559	    return pd.DataFrame(rows)
   560
   561
   562	def _directional_prediction_metrics(predictions: pd.DataFrame) -> dict[str, float]:
   563	    if predictions.empty:
   564	        return {"directional_accuracy": 0.0, "coverage": 0.0}
   565	    active = predictions.loc[predictions["status"] == "ok"].copy()
   566	    if active.empty:
   567	        return {"directional_accuracy": 0.0, "coverage": 0.0}
   568	    predicted = active["expected_return"] > 0
   569	    actual = active["forward_return"] > active.get("target_threshold_return", 0.0)
   570	    return {
   571	        "directional_accuracy": float((predicted == actual).mean()),
   572	        "coverage": float(len(active) / len(predictions)),
   573	        "mean_forecast_volatility": float(active["forecast_volatility"].mean()),
   574	    }
