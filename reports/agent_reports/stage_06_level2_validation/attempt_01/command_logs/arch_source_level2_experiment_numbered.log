   781	def _write_level2_artifacts(
   782	    approaches: list[_ApproachResult],
   783	    *,
   784	    output_dir: Path,
   785	    provenance: ArtifactProvenance,
   786	) -> dict[str, Path]:
   787	    paths = {
   788	        "metrics": output_dir / "metrics" / "level_2.csv",
   789	        "equity": output_dir / "equity" / "level_2.parquet",
   790	        "weights": output_dir / "weights" / "level_2.parquet",
   791	        "orders": output_dir / "orders" / "level_2.parquet",
   792	        "fills": output_dir / "fills" / "level_2.parquet",
