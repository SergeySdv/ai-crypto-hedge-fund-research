   460	def _approach_agents(
   461	    *,
   462	    config: dict[str, Any],
   463	    symbol: str,
   464	    prediction_tables: dict[str, pd.DataFrame],
   465	) -> list[tuple[str, tuple[Any, ...], dict[str, float]]]:
   466	    level_config = dict(config.get("level_2", {}))
   467	    technical = SMACrossoverSignalAgent(
   468	        fast_window=int(level_config.get("technical_fast_window", 10)),
   469	        slow_window=int(level_config.get("technical_slow_window", 50)),
   470	    )
   471	    econometric = PredictionTableSignalAgent(
   472	        "econometric_ar_garch", prediction_tables["econometric_ar_garch"]
   473	    )
   474	    logistic = PredictionTableSignalAgent("ml_logistic", prediction_tables["ml_logistic"])
   475	    hgb = PredictionTableSignalAgent(
   476	        "ml_hist_gradient_boosting", prediction_tables["ml_hist_gradient_boosting"]
   477	    )
   478	    del symbol
   479	    ensemble_weights = {
   480	        "sma_crossover": float(level_config.get("technical_weight", 0.25)),
   481	        "econometric_ar_garch": float(level_config.get("econometric_weight", 0.25)),
   482	        "ml_logistic": float(level_config.get("logistic_weight", 0.25)),
   483	        "ml_hist_gradient_boosting": float(level_config.get("hgb_weight", 0.25)),
   484	    }
   485	    return [
   486	        ("technical_sma", (technical,), {"sma_crossover": 1.0}),
   487	        ("econometric_ar_garch", (econometric,), {"econometric_ar_garch": 1.0}),
   488	        ("ml_logistic", (logistic,), {"ml_logistic": 1.0}),
   489	        ("ml_hist_gradient_boosting", (hgb,), {"ml_hist_gradient_boosting": 1.0}),
   490	        ("agent_ensemble", (technical, econometric, logistic, hgb), ensemble_weights),
   491	    ]
