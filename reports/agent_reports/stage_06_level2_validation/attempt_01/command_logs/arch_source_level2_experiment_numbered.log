   899	def _robustness_checks(
   900	    *,
   901	    selected: _ApproachResult,
   902	    features: pd.DataFrame,
   903	    config: dict[str, Any],
   904	) -> dict[str, Any]:
   905	    returns = selected.net_result.equity["nav"].astype("float64").pct_change().dropna()
   906	    repetitions = int(config["statistics"]["bootstrap_repetitions"])
   907	    permutation_repetitions = int(config["statistics"]["permutation_repetitions"])
   908	    block_length = int(config["statistics"]["block_length_days"])
   909	    rng = np.random.default_rng(int(config["project"]["seed"]))
   910	    boot_means = []
   911	    boot_sharpes = []
   912	    values = returns.to_numpy()
   913	    if len(values) > 0:
   914	        for _ in range(repetitions):
   915	            sample = _moving_block_sample(values, block_length=block_length, rng=rng)
   916	            boot_means.append(float(np.mean(sample)))
   917	            boot_sharpes.append(_sharpe(sample))
   918	    observed_score_return_corr = _score_return_correlation(selected.traces, features)
   919	    shifted = []
   920	    returns_by_bar = features.set_index("bar_start_utc")["forward_return"].to_numpy()
   921	    scores = np.array(
   922	        [
   923	            trace.aggregated_signals[0].score if trace.aggregated_signals else 0.0
   924	            for trace in selected.traces
   925	        ],
   926	        dtype="float64",
   927	    )
   928	    n = min(len(scores), len(returns_by_bar))
   929	    if n > 2:
   930	        for _ in range(permutation_repetitions):
   931	            shift = int(rng.integers(1, n))
   932	            shifted.append(float(np.corrcoef(scores[:n], np.roll(returns_by_bar[:n], shift))[0, 1]))
   933	    cost_stress = {
   934	        "1x_recorded_net_roi": float(selected.metrics["net_roi"]),
   935	        "gross_to_net_total_return_decay": float(
   936	            selected.metrics["gross_to_net_total_return_decay"]
   937	        ),
   938	        "reported_as_validation_only": 1.0,
   939	    }
   940	    return {
   941	        "block_bootstrap": {
   942	            "repetitions": repetitions,
   943	            "block_length_days": block_length,
   944	            "mean_return_ci_95": _percentiles(boot_means),
   945	            "sharpe_ci_95": _percentiles(boot_sharpes),
   946	        },
   947	        "circular_shift_randomization": {
   948	            "repetitions": permutation_repetitions,
   949	            "observed_score_forward_return_correlation": observed_score_return_corr,
   950	            "two_sided_p_value": _two_sided_p_value(observed_score_return_corr, shifted),
   951	        },
   952	        "multiple_seeds": {
   953	            "seeds": [int(seed) for seed in config["statistics"]["random_seeds"]],
   954	            "purpose": (
   955	                "ML walk-forward fitting repeated across configured seeds; first seed drives "
   956	                "trading artifacts"
   957	            ),
   958	        },
   959	        "cost_sensitivity": cost_stress,
   960	    }
   961
   962
   963	def _moving_block_sample(
   964	    values: np.ndarray, *, block_length: int, rng: np.random.Generator
   965	) -> np.ndarray:
   966	    if len(values) == 0:
   967	        return values
   968	    block = max(1, min(block_length, len(values)))
   969	    samples: list[float] = []
   970	    while len(samples) < len(values):
   971	        start = int(rng.integers(0, len(values)))
   972	        for offset in range(block):
   973	            samples.append(float(values[(start + offset) % len(values)]))
   974	            if len(samples) >= len(values):
   975	                break
   976	    return np.array(samples, dtype="float64")
   977
   978
   979	def _sharpe(values: np.ndarray) -> float:
   980	    std = float(np.std(values, ddof=1)) if len(values) > 1 else 0.0
   981	    return float(np.mean(values) / std * np.sqrt(365.0)) if std > 0 else 0.0
   982
   983
   984	def _percentiles(values: list[float]) -> list[float]:
   985	    if not values:
   986	        return [0.0, 0.0]
   987	    low, high = np.percentile(np.array(values, dtype="float64"), [2.5, 97.5])
   988	    return [float(low), float(high)]
   989
   990
   991	def _score_return_correlation(traces: tuple[DecisionTrace, ...], features: pd.DataFrame) -> float:
   992	    by_bar = features.set_index("bar_start_utc")["forward_return"]
   993	    scores = []
   994	    returns = []
   995	    for trace in traces:
   996	        bar_start = pd.Timestamp(trace.clock.bar_start)
   997	        if bar_start in by_bar.index and trace.aggregated_signals:
   998	            scores.append(float(trace.aggregated_signals[0].score))
   999	            returns.append(float(by_bar.loc[bar_start]))
  1000	    if len(scores) < 3 or np.std(scores) <= 0 or np.std(returns) <= 0:
  1001	        return 0.0
  1002	    return float(np.corrcoef(scores, returns)[0, 1])
  1003
  1004
  1005	def _two_sided_p_value(observed: float, shifted: list[float]) -> float:
  1006	    if not shifted:
  1007	        return 1.0
  1008	    extreme = sum(abs(value) >= abs(observed) for value in shifted)
  1009	    return float((extreme + 1) / (len(shifted) + 1))
  1010
