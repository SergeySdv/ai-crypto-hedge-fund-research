    69	def test_missing_next_open_price_blocks_execution_explicitly() -> None:
    70	    market = _panel(
    71	        [
    72	            ("2024-01-01T00:00:00+00:00", "BTC/USDT", 100.0),
    73	        ]
    74	    )
    75	    broker = SimulatedBroker(market, initial_capital=1000)
    76
    77	    with pytest.raises(MissingPriceError, match="execution open"):
    78	        broker.run(
    79	            pd.DataFrame(
    80	                [{"BTC/USDT": 0.5}],
    81	                index=[pd.Timestamp("2024-01-01T00:00:00+00:00")],
    82	            )
    83	        )
