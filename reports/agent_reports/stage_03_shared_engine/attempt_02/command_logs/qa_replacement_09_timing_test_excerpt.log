    16	def _panel(rows: list[tuple[str, str, float]]) -> PanelMarketData:
    17	    frame = pd.DataFrame(
    18	        [
    19	            {
    20	                "bar_start_utc": timestamp,
    21	                "symbol": symbol,
    22	                "open": price,
    23	                "high": price,
    24	                "low": price,
    25	                "close": price,
    26	                "volume": 1.0,
    27	                "dollar_volume": price,
    28	                "exchange": "fixture",
    29	                "market_type": "spot",
    30	                "timeframe": "1d",
    31	            }
    32	            for timestamp, symbol, price in rows
    33	        ]
    34	    )
    35	    return PanelMarketData.from_ohlcv(frame)
    36
