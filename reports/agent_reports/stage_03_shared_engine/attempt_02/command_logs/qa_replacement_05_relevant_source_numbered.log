    29	@dataclass(frozen=True)
    30	class PanelMarketData:
    31	    """Long-form daily OHLCV data indexed by ``(bar_start_utc, symbol)``."""
    32
    33	    frame: pd.DataFrame
    34
    35	    def __post_init__(self) -> None:
    36	        normalized = self._normalize(self.frame)
    37	        object.__setattr__(self, "frame", normalized)
    38
    39	    @classmethod
    40	    def from_ohlcv(cls, frame: pd.DataFrame) -> PanelMarketData:
    41	        """Build panel data from the repository OHLCV schema."""
    42	        return cls(frame)
    43
    44	    @staticmethod
    45	    def _normalize(frame: pd.DataFrame) -> pd.DataFrame:
    46	        if not isinstance(frame, pd.DataFrame):
    47	            msg = "frame must be a pandas DataFrame"
    48	            raise TypeError(msg)
    49	        source = frame.copy()
    50	        if isinstance(source.index, pd.MultiIndex) and {"bar_start_utc", "symbol"}.issubset(
    51	            source.index.names
    52	        ):
    53	            source = source.reset_index()
    54	        required = {"bar_start_utc", "symbol", "open", "close"}
    55	        missing = sorted(required.difference(source.columns))
    56	        if missing:
    57	            msg = f"market data missing required columns: {missing}"
    58	            raise ValueError(msg)
    59	        source["bar_start_utc"] = pd.to_datetime(source["bar_start_utc"], utc=True)
    60	        source["symbol"] = source["symbol"].astype(str)
    61	        source["open"] = source["open"].astype("float64")
    62	        source["close"] = source["close"].astype("float64")
    63	        if source.duplicated(["bar_start_utc", "symbol"]).any():
    64	            msg = "market data contains duplicate (bar_start_utc, symbol) rows"
    65	            raise ValueError(msg)
    66	        for column in ("open", "close"):
    67	            valid = source[column].map(math.isfinite) & (source[column] > 0)
    68	            if not valid.all():
    69	                msg = f"market data column {column!r} must be finite and positive"
    70	                raise ValueError(msg)
    71	        source = source.sort_values(["bar_start_utc", "symbol"], kind="mergesort")
    72	        indexed = source.set_index(["bar_start_utc", "symbol"])
    73	        if not indexed.index.is_unique:
    74	            msg = "market data index must be unique"
    75	            raise ValueError(msg)
    76	        return indexed
    77
    78	    @property
    79	    def symbols(self) -> tuple[str, ...]:
    80	        """Sorted symbol universe present in the panel."""
    81	        return tuple(sorted(self.frame.index.get_level_values("symbol").unique()))
    82
    83	    @property
    84	    def open_times(self) -> pd.DatetimeIndex:
    85	        """Sorted UTC bar-open timestamps present in the panel."""
    86	        return pd.DatetimeIndex(sorted(self.frame.index.get_level_values("bar_start_utc").unique()))
    87
    88	    def open_prices(
    89	        self,
    90	        execution_time: datetime | pd.Timestamp,
    91	        symbols: Iterable[str],
    92	        *,
    93	        reason: str = "execution",
    94	    ) -> pd.Series:
    95	        """Return valid open prices for all requested symbols or fail explicitly."""
    96	        requested = tuple(str(symbol) for symbol in symbols)
    97	        if not requested:
    98	            return pd.Series(dtype="float64")
    99	        time = _utc_timestamp(execution_time)
   100	        try:
   101	            rows = self.frame.xs(time, level="bar_start_utc")
   102	        except KeyError as exc:
   103	            msg = f"missing {reason} open for all symbols at {time.isoformat()}"
   104	            raise MissingPriceError(msg) from exc
   105	        missing = [symbol for symbol in requested if symbol not in rows.index]
   106	        if missing:
   107	            msg = f"missing {reason} open at {time.isoformat()} for symbols: {missing}"
   108	            raise MissingPriceError(msg)
   109	        prices = rows.loc[list(requested), "open"].astype("float64")
   110	        valid = prices.map(math.isfinite) & (prices > 0)
   111	        if not valid.all():
   112	            bad = prices.index[~valid].tolist()
   113	            msg = f"invalid {reason} open at {time.isoformat()} for symbols: {bad}"
   114	            raise MissingPriceError(msg)
   115	        return prices
   116
   117	    def benchmark_open_to_open(
   118	        self,
   119	        symbol: str,
   120	        *,
   121	        start_time: datetime | pd.Timestamp,
   122	        end_time: datetime | pd.Timestamp | None = None,
   123	    ) -> pd.DataFrame:
   124	        """Return a one-symbol buy-and-hold benchmark using open-to-open prices."""
   125	        start = _utc_timestamp(start_time)
   126	        end = _utc_timestamp(end_time) if end_time is not None else None
   127	        rows = self.frame.xs(str(symbol), level="symbol").sort_index()
   128	        rows = rows.loc[rows.index >= start]
   129	        if end is not None:
   130	            rows = rows.loc[rows.index <= end]
   131	        if rows.empty:
   132	            msg = f"no benchmark prices for {symbol} from {start.isoformat()}"
   133	            raise MissingPriceError(msg)
   134	        first = float(rows["open"].iloc[0])
   135	        benchmark = rows[["open"]].copy()
   136	        benchmark["benchmark_nav"] = benchmark["open"] / first
   137	        benchmark["benchmark_return"] = benchmark["benchmark_nav"].pct_change().fillna(0.0)
   138	        return benchmark.reset_index().rename(columns={"bar_start_utc": "timestamp"})
