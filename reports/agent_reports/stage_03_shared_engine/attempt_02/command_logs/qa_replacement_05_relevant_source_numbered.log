    46	class BacktestArtifactWriter:
    47	    """Write shared execution artifacts with stable schemas and provenance."""
    48
    49	    def __init__(self, artifacts_dir: str | Path) -> None:
    50	        self.artifacts_dir = Path(artifacts_dir)
    51
    52	    def write_run(
    53	        self,
    54	        result: BacktestRunResult,
    55	        metrics: dict[str, float],
    56	        provenance: ArtifactProvenance,
    57	        *,
    58	        level_name: str,
    59	    ) -> dict[str, Path]:
    60	        """Write metrics/equity/weights/orders/fills and return their paths."""
    61	        paths = {
    62	            "metrics": self.artifacts_dir / "metrics" / f"{level_name}.csv",
    63	            "equity": self.artifacts_dir / "equity" / f"{level_name}.parquet",
    64	            "weights": self.artifacts_dir / "weights" / f"{level_name}.parquet",
    65	            "orders": self.artifacts_dir / "orders" / f"{level_name}.parquet",
    66	            "fills": self.artifacts_dir / "fills" / f"{level_name}.parquet",
    67	        }
    68	        self.write_metrics(metrics, paths["metrics"], provenance)
    69	        self.write_frame(result.equity, paths["equity"], provenance)
    70	        self.write_frame(result.weights, paths["weights"], provenance)
    71	        self.write_frame(result.orders, paths["orders"], provenance)
    72	        self.write_frame(result.fills, paths["fills"], provenance)
    73	        return paths
    74
    75	    def write_metrics(
    76	        self,
    77	        metrics: dict[str, float],
    78	        path: str | Path,
    79	        provenance: ArtifactProvenance,
    80	    ) -> Path:
    81	        """Write one metrics CSV row with provenance columns."""
    82	        output = Path(path)
    83	        output.parent.mkdir(parents=True, exist_ok=True)
    84	        row = {str(key): float(value) for key, value in metrics.items()}
    85	        frame = pd.DataFrame([self._with_metadata(row, provenance)])
    86	        frame.to_csv(output, index=False)
    87	        self._write_metadata_sidecar(output, provenance)
    88	        return output
    89
    90	    def write_frame(
    91	        self,
    92	        frame: pd.DataFrame,
    93	        path: str | Path,
    94	        provenance: ArtifactProvenance,
    95	    ) -> Path:
    96	        """Write a parquet frame with repeated provenance columns and JSON sidecar."""
    97	        output = Path(path)
    98	        output.parent.mkdir(parents=True, exist_ok=True)
    99	        enriched = frame.copy()
   100	        for key, value in self._provenance_columns(provenance).items():
   101	            enriched[key] = value
   102	        enriched.to_parquet(output, index=False)
   103	        self._write_metadata_sidecar(output, provenance)
   104	        return output
   105
   106	    @staticmethod
   107	    def _provenance_columns(provenance: ArtifactProvenance) -> dict[str, str | int]:
   108	        metadata = provenance.metadata()
   109	        cost_assumptions = metadata.pop("cost_assumptions")
   110	        warnings = metadata.pop("warnings")
   111	        columns = {
   112	            f"provenance_{key}": value if value is not None else ""
   113	            for key, value in metadata.items()
   114	        }
   115	        columns["provenance_cost_assumptions"] = json.dumps(cost_assumptions, sort_keys=True)
   116	        columns["provenance_warnings"] = json.dumps(list(warnings), sort_keys=True)
   117	        return columns
   118
   119	    @classmethod
   120	    def _with_metadata(
   121	        cls,
   122	        row: dict[str, float],
   123	        provenance: ArtifactProvenance,
   124	    ) -> dict[str, object]:
   125	        return {**row, **cls._provenance_columns(provenance)}
   126
   127	    @staticmethod
   128	    def _write_metadata_sidecar(path: Path, provenance: ArtifactProvenance) -> None:
   129	        sidecar = path.with_suffix(f"{path.suffix}.metadata.json")
   130	        with sidecar.open("w", encoding="utf-8") as handle:
   131	            json.dump(provenance.metadata(), handle, indent=2, sort_keys=True)
   132	            handle.write("\n")
