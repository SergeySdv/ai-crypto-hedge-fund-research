    31	def _cmd_status(_args: argparse.Namespace) -> int:
    32	    payload = {
    33	        "package": "crypto_hedge_fund",
    34	        "git_commit": git_commit(),
    35	        "default_config_hash": canonical_config_hash(load_config(resolve_paths=False)),
    36	    }
    37	    print(json.dumps(payload, indent=2, sort_keys=True))
    38	    return 0
