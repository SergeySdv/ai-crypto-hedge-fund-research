   107	def _freeze_mapping(mapping: Mapping[str, Any], *, field_name: str) -> Mapping[str, Any]:
   108	    if not isinstance(mapping, Mapping):
   109	        msg = f"{field_name} must be a mapping"
   110	        raise TypeError(msg)
   111	    return MappingProxyType(dict(mapping))
   112
   113
   114	def _reason_tuple(reason_codes: Sequence[ReasonCode | str]) -> tuple[ReasonCode, ...]:
   115	    if not reason_codes:
   116	        msg = "reason_codes must not be empty"
   117	        raise ValueError(msg)
   118	    return tuple(
   119	        code if isinstance(code, ReasonCode) else ReasonCode(code) for code in reason_codes
   120	    )
   121
   122
   123	def _validated_weights(
   124	    weights: Mapping[str, float],
   125	    *,
   126	    cash_weight: float,
   127	    field_name: str,
   128	) -> Mapping[str, float]:
   129	    if not isinstance(weights, Mapping):
   130	        msg = f"{field_name} must be a mapping"
   131	        raise TypeError(msg)
   132	    validated = {
   133	        str(symbol): _non_negative(weight, field_name=f"{field_name}[{symbol}]")
   134	        for symbol, weight in weights.items()
   135	    }
   136	    cash = _range(cash_weight, field_name="cash_weight", low=0.0, high=1.0)
   137	    total = sum(validated.values()) + cash
   138	    if abs(total - 1.0) > WEIGHT_TOLERANCE:
   139	        msg = f"{field_name} plus cash_weight must sum to 1.0, got {total}"
   140	        raise ValueError(msg)
   141	    return MappingProxyType(validated)
