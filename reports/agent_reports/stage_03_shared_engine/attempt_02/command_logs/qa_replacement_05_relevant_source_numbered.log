    56	def _cmd_validate_data(args: argparse.Namespace) -> int:
    57	    try:
    58	        result = validate_data_bundle(config_path=args.config)
    59	    except DataValidationError as exc:
    60	        _fail_closed(str(exc))
    61	    print(json.dumps(result.to_dict(), indent=2, sort_keys=True))
    62	    return 0
