    62	def _validate_nav(nav: float) -> float:
    63	    number = float(nav)
    64	    if not math.isfinite(number) or number <= 0:
    65	        msg = "nav must be finite and positive"
    66	        raise ValueError(msg)
    67	    return number
    68
    69
    70	def _validate_weights(weights: pd.Series, *, label: str) -> pd.Series:
    71	    if not isinstance(weights, pd.Series):
    72	        msg = f"{label} must be a pandas Series"
    73	        raise TypeError(msg)
    74	    clean = weights.astype("float64").copy()
    75	    clean.index = clean.index.astype(str)
    76	    if clean.index.has_duplicates:
    77	        msg = f"{label} contains duplicate symbols"
    78	        raise InvalidWeightsError(msg)
    79	    if not clean.map(math.isfinite).all():
    80	        msg = f"{label} must contain only finite weights"
    81	        raise InvalidWeightsError(msg)
    82	    if (clean < -1e-12).any():
    83	        msg = f"{label} must be long-only"
    84	        raise InvalidWeightsError(msg)
    85	    clean[clean.abs() < 1e-15] = 0.0
    86	    risky_sum = float(clean.sum())
    87	    if risky_sum > 1.0 + 1e-10:
    88	        msg = f"{label} risky weights exceed the unlevered budget: {risky_sum}"
    89	        raise InvalidWeightsError(msg)
    90	    return clean
    91
