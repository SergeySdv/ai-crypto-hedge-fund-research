   145	class ResearchClock:
   146	    """Explicit UTC timestamps for one completed-bar decision."""
   147
   148	    bar_start: datetime
   149	    bar_end: datetime
   150	    feature_cutoff: datetime
   151	    decision_time: datetime
   152	    execution_time: datetime
   153
   154	    def __post_init__(self) -> None:
   155	        for name in ("bar_start", "bar_end", "feature_cutoff", "decision_time", "execution_time"):
   156	            object.__setattr__(self, name, _as_utc(getattr(self, name), field_name=name))
   157	        if not (
   158	            self.bar_start
   159	            < self.bar_end
   160	            <= self.feature_cutoff
   161	            <= self.decision_time
   162	            <= self.execution_time
   163	        ):
   164	            msg = (
   165	                "ResearchClock requires bar_start < bar_end <= feature_cutoff "
   166	                "<= decision_time <= execution_time"
   167	            )
   168	            raise ValueError(msg)
