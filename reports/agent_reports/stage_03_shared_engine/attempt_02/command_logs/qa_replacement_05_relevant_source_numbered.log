     1	"""Transaction-cost accounting for risky-asset weight changes."""
     2
     3	from __future__ import annotations
     4
     5	import math
     6	from dataclasses import dataclass
     7
     8	import pandas as pd
     9
    10
    11	class InvalidWeightsError(ValueError):
    12	    """Raised when target or pre-trade risky weights are invalid."""
    13
    14
    15	@dataclass(frozen=True)
    16	class CostAssumptions:
    17	    """One-way fee and slippage assumptions in basis points."""
    18
    19	    fee_bps_one_way: float = 10.0
    20	    slippage_bps_one_way: float = 5.0
    21
    22	    def __post_init__(self) -> None:
    23	        for field_name, value in (
    24	            ("fee_bps_one_way", self.fee_bps_one_way),
    25	            ("slippage_bps_one_way", self.slippage_bps_one_way),
    26	        ):
    27	            number = float(value)
    28	            if not math.isfinite(number) or number < 0:
    29	                msg = f"{field_name} must be finite and non-negative"
    30	                raise ValueError(msg)
    31	            object.__setattr__(self, field_name, number)
    32
    33	    @property
    34	    def fee_rate(self) -> float:
    35	        """One-way fee rate as a fraction of risky notional."""
    36	        return self.fee_bps_one_way / 10_000.0
    37
    38	    @property
    39	    def slippage_rate(self) -> float:
    40	        """One-way slippage rate as a fraction of risky notional."""
    41	        return self.slippage_bps_one_way / 10_000.0
    42
    43	    @property
    44	    def total_rate(self) -> float:
    45	        """Combined one-way cost rate as a fraction of risky notional."""
    46	        return self.fee_rate + self.slippage_rate
    47
