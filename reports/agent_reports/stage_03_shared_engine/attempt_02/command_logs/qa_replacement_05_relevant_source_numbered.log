    93	def validate_target_risky_weights(
    94	    weights: pd.Series,
    95	    *,
    96	    label: str = "target_weights",
    97	) -> pd.Series:
    98	    """Validate long-only unlevered risky weights and return a normalized copy."""
    99	    return _validate_weights(weights, label=label)
