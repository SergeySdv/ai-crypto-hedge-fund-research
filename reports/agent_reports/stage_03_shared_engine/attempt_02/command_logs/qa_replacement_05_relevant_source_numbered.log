    71	def _cmd_final_test(args: argparse.Namespace) -> NoReturn:
    72	    config = load_config(resolve_paths=True)
    73	    lock_path = Path(config["final_test"]["lock_path"])
    74	    if not lock_path.is_absolute():
    75	        lock_path = Path.cwd() / lock_path
    76	    if not lock_path.exists():
    77	        _fail_closed(
    78	            "`make final-test` requires artifacts/final_test_lock.json. "
    79	            "Run the validation-only stages and pretest freeze first."
    80	        )
    81	    _fail_closed(
    82	        f"`{args.command}` found lock {lock_path} but the frozen final-test runner "
    83	        "is not implemented until later stages."
    84	    )
    85
