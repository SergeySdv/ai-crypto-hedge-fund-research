    43	    def __post_init__(self) -> None:
    44	        object.__setattr__(self, "timestamp", _timestamp(self.timestamp))
    45	        if not self.symbol:
    46	            msg = "symbol must be non-empty"
    47	            raise ValueError(msg)
    48	        object.__setattr__(
    49	            self, "quantity", _finite_non_negative(self.quantity, field_name="quantity")
    50	        )
    51	        object.__setattr__(self, "price", _finite_non_negative(self.price, field_name="price"))
    52	        object.__setattr__(
    53	            self,
    54	            "market_value",
    55	            _finite_non_negative(self.market_value, field_name="market_value"),
    56	        )
    57	        object.__setattr__(self, "weight", _finite_non_negative(self.weight, field_name="weight"))
