    22	def _cmd_config_hash(args: argparse.Namespace) -> int:
    23	    config = load_config(
    24	        overlay_path=Path("configs/fast.yaml") if args.fast else None,
    25	        resolve_paths=False,
    26	    )
    27	    print(canonical_config_hash(config))
    28	    return 0
