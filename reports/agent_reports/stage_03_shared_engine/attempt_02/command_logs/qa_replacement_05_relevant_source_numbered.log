    61	def _as_utc(value: datetime, *, field_name: str) -> datetime:
    62	    if not isinstance(value, datetime):
    63	        msg = f"{field_name} must be a datetime"
    64	        raise TypeError(msg)
    65	    if value.tzinfo is None:
    66	        msg = f"{field_name} must be timezone-aware UTC"
    67	        raise ValueError(msg)
    68	    converted = value.astimezone(UTC)
    69	    if converted != value:
    70	        msg = f"{field_name} must already be normalized to UTC"
    71	        raise ValueError(msg)
    72	    return converted
    73
    74
    75	def _finite(value: float | int, *, field_name: str) -> float:
    76	    number = float(value)
    77	    if not math.isfinite(number):
    78	        msg = f"{field_name} must be finite"
    79	        raise ValueError(msg)
    80	    return number
    81
    82
    83	def _range(value: float | int, *, field_name: str, low: float, high: float) -> float:
    84	    number = _finite(value, field_name=field_name)
    85	    if not low <= number <= high:
    86	        msg = f"{field_name} must be in [{low}, {high}], got {number}"
    87	        raise ValueError(msg)
    88	    return number
    89
    90
    91	def _positive(value: float | int, *, field_name: str) -> float:
    92	    number = _finite(value, field_name=field_name)
    93	    if number <= 0:
    94	        msg = f"{field_name} must be positive"
    95	        raise ValueError(msg)
    96	    return number
    97
    98
    99	def _non_negative(value: float | int, *, field_name: str) -> float:
   100	    number = _finite(value, field_name=field_name)
   101	    if number < 0:
   102	        msg = f"{field_name} must be non-negative"
   103	        raise ValueError(msg)
   104	    return number
   105
