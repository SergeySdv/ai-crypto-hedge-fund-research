    92	def build_parser() -> argparse.ArgumentParser:
    93	    parser = argparse.ArgumentParser(prog="crypto-hedge-fund")
    94	    subparsers = parser.add_subparsers(dest="command", required=True)
    95
    96	    config_hash = subparsers.add_parser("config-hash", help="Print the effective config hash.")
    97	    config_hash.add_argument("--fast", action="store_true", help="Apply configs/fast.yaml overlay.")
    98	    config_hash.set_defaults(func=_cmd_config_hash)
    99
   100	    status = subparsers.add_parser("status", help="Print Stage 1 package provenance.")
   101	    status.set_defaults(func=_cmd_status)
   102
   103	    hash_file = subparsers.add_parser("hash-file", help="Print a file SHA-256 digest.")
   104	    hash_file.add_argument("path", type=Path)
   105	    hash_file.set_defaults(func=_cmd_hash_file)
   106
   107	    data = subparsers.add_parser("data", help="Download/freeze configured public OHLCV data.")
   108	    data.add_argument("--config", type=Path, default=Path("configs/default.yaml"))
   109	    data.add_argument("--max-symbols", type=int, default=None)
   110	    data.set_defaults(func=_cmd_data)
   111
   112	    validate_data = subparsers.add_parser(
   113	        "validate-data", help="Validate included OHLCV data and universe proof."
   114	    )
   115	    validate_data.add_argument("--config", type=Path, default=Path("configs/default.yaml"))
   116	    validate_data.set_defaults(func=_cmd_validate_data)
   117
   118	    for command in (
   119	        "experiments-val",
   120	        "pretest-freeze",
   121	        "notebook-fast",
   122	        "notebook-full",
   123	        "report",
   124	        "presentation",
   125	    ):
   126	        future = subparsers.add_parser(command, help="Later-stage command placeholder.")
   127	        future.set_defaults(func=_cmd_future_stage)
   128
   129	    final_test = subparsers.add_parser("final-test", help="Run frozen final-test suite.")
   130	    final_test.set_defaults(func=_cmd_final_test)
   131	    return parser
   132
   133
   134	def main(argv: list[str] | None = None) -> int:
   135	    parser = build_parser()
   136	    args = parser.parse_args(argv)
   137	    return args.func(args)
   138
   139
   140	if __name__ == "__main__":
   141	    raise SystemExit(main())
