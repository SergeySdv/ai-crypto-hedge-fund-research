    39	def _validate_initial_capital(value: float) -> float:
    40	    capital = float(value)
    41	    if not math.isfinite(capital) or capital <= 0:
    42	        msg = "initial_capital must be finite and positive"
    43	        raise ValueError(msg)
    44	    return capital
    45
