    41	def _cmd_data(args: argparse.Namespace) -> int:
    42	    manifest = freeze_data(config_path=args.config, max_symbols=args.max_symbols)
    43	    payload = {
    44	        "exchange": manifest["source"]["exchange"],
    45	        "row_count": manifest["row_count"],
    46	        "symbol_count": manifest["symbol_count"],
    47	        "min_bar_start_utc": manifest["actual_min_bar_start_utc"],
    48	        "max_bar_start_utc": manifest["actual_max_bar_start_utc"],
    49	        "file_sha256": manifest["file_sha256"],
    50	        "instrument_sha256": manifest["instrument_sha256"],
    51	    }
    52	    print(json.dumps(payload, indent=2, sort_keys=True))
    53	    return 0
