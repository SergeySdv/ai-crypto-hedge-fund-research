    77	            "cash",
    78	            "risky_value",
    79	            "nav",
    80	            "turnover",
    81	            "fees",
    82	            "slippage",
    83	            "exposure",
    84	        ):
    85	            object.__setattr__(
    86	                self,
    87	                field_name,
    88	                _finite_non_negative(getattr(self, field_name), field_name=field_name),
    89	            )
    90	        if self.nav <= 0:
    91	            msg = "nav must be positive"
    92	            raise ValueError(msg)
    93	        if self.trade_count < 0:
    94	            msg = "trade_count must be non-negative"
    95	            raise ValueError(msg)
