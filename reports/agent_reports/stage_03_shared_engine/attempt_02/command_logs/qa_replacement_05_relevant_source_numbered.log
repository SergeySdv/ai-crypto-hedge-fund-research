    49	@dataclass(frozen=True)
    50	class CostBreakdown:
    51	    """Detailed cost and turnover decomposition for a rebalance."""
    52
    53	    nav: float
    54	    gross_traded_notional: float
    55	    gross_traded_notional_fraction: float
    56	    reporting_turnover: float
    57	    fee: float
    58	    slippage: float
    59	    total_cost: float
