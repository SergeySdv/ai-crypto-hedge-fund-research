     1	"""Performance and risk metrics for shared backtest artifacts."""
     2
     3	from __future__ import annotations
     4
     5	import math
     6
     7	import numpy as np
     8	import pandas as pd
     9
    10
    11	def _zero_series(index: pd.Index) -> pd.Series:
    12	    return pd.Series(0.0, index=index, dtype="float64")
    13
    14
    15	def _max_drawdown(nav: pd.Series) -> tuple[float, int]:
    16	    cumulative_max = nav.cummax()
    17	    drawdown = nav / cumulative_max - 1.0
    18	    max_dd = float(drawdown.min())
    19	    underwater = drawdown < 0
    20	    longest = 0
    21	    current = 0
    22	    for value in underwater:
    23	        if bool(value):
    24	            current += 1
    25	            longest = max(longest, current)
    26	        else:
    27	            current = 0
    28	    return max_dd, longest
    29
    30
    31	def _annualized_return(total_return: float, periods: int, periods_per_year: int) -> float:
    32	    if periods <= 1:
    33	        return 0.0
    34	    years = periods / periods_per_year
    35	    if years <= 0 or total_return <= -1.0:
    36	        return 0.0
    37	    return (1.0 + total_return) ** (1.0 / years) - 1.0
    38
    39
    40	def _historical_var_cvar(returns: pd.Series, confidence: float) -> tuple[float, float]:
    41	    if returns.empty:
    42	        return 0.0, 0.0
    43	    alpha = 1.0 - confidence
    44	    quantile = float(returns.quantile(alpha))
    45	    tail = returns[returns <= quantile]
    46	    var = max(0.0, -quantile)
    47	    cvar = max(0.0, -float(tail.mean())) if not tail.empty else var
    48	    return var, cvar
    49
    50
    51	def _safe_symbol_key(symbol: object) -> str:
    52	    return str(symbol).lower().replace("/", "_").replace("-", "_").replace(" ", "_")
    53
    54
    55	def _weight_metrics(weights: pd.DataFrame | None, equity: pd.DataFrame) -> dict[str, float]:
    56	    metrics: dict[str, float] = {
    57	        "average_cash_exposure": 0.0,
    58	        "average_concentration_hhi": 0.0,
    59	        "average_effective_n": 0.0,
    60	        "max_symbol_weight": 0.0,
    61	    }
    62	    if weights is None or weights.empty:
    63	        if "cash" in equity.columns and "nav" in equity.columns:
    64	            cash_weight = (equity["cash"].astype("float64") / equity["nav"].astype("float64")).clip(
    65	                lower=0.0
    66	            )
    67	            metrics["average_cash_exposure"] = float(cash_weight.mean())
    68	        elif "exposure" in equity.columns:
    69	            metrics["average_cash_exposure"] = float(
    70	                (1.0 - equity["exposure"].astype("float64")).clip(lower=0.0).mean()
    71	            )
    72	        return metrics
    73
    74	    frame = weights.copy()
    75	    if "timestamp" in frame.columns:
    76	        frame = frame.drop(columns=["timestamp"])
    77	    if "run_label" in frame.columns:
    78	        frame = frame.drop(columns=["run_label"])
    79	    numeric = frame.apply(pd.to_numeric, errors="coerce").fillna(0.0)
    80	    cash_weight = (
    81	        numeric["cash_weight"] if "cash_weight" in numeric.columns else _zero_series(numeric.index)
    82	    )
    83	    risky = numeric.drop(columns=["cash_weight"], errors="ignore")
    84	    risky = risky.loc[
    85	        :, [column for column in risky.columns if not str(column).startswith("provenance_")]
    86	    ]
    87	    hhi = (risky**2).sum(axis=1)
    88	    effective_n = hhi.where(hhi <= 0.0, 1.0 / hhi).where(hhi > 0.0, 0.0)
    89	    metrics.update(
    90	        {
    91	            "average_cash_exposure": float(cash_weight.mean()),
    92	            "average_concentration_hhi": float(hhi.mean()) if not hhi.empty else 0.0,
    93	            "average_effective_n": float(effective_n.mean()) if not effective_n.empty else 0.0,
    94	            "max_symbol_weight": float(risky.max(axis=1).max()) if not risky.empty else 0.0,
    95	        }
    96	    )
    97	    risky_sum = risky.sum(axis=1).replace(0.0, np.nan)
    98	    contribution = risky.div(risky_sum, axis=0).fillna(0.0).mean(axis=0)
    99	    for symbol, value in contribution.items():
   100	        metrics[f"average_risky_weight_contribution_{_safe_symbol_key(symbol)}"] = float(value)
   101	    return metrics
   102
   103
   104	def calculate_performance_metrics(
   105	    equity: pd.DataFrame,
   106	    *,
   107	    periods_per_year: int = 365,
   108	    risk_free_rate: float = 0.0,
   109	    weights: pd.DataFrame | None = None,
   110	    benchmark_nav: pd.Series | None = None,
   111	) -> dict[str, float]:
   112	    """Calculate shared return, risk, cost, concentration and benchmark metrics."""
   113	    if "nav" not in equity.columns:
   114	        msg = "equity must contain a 'nav' column"
   115	        raise ValueError(msg)
   116	    nav = equity["nav"].astype("float64")
   117	    if nav.empty or not nav.map(math.isfinite).all() or (nav <= 0).any():
   118	        msg = "equity nav must be finite, positive and non-empty"
   119	        raise ValueError(msg)
   120	    returns = nav.pct_change().dropna()
   121	    total_return = float(nav.iloc[-1] / nav.iloc[0] - 1.0)
   122	    cagr = _annualized_return(total_return, len(nav), periods_per_year)
   123	    volatility = float(returns.std(ddof=1) * np.sqrt(periods_per_year)) if len(returns) > 1 else 0.0
   124	    rf_per_period = risk_free_rate / periods_per_year
   125	    excess = returns - rf_per_period
   126	    sharpe = (
   127	        float(excess.mean() / returns.std(ddof=1) * np.sqrt(periods_per_year))
   128	        if len(returns) > 1 and returns.std(ddof=1) > 0
   129	        else 0.0
   130	    )
   131	    downside = returns[returns < rf_per_period] - rf_per_period
   132	    downside_dev = (
   133	        float(np.sqrt((downside**2).mean()) * np.sqrt(periods_per_year))
   134	        if not downside.empty
   135	        else 0.0
   136	    )
   137	    sortino = (
   138	        float((returns.mean() - rf_per_period) * periods_per_year / downside_dev)
   139	        if downside_dev > 0
   140	        else 0.0
   141	    )
   142	    max_dd, drawdown_duration = _max_drawdown(nav)
   143	    calmar = float(cagr / abs(max_dd)) if max_dd < 0 else 0.0
   144	    var_95, cvar_95 = _historical_var_cvar(returns, 0.95)
   145
   146	    metrics = {
   147	        "total_return": total_return,
   148	        "roi": total_return,
   149	        "cagr": cagr,
   150	        "volatility": volatility,
   151	        "sharpe": sharpe,
   152	        "sortino": sortino,
   153	        "downside_deviation": downside_dev,
   154	        "calmar": calmar,
   155	        "max_drawdown": max_dd,
   156	        "drawdown_duration": float(drawdown_duration),
   157	        "var_95": var_95,
   158	        "cvar_95": cvar_95,
   159	        "turnover": float(equity.get("turnover", _zero_series(equity.index)).sum()),
   160	        "average_exposure": float(equity.get("exposure", _zero_series(equity.index)).mean()),
   161	        "trade_count": float(equity.get("trade_count", _zero_series(equity.index)).sum()),
   162	        "fees": float(equity.get("fees", _zero_series(equity.index)).sum()),
   163	        "slippage": float(equity.get("slippage", _zero_series(equity.index)).sum()),
   164	        "total_cost": float(equity.get("total_cost", _zero_series(equity.index)).sum()),
   165	    }
   166	    metrics.update(_weight_metrics(weights, equity))
   167	    if benchmark_nav is not None:
   168	        benchmark = benchmark_nav.astype("float64")
   169	        if len(benchmark) == len(nav):
   170	            benchmark = pd.Series(benchmark.to_numpy(), index=nav.index, dtype="float64")
   171	        else:
   172	            benchmark = benchmark.reindex(nav.index).ffill()
   173	        if benchmark.isna().any() or (benchmark <= 0).any():
   174	            msg = "benchmark_nav must align to equity and contain finite positive values"
   175	            raise ValueError(msg)
   176	        benchmark_returns = benchmark.pct_change().dropna()
   177	        benchmark_total_return = float(benchmark.iloc[-1] / benchmark.iloc[0] - 1.0)
   178	        benchmark_volatility = (
   179	            float(benchmark_returns.std(ddof=1) * np.sqrt(periods_per_year))
   180	            if len(benchmark_returns) > 1
   181	            else 0.0
   182	        )
   183	        active_returns = returns - benchmark_returns.reindex(returns.index).fillna(0.0)
   184	        tracking_error = (
   185	            float(active_returns.std(ddof=1) * np.sqrt(periods_per_year))
   186	            if len(active_returns) > 1
   187	            else 0.0
   188	        )
   189	        metrics["benchmark_total_return"] = float(benchmark.iloc[-1] / benchmark.iloc[0] - 1.0)
   190	        metrics["benchmark_cagr"] = _annualized_return(
   191	            benchmark_total_return, len(benchmark), periods_per_year
   192	        )
   193	        metrics["benchmark_volatility"] = benchmark_volatility
   194	        metrics["excess_total_return"] = total_return - benchmark_total_return
   195	        metrics["tracking_error"] = tracking_error
   196	        metrics["information_ratio"] = (
   197	            float(active_returns.mean() / active_returns.std(ddof=1) * np.sqrt(periods_per_year))
   198	            if len(active_returns) > 1 and active_returns.std(ddof=1) > 0
   199	            else 0.0
   200	        )
   201	    return metrics
