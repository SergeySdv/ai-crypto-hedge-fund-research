    17	def _utc_timestamp(value: datetime | pd.Timestamp) -> pd.Timestamp:
    18	    ts = pd.Timestamp(value)
    19	    if ts.tzinfo is None:
    20	        msg = f"timestamp must be timezone-aware UTC: {value!r}"
    21	        raise ValueError(msg)
    22	    ts = ts.tz_convert(UTC)
    23	    if ts != pd.Timestamp(value):
    24	        msg = f"timestamp must already be normalized to UTC: {value!r}"
    25	        raise ValueError(msg)
    26	    return ts
