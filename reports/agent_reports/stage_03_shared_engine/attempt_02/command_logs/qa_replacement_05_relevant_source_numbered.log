    12	def _timestamp(value: datetime | pd.Timestamp) -> pd.Timestamp:
    13	    timestamp = pd.Timestamp(value)
    14	    if timestamp.tzinfo is None:
    15	        msg = "timestamp must be timezone-aware UTC"
    16	        raise ValueError(msg)
    17	    timestamp = timestamp.tz_convert(UTC)
    18	    if timestamp != pd.Timestamp(value):
    19	        msg = "timestamp must already be normalized to UTC"
    20	        raise ValueError(msg)
    21	    return timestamp
    22
    23
    24	def _finite_non_negative(value: float, *, field_name: str) -> float:
    25	    number = float(value)
    26	    if not math.isfinite(number) or number < 0:
    27	        msg = f"{field_name} must be finite and non-negative"
    28	        raise ValueError(msg)
    29	    return number
