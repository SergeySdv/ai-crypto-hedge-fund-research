   153	def test_broker_ledger_transitions_are_consistent_across_rebalance_cases() -> None:
   154	    rows = []
   155	    for day in pd.date_range("2024-01-01", periods=6, tz="UTC"):
   156	        timestamp = day.isoformat()
   157	        rows.append((timestamp, "BTC/USDT", 100.0))
   158	        rows.append((timestamp, "ETH/USDT", 50.0))
   159	    market = _panel(rows)
   160	    broker = SimulatedBroker(
   161	        market,
   162	        initial_capital=1000,
   163	        cost_assumptions=CostAssumptions(fee_bps_one_way=0, slippage_bps_one_way=0),
   164	    )
   165	    schedule = pd.DataFrame(
   166	        [
   167	            {"BTC/USDT": 0.5, "ETH/USDT": 0.0},
   168	            {"BTC/USDT": 0.5, "ETH/USDT": 0.0},
   169	            {"BTC/USDT": 0.25, "ETH/USDT": 0.25},
   170	            {"BTC/USDT": 0.0, "ETH/USDT": 0.5},
   171	            {"BTC/USDT": 0.0, "ETH/USDT": 0.0},
   172	        ],
   173	        index=pd.date_range("2024-01-01", periods=5, tz="UTC"),
   174	    )
   175
   176	    result = broker.run(schedule, end_time=pd.Timestamp("2024-01-06T00:00:00+00:00"))
   177	    equity = result.equity.set_index("timestamp")
   178	    weights = result.weights.set_index("timestamp")
   179
   180	    assert equity["nav"].tolist() == pytest.approx([1000] * 6)
   181	    assert equity.loc[pd.Timestamp("2024-01-02T00:00:00+00:00"), "cash"] == pytest.approx(500)
   182	    assert weights.loc[pd.Timestamp("2024-01-02T00:00:00+00:00"), "BTC/USDT"] == pytest.approx(0.5)
   183	    assert equity.loc[pd.Timestamp("2024-01-03T00:00:00+00:00"), "trade_count"] == pytest.approx(0)
   184	    assert weights.loc[pd.Timestamp("2024-01-04T00:00:00+00:00"), "BTC/USDT"] == pytest.approx(0.25)
   185	    assert weights.loc[pd.Timestamp("2024-01-04T00:00:00+00:00"), "ETH/USDT"] == pytest.approx(0.25)
   186	    assert weights.loc[pd.Timestamp("2024-01-05T00:00:00+00:00"), "BTC/USDT"] == pytest.approx(0.0)
   187	    assert weights.loc[pd.Timestamp("2024-01-05T00:00:00+00:00"), "ETH/USDT"] == pytest.approx(0.5)
   188	    assert equity.loc[pd.Timestamp("2024-01-06T00:00:00+00:00"), "cash"] == pytest.approx(1000)
   189	    assert weights.loc[pd.Timestamp("2024-01-06T00:00:00+00:00"), "cash_weight"] == pytest.approx(
   190	        1.0
   191	    )
   192	    assert result.orders["side"].tolist() == ["buy", "sell", "buy", "sell", "buy", "sell"]
   193	    assert result.fills["total_cost"].sum() == pytest.approx(0.0)
