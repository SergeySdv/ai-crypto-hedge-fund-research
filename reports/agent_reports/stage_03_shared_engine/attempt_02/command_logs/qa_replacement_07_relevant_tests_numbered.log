   113	def test_one_symbol_and_multi_symbol_use_same_engine_and_are_deterministic() -> None:
   114	    rows = []
   115	    for day, btc, eth in [
   116	        ("2024-01-01T00:00:00+00:00", 100.0, 50.0),
   117	        ("2024-01-02T00:00:00+00:00", 100.0, 50.0),
   118	        ("2024-01-03T00:00:00+00:00", 110.0, 55.0),
   119	        ("2024-01-04T00:00:00+00:00", 121.0, 50.0),
   120	    ]:
   121	        rows.append((day, "BTC/USDT", btc))
   122	        rows.append((day, "ETH/USDT", eth))
   123	    market = _panel(rows)
   124	    assumptions = CostAssumptions(fee_bps_one_way=0, slippage_bps_one_way=0)
   125	    one_symbol = pd.DataFrame(
   126	        [{"BTC/USDT": 0.5}],
   127	        index=[pd.Timestamp("2024-01-01T00:00:00+00:00")],
   128	    )
   129	    multi_symbol = pd.DataFrame(
   130	        [{"BTC/USDT": 0.25, "ETH/USDT": 0.25}],
   131	        index=[pd.Timestamp("2024-01-01T00:00:00+00:00")],
   132	    )
   133
   134	    first = SimulatedBroker(market, initial_capital=1000, cost_assumptions=assumptions).run(
   135	        one_symbol,
   136	        end_time=datetime(2024, 1, 4, tzinfo=UTC),
   137	    )
   138	    second = SimulatedBroker(market, initial_capital=1000, cost_assumptions=assumptions).run(
   139	        one_symbol,
   140	        end_time=datetime(2024, 1, 4, tzinfo=UTC),
   141	    )
   142	    multi = SimulatedBroker(market, initial_capital=1000, cost_assumptions=assumptions).run(
   143	        multi_symbol,
   144	        end_time=datetime(2024, 1, 4, tzinfo=UTC),
   145	    )
   146
   147	    pd.testing.assert_frame_equal(first.equity, second.equity)
   148	    pd.testing.assert_frame_equal(first.orders, second.orders)
   149	    assert set(multi.fills["symbol"]) == {"BTC/USDT", "ETH/USDT"}
   150	    assert list(first.weights.columns) != ["BTC/USDT"]
