    11	def _cost(target: dict[str, float], pretrade: dict[str, float]) -> float:
    12	    model = WeightDeltaCostModel(CostAssumptions(fee_bps_one_way=10, slippage_bps_one_way=5))
    13	    return model.estimate_from_weight_deltas(
    14	        pd.Series(target, dtype="float64"),
    15	        pd.Series(pretrade, dtype="float64"),
    16	        1_000_000,
    17	    ).total_cost
