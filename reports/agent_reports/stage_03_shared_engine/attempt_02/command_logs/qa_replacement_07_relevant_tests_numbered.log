     9	def test_artifact_writers_add_provenance_and_stable_schema(tmp_path) -> None:
    10	    result = BacktestRunResult(
    11	        equity=pd.DataFrame(
    12	            {"timestamp": pd.date_range("2024-01-01", periods=1, tz="UTC"), "nav": [1.0]}
    13	        ),
    14	        weights=pd.DataFrame(
    15	            {
    16	                "timestamp": pd.date_range("2024-01-01", periods=1, tz="UTC"),
    17	                "cash_weight": [1.0],
    18	            }
    19	        ),
    20	        orders=pd.DataFrame({"order_id": ["o1"], "symbol": ["BTC/USDT"]}),
    21	        fills=pd.DataFrame({"order_id": ["o1"], "symbol": ["BTC/USDT"], "fee": [1.0]}),
    22	    )
    23	    provenance = ArtifactProvenance(
    24	        level="level_1",
    25	        run_label="validation",
    26	        split="validation",
    27	        data_hash="datahash",
    28	        config_hash="confighash",
    29	        git_commit="gitsha",
    30	        period_start="2024-01-01",
    31	        period_end="2024-12-31",
    32	        cost_assumptions={"fee_bps_one_way": 10.0, "slippage_bps_one_way": 5.0},
    33	        benchmark="buy_and_hold",
    34	        seed=42,
    35	        warnings=("survivorship_bias_active_markets",),
    36	        created_at_utc="2026-01-01T00:00:00+00:00",
    37	    )
    38
    39	    paths = BacktestArtifactWriter(tmp_path).write_run(
    40	        result,
    41	        {"total_return": 0.1, "sharpe": 1.0},
    42	        provenance,
    43	        level_name="level_1",
    44	    )
    45
    46	    metrics = pd.read_csv(paths["metrics"])
    47	    equity = pd.read_parquet(paths["equity"])
    48	    assert metrics.loc[0, "provenance_data_hash"] == "datahash"
    49	    assert metrics.loc[0, "provenance_artifact_schema_version"] == "stage3-execution-artifacts-v1"
    50	    assert equity.loc[0, "provenance_run_label"] == "validation"
    51	    assert set(paths) == {"metrics", "equity", "weights", "orders", "fills"}
    52
    53	    sidecar = paths["equity"].with_suffix(".parquet.metadata.json")
    54	    metadata = json.loads(sidecar.read_text(encoding="utf-8"))
    55	    assert metadata["artifact_schema_version"] == "stage3-execution-artifacts-v1"
    56	    assert metadata["warnings"] == ["survivorship_bias_active_markets"]
