    38	def test_completed_bar_signal_fills_only_at_next_open_and_has_no_earlier_pnl() -> None:
    39	    market = _panel(
    40	        [
    41	            ("2024-01-01T00:00:00+00:00", "BTC/USDT", 100.0),
    42	            ("2024-01-02T00:00:00+00:00", "BTC/USDT", 200.0),
    43	            ("2024-01-03T00:00:00+00:00", "BTC/USDT", 300.0),
    44	            ("2024-01-04T00:00:00+00:00", "BTC/USDT", 600.0),
    45	        ]
    46	    )
    47	    broker = SimulatedBroker(
    48	        market,
    49	        initial_capital=1000,
    50	        cost_assumptions=CostAssumptions(fee_bps_one_way=0, slippage_bps_one_way=0),
    51	    )
    52	    result = broker.run(
    53	        pd.DataFrame(
    54	            [{"BTC/USDT": 0.5}],
    55	            index=[pd.Timestamp("2024-01-01T00:00:00+00:00")],
    56	        ),
    57	        end_time=pd.Timestamp("2024-01-04T00:00:00+00:00"),
    58	    )
    59
    60	    equity = result.equity.set_index("timestamp")
    61	    assert equity.loc[pd.Timestamp("2024-01-01T00:00:00+00:00"), "nav"] == pytest.approx(1000)
    62	    assert equity.loc[pd.Timestamp("2024-01-01T00:00:00+00:00"), "exposure"] == pytest.approx(0)
    63	    assert result.fills["timestamp"].tolist() == [pd.Timestamp("2024-01-02T00:00:00+00:00")]
    64	    assert equity.loc[pd.Timestamp("2024-01-02T00:00:00+00:00"), "nav"] == pytest.approx(1000)
    65	    assert equity.loc[pd.Timestamp("2024-01-03T00:00:00+00:00"), "nav"] == pytest.approx(1250)
    66	    assert equity.loc[pd.Timestamp("2024-01-04T00:00:00+00:00"), "nav"] == pytest.approx(2000)
