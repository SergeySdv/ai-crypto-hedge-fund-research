   152	def _optimize_capped_weights(
   153	    *,
   154	    objective,
   155	    symbols: list[str],
   156	    constraints: RiskConstraints,
   157	    previous_weights: pd.Series,
   158	    objective_name: str,
   159	    metadata: dict[str, object],
   160	) -> PortfolioProposal:
   161	    target_gross = _target_gross(symbols, constraints)
   162	    if target_gross <= 0:
   163	        return _failure_proposal(
   164	            constraints=constraints,
   165	            previous_weights=previous_weights,
   166	            reason="target gross exposure is zero",
   167	        )
   168	    caps = np.array([constraints.per_asset_caps.get(symbol, 0.0) for symbol in symbols])
   169	    if float(caps.sum()) + 1e-12 < target_gross:
   170	        return _failure_proposal(
   171	            constraints=constraints,
   172	            previous_weights=previous_weights,
   173	            reason="per-asset caps cannot fund target gross exposure",
   174	        )
   175	    x0 = np.full(len(symbols), target_gross / len(symbols), dtype="float64")
   176	    x0 = np.minimum(x0, caps)
   177	    if float(x0.sum()) <= 0:
   178	        return _failure_proposal(
   179	            constraints=constraints,
   180	            previous_weights=previous_weights,
   181	            reason="initial optimizer weights are zero",
   182	        )
   183	    x0 *= target_gross / float(x0.sum())
   184	    result = minimize(
   185	        objective,
   186	        x0,
   187	        method="SLSQP",
   188	        bounds=[(0.0, float(cap)) for cap in caps],
   189	        constraints=({"type": "eq", "fun": lambda weights: float(weights.sum() - target_gross)},),
   190	        options={"ftol": 1e-12, "maxiter": 500, "disp": False},
   191	    )
   192	    if not result.success or not np.isfinite(result.x).all():
   193	        return _failure_proposal(
   194	            constraints=constraints,
   195	            previous_weights=previous_weights,
   196	            reason=f"{objective_name} optimizer failed: {result.message}",
   197	        )
   198	    weights = {
   199	        symbol: max(0.0, float(weight))
   200	        for symbol, weight in zip(symbols, result.x, strict=True)
   201	        if float(weight) > 1e-12
   202	    }
   203	    objective_value = float(objective(result.x))
   204	    return _proposal(
   205	        constraints=constraints,
   206	        weights=weights,
   207	        previous_weights=previous_weights,
   208	        objective_value=objective_value,
   209	        metadata={**metadata, "objective": objective_name},
   210	    )
