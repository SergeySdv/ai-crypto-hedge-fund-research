   302	@dataclass(frozen=True)
   303	class MinimumVarianceAllocator:
   304	    """Long-only capped minimum-variance allocator with covariance shrinkage."""
   305
   306	    name: str = "minimum_variance"
   307	    min_periods: int = 30
   308	    shrinkage: float = 0.10
   309
   310	    def allocate(
   311	        self,
   312	        signals: pd.Series,
   313	        historical_returns: pd.DataFrame,
   314	        constraints: RiskConstraints,
   315	        previous_weights: pd.Series,
   316	    ) -> PortfolioProposal:
   317	        symbols = _eligible_symbols(signals, constraints)
   318	        try:
   319	            returns = _clean_returns(historical_returns, symbols, min_periods=self.min_periods)
   320	            covariance = _shrink_covariance(returns, self.shrinkage)
   321	        except ValueError as exc:
   322	            return _failure_proposal(
   323	                constraints=constraints,
   324	                previous_weights=previous_weights,
   325	                reason=str(exc),
   326	            )
   327
   328	        def objective(weights: np.ndarray) -> float:
   329	            return float(weights @ covariance @ weights)
   330
   331	        return _optimize_capped_weights(
   332	            objective=objective,
   333	            symbols=symbols,
   334	            constraints=constraints,
   335	            previous_weights=previous_weights,
   336	            objective_name="minimize w' Sigma_shrunk w subject to long-only caps and gross budget",
   337	            metadata={
   338	                "allocator": self.name,
   339	                "shrinkage": self.shrinkage,
   340	                "min_periods": self.min_periods,
   341	            },
   342	        )
