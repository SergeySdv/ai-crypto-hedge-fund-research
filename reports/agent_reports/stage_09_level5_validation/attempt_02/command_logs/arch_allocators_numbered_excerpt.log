   247	@dataclass(frozen=True)
   248	class InverseVolatilityAllocator:
   249	    """Allocate by inverse realized volatility with explicit failure on invalid inputs."""
   250
   251	    name: str = "inverse_volatility"
   252	    min_periods: int = 2
   253
   254	    def allocate(
   255	        self,
   256	        signals: pd.Series,
   257	        historical_returns: pd.DataFrame,
   258	        constraints: RiskConstraints,
   259	        previous_weights: pd.Series,
   260	    ) -> PortfolioProposal:
   261	        symbols = _eligible_symbols(signals, constraints)
   262	        if not symbols:
   263	            return _proposal(
   264	                constraints=constraints,
   265	                weights={},
   266	                previous_weights=previous_weights,
   267	                objective_value=None,
   268	                status="no_eligible_symbols",
   269	                reason_codes=(ReasonCode.ABSTAIN,),
   270	            )
   271	        if historical_returns.empty or len(historical_returns) < self.min_periods:
   272	            return self._failure(constraints, previous_weights, "not enough return history")
   273	        returns = historical_returns.reindex(columns=symbols)
   274	        vol = returns.std(ddof=0).replace(0.0, math.nan)
   275	        if vol.isna().any() or (vol <= 0).any():
   276	            return self._failure(
   277	                constraints, previous_weights, "non-positive or missing volatility"
   278	            )
   279	        inv = 1.0 / vol
   280	        inv = inv / inv.sum() * constraints.max_gross_exposure
   281	        weights = _cap_and_normalize(inv.to_dict(), constraints)
   282	        return _proposal(
   283	            constraints=constraints,
   284	            weights=weights,
   285	            previous_weights=previous_weights,
   286	            objective_value=float(-vol.mean()),
   287	        )
   288
   289	    def _failure(
   290	        self,
   291	        constraints: RiskConstraints,
   292	        previous_weights: pd.Series,
   293	        reason: str,
   294	    ) -> PortfolioProposal:
   295	        return _failure_proposal(
   296	            constraints=constraints,
   297	            previous_weights=previous_weights,
   298	            reason=reason,
   299	        )
