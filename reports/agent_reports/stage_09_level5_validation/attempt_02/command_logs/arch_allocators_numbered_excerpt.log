    15	def _eligible_symbols(signals: pd.Series, constraints: RiskConstraints) -> list[str]:
    16	    clean = signals.astype("float64").replace([math.inf, -math.inf], math.nan).dropna()
    17	    clean.index = clean.index.astype(str)
    18	    return [
    19	        symbol
    20	        for symbol, score in clean.items()
    21	        if symbol not in constraints.blocked_symbols
    22	        and constraints.per_asset_caps.get(symbol, 0.0) > 0
    23	        and score > 0
    24	    ]
    25
    26
    27	def _proposal(
    28	    *,
    29	    constraints: RiskConstraints,
    30	    weights: dict[str, float],
    31	    previous_weights: pd.Series,
    32	    objective_value: float | None,
    33	    status: str = "ok",
    34	    reason_codes: tuple[ReasonCode, ...] = (ReasonCode.OK,),
    35	    metadata: dict[str, object] | None = None,
    36	) -> PortfolioProposal:
    37	    weights = {symbol: max(0.0, float(weight)) for symbol, weight in weights.items()}
    38	    risky_sum = sum(weights.values())
    39	    cash_weight = 1.0 - risky_sum
    40	    previous = previous_weights.astype("float64").reindex(weights, fill_value=0.0)
    41	    target = pd.Series(weights, dtype="float64")
    42	    expected_turnover = float((target - previous).abs().sum())
    43	    return PortfolioProposal(
    44	        decision_time=constraints.decision_time,
    45	        target_weights=weights,
    46	        cash_weight=cash_weight,
    47	        optimizer_status=status,
    48	        expected_turnover=expected_turnover,
    49	        objective_value=objective_value,
    50	        reason_codes=reason_codes,
    51	        metadata=metadata or {},
    52	    )
    53
    54
    55	def _failure_proposal(
    56	    *,
    57	    constraints: RiskConstraints,
    58	    previous_weights: pd.Series,
    59	    reason: str,
    60	) -> PortfolioProposal:
    61	    return _proposal(
    62	        constraints=constraints,
    63	        weights={},
    64	        previous_weights=previous_weights,
    65	        objective_value=None,
    66	        status="optimizer_failure",
    67	        reason_codes=(ReasonCode.OPTIMIZER_FAILURE,),
    68	        metadata={"error": reason},
    69	    )
