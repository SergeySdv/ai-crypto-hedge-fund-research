   213	@dataclass(frozen=True)
   214	class EqualWeightAllocator:
   215	    """Allocate equal risky weights to approved positive-score symbols."""
   216
   217	    name: str = "equal_weight"
   218
   219	    def allocate(
   220	        self,
   221	        signals: pd.Series,
   222	        historical_returns: pd.DataFrame,
   223	        constraints: RiskConstraints,
   224	        previous_weights: pd.Series,
   225	    ) -> PortfolioProposal:
   226	        del historical_returns
   227	        symbols = _eligible_symbols(signals, constraints)
   228	        if not symbols:
   229	            return _proposal(
   230	                constraints=constraints,
   231	                weights={},
   232	                previous_weights=previous_weights,
   233	                objective_value=None,
   234	                status="no_eligible_symbols",
   235	                reason_codes=(ReasonCode.ABSTAIN,),
   236	            )
   237	        base_weight = constraints.max_gross_exposure / len(symbols)
   238	        weights = _cap_and_normalize(dict.fromkeys(symbols, base_weight), constraints)
   239	        return _proposal(
   240	            constraints=constraints,
   241	            weights=weights,
   242	            previous_weights=previous_weights,
   243	            objective_value=None,
   244	        )
