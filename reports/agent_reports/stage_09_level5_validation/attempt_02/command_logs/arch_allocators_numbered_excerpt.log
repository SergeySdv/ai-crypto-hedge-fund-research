    72	def _cap_and_normalize(
    73	    raw_weights: dict[str, float], constraints: RiskConstraints
    74	) -> dict[str, float]:
    75	    if not raw_weights:
    76	        return {}
    77	    raw = {
    78	        symbol: max(0.0, float(weight))
    79	        for symbol, weight in raw_weights.items()
    80	        if constraints.per_asset_caps.get(symbol, 0.0) > 0 and float(weight) > 0
    81	    }
    82	    if not raw:
    83	        return {}
    84	    caps = {symbol: float(constraints.per_asset_caps.get(symbol, 0.0)) for symbol in raw}
    85	    target_gross = min(float(constraints.max_gross_exposure), sum(caps.values()))
    86	    if target_gross <= 0:
    87	        return {}
    88	    weights = dict.fromkeys(raw, 0.0)
    89	    remaining = set(raw)
    90	    remaining_gross = target_gross
    91	    for _ in range(len(raw)):
    92	        raw_sum = sum(raw[symbol] for symbol in remaining)
    93	        if raw_sum <= 0 or remaining_gross <= 0:
    94	            break
    95	        capped_this_round = set()
    96	        for symbol in sorted(remaining):
    97	            candidate = remaining_gross * raw[symbol] / raw_sum
    98	            if candidate >= caps[symbol]:
    99	                weights[symbol] = caps[symbol]
   100	                capped_this_round.add(symbol)
   101	        if not capped_this_round:
   102	            for symbol in remaining:
   103	                weights[symbol] = remaining_gross * raw[symbol] / raw_sum
   104	            remaining.clear()
   105	            break
   106	        remaining -= capped_this_round
   107	        remaining_gross = target_gross - sum(weights.values())
   108	    return {symbol: weight for symbol, weight in weights.items() if weight > 1e-12}
   109
   110
   111	def _target_gross(symbols: list[str], constraints: RiskConstraints) -> float:
   112	    cap_sum = sum(
   113	        max(0.0, float(constraints.per_asset_caps.get(symbol, 0.0))) for symbol in symbols
   114	    )
   115	    return min(float(constraints.max_gross_exposure), cap_sum)
   116
   117
   118	def _clean_returns(
   119	    historical_returns: pd.DataFrame,
   120	    symbols: list[str],
   121	    *,
   122	    min_periods: int,
   123	) -> pd.DataFrame:
   124	    if historical_returns.empty or len(historical_returns) < min_periods:
   125	        msg = "not enough return history"
   126	        raise ValueError(msg)
   127	    returns = historical_returns.reindex(columns=symbols).dropna(how="any")
   128	    if len(returns) < min_periods:
   129	        msg = "not enough complete return history"
   130	        raise ValueError(msg)
   131	    numeric = returns.astype("float64")
   132	    if not np.isfinite(numeric.to_numpy()).all():
   133	        msg = "return history contains non-finite values"
   134	        raise ValueError(msg)
   135	    return numeric
   136
   137
   138	def _shrink_covariance(returns: pd.DataFrame, shrinkage: float) -> np.ndarray:
   139	    values = returns.to_numpy(dtype="float64")
   140	    covariance = np.cov(values, rowvar=False, ddof=0)
   141	    covariance = np.atleast_2d(covariance).astype("float64")
   142	    if not np.isfinite(covariance).all():
   143	        msg = "covariance matrix contains non-finite values"
   144	        raise ValueError(msg)
   145	    diagonal = np.diag(np.diag(covariance))
   146	    alpha = min(1.0, max(0.0, float(shrinkage)))
   147	    covariance = (1.0 - alpha) * covariance + alpha * diagonal
   148	    covariance += np.eye(covariance.shape[0]) * 1e-10
   149	    return covariance
   150
