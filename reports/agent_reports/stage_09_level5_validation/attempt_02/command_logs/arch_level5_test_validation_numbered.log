    17	def _default_level5_config(tmp_path: Path, *, kill_switch: bool = False) -> Path:
    18	    root = find_repo_root()
    19	    config = yaml.safe_load((root / "configs/default.yaml").read_text(encoding="utf-8"))
    20	    config["paths"]["market_data"] = str(root / config["paths"]["market_data"])
    21	    config["paths"]["instruments"] = str(root / config["paths"]["instruments"])
    22	    config["paths"]["manifest"] = str(root / config["paths"]["manifest"])
    23	    config["paths"]["artifacts"] = str(tmp_path / "artifacts")
    24	    config["level_5"]["kill_switch"] = kill_switch
    25	    config["final_test"]["lock_path"] = str(tmp_path / "artifacts" / "final_test_lock.json")
    26	    path = tmp_path / "config.yaml"
    27	    path.write_text(yaml.safe_dump(config), encoding="utf-8")
    28	    return path
    29
    30
    31	@pytest.fixture()
    32	def level5_result(tmp_path: Path):
    33	    return run_level_5_validation(config_path=_default_level5_config(tmp_path))
    34
