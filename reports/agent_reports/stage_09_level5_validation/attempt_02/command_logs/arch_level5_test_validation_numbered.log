    75	def test_level5_topk_liquidity_and_weight_caps_hold(level5_result) -> None:
    76	    scores = pd.read_parquet(level5_result.universe_scores_path)
    77	    log = pd.read_parquet(level5_result.rebalance_log_path)
    78	    weights = pd.read_parquet(level5_result.artifact_paths["weights"])
    79	    symbol_columns = [column for column in weights.columns if "/" in column]
    80
    81	    assert scores.loc[scores["selected_top_k"], "max_weight_by_liquidity"].gt(0.0).all()
    82	    assert log["selected_count"].max() == 25
    83	    assert log["approved_nonzero_count"].max() <= 25
    84	    assert weights[symbol_columns].max().max() <= 0.05 + 0.01
    85	    assert log["max_approved_weight"].max() <= 0.05 + 1e-12
    86
