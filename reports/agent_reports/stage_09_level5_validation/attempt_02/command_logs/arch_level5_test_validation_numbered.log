    36	def test_level5_full_mode_scores_100_pairs_and_writes_validation_artifacts(level5_result) -> None:
    37	    proof = json.loads(level5_result.pair_count_proof_path.read_text(encoding="utf-8"))
    38	    metrics = pd.read_csv(level5_result.artifact_paths["metrics"])
    39	    scores = pd.read_parquet(level5_result.universe_scores_path)
    40	    log = pd.read_parquet(level5_result.rebalance_log_path)
    41	    metadata = json.loads(
    42	        level5_result.artifact_paths["metrics"]
    43	        .with_suffix(".csv.metadata.json")
    44	        .read_text(encoding="utf-8")
    45	    )
    46
    47	    assert proof["split"] == "validation"
    48	    assert proof["final_test_exposure"] == "NOT_EXPOSED"
    49	    assert proof["scored_count"] >= 100
    50	    assert proof["selected_count"] == 25
    51	    assert metrics["provenance_split"].iloc[0] == "validation"
    52	    assert metadata["final_test_lock_hash"] is None
    53	    assert metrics["scored_count_max"].iloc[0] >= 100
    54	    assert scores.groupby("decision_bar_start")["symbol"].nunique().max() >= 100
    55	    assert scores["selected_top_k"].any()
    56	    assert log["submitted_to_broker"].any()
    57	    assert level5_result.figure_path.exists()
    58
