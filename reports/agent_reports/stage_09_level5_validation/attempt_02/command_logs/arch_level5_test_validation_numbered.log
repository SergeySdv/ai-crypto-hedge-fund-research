    60	def test_level5_cutoffs_and_artifacts_do_not_enter_final_test(level5_result) -> None:
    61	    scores = pd.read_parquet(level5_result.universe_scores_path)
    62	    weights = pd.read_parquet(level5_result.artifact_paths["weights"])
    63	    trace = json.loads(level5_result.decision_trace_path.read_text(encoding="utf-8"))
    64
    65	    assert pd.to_datetime(scores["feature_cutoff"], utc=True).max() < pd.Timestamp(
    66	        "2025-01-01", tz="UTC"
    67	    )
    68	    assert pd.to_datetime(weights["timestamp"], utc=True).max() <= pd.Timestamp(
    69	        "2024-12-31", tz="UTC"
    70	    )
    71	    assert trace["final_test_exposure"] == "NOT_EXPOSED"
    72	    assert trace["portfolio_protocol"]["point_in_time_universe"] is True
    73
