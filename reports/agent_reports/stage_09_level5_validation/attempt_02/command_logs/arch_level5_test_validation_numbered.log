    88	def test_level5_kill_switch_scores_but_moves_schedule_to_cash(tmp_path: Path) -> None:
    89	    config_path = _default_level5_config(tmp_path, kill_switch=True)
    90	    config = yaml.safe_load(config_path.read_text(encoding="utf-8"))
    91	    frame = pd.read_parquet(config["paths"]["market_data"])
    92	    instruments = pd.read_parquet(config["paths"]["instruments"])
    93
    94	    schedule, scores, log, traces = build_level_5_target_schedule(
    95	        frame=frame,
    96	        instruments=instruments,
    97	        config=config,
    98	        decision_start=pd.Timestamp(config["level_5"]["validation_decision_start"], tz="UTC"),
    99	        decision_end=pd.Timestamp(config["level_5"]["validation_decision_start"], tz="UTC"),
   100	    )
   101
   102	    assert scores["scored"].sum() >= 100
   103	    assert schedule.sum(axis=1).eq(0.0).all()
   104	    assert set(log["approval_action"]) == {"cash"}
   105	    assert traces[0].approval is not None
   106	    assert traces[0].approval.reason_codes[0].value == "kill_switch"
   107
