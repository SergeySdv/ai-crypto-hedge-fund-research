   109	def test_level5_schedule_repeatability_on_same_inputs(tmp_path: Path) -> None:
   110	    config_path = _default_level5_config(tmp_path)
   111	    config = yaml.safe_load(config_path.read_text(encoding="utf-8"))
   112	    frame = pd.read_parquet(config["paths"]["market_data"])
   113	    instruments = pd.read_parquet(config["paths"]["instruments"])
   114	    kwargs = {
   115	        "frame": frame,
   116	        "instruments": instruments,
   117	        "config": config,
   118	        "decision_start": pd.Timestamp(config["level_5"]["validation_decision_start"], tz="UTC"),
   119	        "decision_end": pd.Timestamp(config["level_5"]["validation_decision_start"], tz="UTC"),
   120	    }
   121
   122	    schedule_a, scores_a, _, _ = build_level_5_target_schedule(**kwargs)
   123	    schedule_b, scores_b, _, _ = build_level_5_target_schedule(**kwargs)
   124
   125	    pd.testing.assert_frame_equal(schedule_a, schedule_b)
   126	    pd.testing.assert_series_equal(
   127	        scores_a.sort_values("symbol").set_index("symbol")["score"],
   128	        scores_b.sort_values("symbol").set_index("symbol")["score"],
   129	    )
