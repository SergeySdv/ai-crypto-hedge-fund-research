    57	@dataclass(frozen=True)
    58	class UniverseRules:
    59	    """Rules used by the Stage 2 full-mode Level 5 universe proof."""
    60
    61	    quote_currency: str
    62	    stable_bases: tuple[str, ...]
    63	    min_history_days: int
    64	    preferred_history_days: int
    65	    liquidity_lookback_days: int
    66	    large_universe_size: int
    67	    min_trailing_valid_days: int | None = None
    68	    min_median_dollar_volume: float = 0.0
    69
    70	    @classmethod
    71	    def from_config(cls, config: dict) -> UniverseRules:
    72	        data = config["data"]
    73	        min_trailing = max(1, int(data["liquidity_lookback_days"]) * 4 // 5)
    74	        return cls(
    75	            quote_currency=str(data["quote_currency"]),
    76	            stable_bases=tuple(str(item) for item in data.get("stable_bases", ())),
    77	            min_history_days=int(data["min_history_days"]),
    78	            preferred_history_days=int(data["preferred_history_days"]),
    79	            liquidity_lookback_days=int(data["liquidity_lookback_days"]),
    80	            large_universe_size=int(data["large_universe_size"]),
    81	            min_trailing_valid_days=min_trailing,
    82	        )
    83
    84
    85	def split_symbol(symbol: str) -> tuple[str, str]:
    86	    """Split a CCXT-style symbol into base and quote components."""
    87	    if "/" not in symbol:
    88	        msg = f"Expected CCXT symbol with base/quote separator: {symbol}"
    89	        raise ValueError(msg)
    90	    base, quote = symbol.split("/", 1)
    91	    return base, quote.split(":", 1)[0]
    92
    93
    94	def deterministic_exclusion_reason(
    95	    row: pd.Series,
    96	    *,
    97	    rules: UniverseRules,
    98	) -> str | None:
    99	    """Return an exclusion reason for static instrument filters, or ``None``."""
   100	    symbol = str(row["symbol"])
   101	    base = str(row.get("base") or split_symbol(symbol)[0]).upper()
   102	    quote = str(row.get("quote") or split_symbol(symbol)[1]).upper()
   103	    stable_bases = {item.upper() for item in rules.stable_bases} | FIAT_LIKE_BASES
   104	    if quote != rules.quote_currency.upper():
   105	        return "wrong_quote_currency"
   106	    if str(row.get("market_type", "")).lower() != "spot":
   107	        return "non_spot"
   108	    if not bool(row.get("active", False)):
   109	        return "inactive"
   110	    if base in stable_bases:
   111	        return "stable_or_fiat_base"
   112	    if any(base.endswith(suffix) for suffix in LEVERAGED_SUFFIXES):
   113	        return "leveraged_token_suffix"
   114	    if any(token in base for token in ("BULL", "BEAR")):
   115	        return "leveraged_token_name"
   116	    return None
   117
   118
   119	def exclusion_table(
   120	    instruments: pd.DataFrame,
   121	    *,
   122	    rules: UniverseRules,
   123	) -> pd.DataFrame:
   124	    """Return one static exclusion row per instrument."""
   125	    rows = []
   126	    for _, row in instruments.iterrows():
   127	        reason = deterministic_exclusion_reason(row, rules=rules)
   128	        rows.append(
   129	            {
   130	                "symbol": row["symbol"],
   131	                "base": row["base"],
   132	                "quote": row["quote"],
   133	                "excluded": reason is not None,
   134	                "reason": reason or "eligible_static",
   135	            }
   136	        )
   137	    return pd.DataFrame(rows)
   138
   139
   140	def eligible_universe_at(
   141	    market_data: pd.DataFrame,
   142	    instruments: pd.DataFrame,
   143	    *,
   144	    decision_cutoff_utc: pd.Timestamp,
   145	    rules: UniverseRules,
   146	) -> pd.DataFrame:
   147	    """Compute point-in-time eligible symbols using only data at or before cutoff."""
   148	    cutoff = pd.Timestamp(decision_cutoff_utc)
   149	    cutoff = cutoff.tz_localize(UTC) if cutoff.tzinfo is None else cutoff.tz_convert(UTC)
   150	    usable = market_data.loc[market_data["bar_end_utc"] <= cutoff].copy()
   151	    if usable.empty:
   152	        return pd.DataFrame(
   153	            columns=[
   154	                "symbol",
   155	                "eligible",
   156	                "reason",
   157	                "valid_history_days",
   158	                "trailing_valid_days",
   159	                "trailing_median_dollar_volume",
   160	                "first_bar_start_utc",
   161	                "last_bar_start_utc",
   162	                "rank",
   163	            ]
   164	        )
   165
   166	    static = exclusion_table(instruments, rules=rules).set_index("symbol")
   167	    trailing_start = cutoff - pd.Timedelta(days=rules.liquidity_lookback_days)
   168	    history_rows = []
   169	    seen_symbols: set[str] = set()
   170	    for symbol, group in usable.groupby("symbol", sort=False):
   171	        seen_symbols.add(str(symbol))
   172	        instrument = static.loc[symbol] if symbol in static.index else None
   173	        if instrument is None:
   174	            static_reason = "missing_instrument_metadata"
   175	        elif bool(instrument["excluded"]):
   176	            static_reason = str(instrument["reason"])
   177	        else:
   178	            static_reason = None
   179
   180	        valid_group = group.dropna(subset=["open", "high", "low", "close", "volume"])
   181	        trailing = valid_group.loc[valid_group["bar_start_utc"] >= trailing_start]
   182	        valid_days = int(valid_group["bar_start_utc"].nunique())
   183	        trailing_days = int(trailing["bar_start_utc"].nunique())
   184	        median_dollar_volume = float(trailing["dollar_volume"].median())
   185	        if not np.isfinite(median_dollar_volume):
   186	            median_dollar_volume = 0.0
   187
   188	        reason = static_reason
   189	        eligible = reason is None
   190	        if eligible and valid_days < rules.min_history_days:
   191	            eligible = False
   192	            reason = "insufficient_history"
   193	        if eligible and trailing_days < int(rules.min_trailing_valid_days or 1):
   194	            eligible = False
   195	            reason = "insufficient_trailing_liquidity_window"
   196	        if eligible and median_dollar_volume <= rules.min_median_dollar_volume:
   197	            eligible = False
   198	            reason = "low_liquidity"
   199
   200	        history_rows.append(
   201	            {
   202	                "symbol": symbol,
   203	                "eligible": eligible,
   204	                "reason": reason or "eligible",
   205	                "valid_history_days": valid_days,
   206	                "trailing_valid_days": trailing_days,
   207	                "trailing_median_dollar_volume": median_dollar_volume,
   208	                "first_bar_start_utc": valid_group["bar_start_utc"].min(),
   209	                "last_bar_start_utc": valid_group["bar_start_utc"].max(),
   210	            }
   211	        )
   212	    for _, row in instruments.loc[~instruments["symbol"].isin(seen_symbols)].iterrows():
   213	        reason = deterministic_exclusion_reason(row, rules=rules) or "no_completed_bars_by_cutoff"
   214	        history_rows.append(
   215	            {
   216	                "symbol": row["symbol"],
   217	                "eligible": False,
   218	                "reason": reason,
   219	                "valid_history_days": 0,
   220	                "trailing_valid_days": 0,
   221	                "trailing_median_dollar_volume": 0.0,
   222	                "first_bar_start_utc": pd.NaT,
   223	                "last_bar_start_utc": pd.NaT,
   224	            }
   225	        )
   226
   227	    result = pd.DataFrame(history_rows)
   228	    result = result.sort_values(
   229	        ["eligible", "trailing_median_dollar_volume", "symbol"],
   230	        ascending=[False, False, True],
   231	        kind="mergesort",
   232	    ).reset_index(drop=True)
   233	    result["rank"] = np.nan
   234	    eligible_mask = result["eligible"]
   235	    result.loc[eligible_mask, "rank"] = np.arange(1, int(eligible_mask.sum()) + 1)
   236	    return result
   237
   238
   239	def selected_large_universe(eligibility: pd.DataFrame, *, rules: UniverseRules) -> pd.DataFrame:
   240	    """Return the full-mode selected/scored universe ranked by trailing liquidity."""
   241	    eligible = eligibility.loc[eligibility["eligible"]].copy()
   242	    eligible = eligible.sort_values(
   243	        ["trailing_median_dollar_volume", "symbol"],
   244	        ascending=[False, True],
   245	        kind="mergesort",
   246	    )
   247	    selected = eligible.head(rules.large_universe_size).reset_index(drop=True)
   248	    selected["selected_for_scoring"] = True
   249	    return selected
