     1	from __future__ import annotations
     2
     3	import json
     4	from pathlib import Path
     5
     6	import pandas as pd
     7	import yaml
     8
     9	from crypto_hedge_fund.config import find_repo_root
    10	from crypto_hedge_fund.experiments.level_5 import run_level_5_validation
    11
    12
    13	def _config(tmp_path: Path) -> Path:
    14	    root = find_repo_root()
    15	    config = yaml.safe_load((root / "configs/default.yaml").read_text(encoding="utf-8"))
    16	    config["paths"]["market_data"] = str(root / config["paths"]["market_data"])
    17	    config["paths"]["instruments"] = str(root / config["paths"]["instruments"])
    18	    config["paths"]["manifest"] = str(root / config["paths"]["manifest"])
    19	    config["paths"]["artifacts"] = str(tmp_path / "artifacts")
    20	    config["final_test"]["lock_path"] = str(tmp_path / "artifacts" / "final_test_lock.json")
    21	    path = tmp_path / "config.yaml"
    22	    path.write_text(yaml.safe_dump(config), encoding="utf-8")
    23	    return path
    24
    25
    26	def test_large_universe_monitoring_health_alerts_and_proof_fields(tmp_path: Path) -> None:
    27	    result = run_level_5_validation(config_path=_config(tmp_path))
    28	    health = pd.read_csv(result.health_summary_path)
    29	    alerts = pd.read_parquet(result.alerts_path)
    30	    proof = json.loads(result.pair_count_proof_path.read_text(encoding="utf-8"))
    31
    32	    assert health["level"].iloc[0] == "level_5"
    33	    assert health["scored_count_max"].iloc[0] >= 100
    34	    assert health["runtime_seconds"].iloc[0] > 0.0
    35	    assert health["peak_rss_mb"].iloc[0] > 0.0
    36	    assert health["peak_rss_unit"].iloc[0] == "MiB"
    37	    assert health["final_test_exposure"].iloc[0] == "NOT_EXPOSED"
    38	    assert {
    39	        "level5_data",
    40	        "level5_methodology",
    41	        "level5_long_term_quality",
    42	        "level5_fail_safe",
    43	    }.issubset(set(alerts["component"]))
    44	    assert "feature_drift_abs_mean" in health.columns
    45	    assert "optimizer_fallback_rate" in health.columns
    46	    assert "fail_safe_scenarios_demonstrated" in health.columns
    47	    assert proof["runtime_seconds"] > 0.0
    48	    assert proof["peak_rss_mb"] > 0.0
    49	    assert proof["peak_rss_unit"] == "MiB"
    50	    assert "full_universe_exclusion_reason_counts" in proof
    51	    assert "filters" in proof
    52	    assert proof["coverage_stats"]["valid_history_days_min"] >= 240
    53	    assert proof["liquidity_stats"]["max_weight_by_liquidity_min"] >= 0.0
