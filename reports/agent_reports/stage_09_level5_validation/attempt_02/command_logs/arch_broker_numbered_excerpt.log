    29	@dataclass(frozen=True)
    30	class BacktestRunResult:
    31	    """In-memory execution artifacts produced by the shared broker."""
    32
    33	    equity: pd.DataFrame
    34	    weights: pd.DataFrame
    35	    orders: pd.DataFrame
    36	    fills: pd.DataFrame
