    38
    39	def _validate_initial_capital(value: float) -> float:
    40	    capital = float(value)
    41	    if not math.isfinite(capital) or capital <= 0:
    42	        msg = "initial_capital must be finite and positive"
    43	        raise ValueError(msg)
    44	    return capital
    45
    46
    47	def _normalize_schedule(target_weights: pd.DataFrame) -> pd.DataFrame:
    48	    if not isinstance(target_weights, pd.DataFrame):
    49	        msg = "target_weights must be a pandas DataFrame"
    50	        raise TypeError(msg)
    51	    if target_weights.empty:
    52	        msg = "target_weights must not be empty"
    53	        raise InvalidWeightsError(msg)
    54	    schedule = target_weights.copy()
    55	    if "bar_start_utc" in schedule.columns:
    56	        schedule["bar_start_utc"] = pd.to_datetime(schedule["bar_start_utc"], utc=True)
    57	        schedule = schedule.set_index("bar_start_utc")
    58	    schedule.index = pd.to_datetime(schedule.index, utc=True)
    59	    if schedule.index.has_duplicates:
    60	        msg = "target_weights contains duplicate decision bars"
    61	        raise InvalidWeightsError(msg)
    62	    schedule.columns = schedule.columns.astype(str)
    63	    schedule = schedule.sort_index(kind="mergesort").astype("float64")
    64	    if not schedule.map(math.isfinite).all().all():
    65	        msg = "target_weights must contain only finite values"
    66	        raise InvalidWeightsError(msg)
    67	    for timestamp, row in schedule.iterrows():
    68	        try:
    69	            validate_target_risky_weights(row, label=f"target_weights[{timestamp.isoformat()}]")
    70	        except ValueError as exc:
    71	            raise InvalidWeightsError(str(exc)) from exc
    72	    return schedule
    73
    74
    75	class SimulatedBroker:
    76	    """Panel-native long-only broker that fills approved weights at next opens."""
    77
    78	    def __init__(
    79	        self,
    80	        market_data: PanelMarketData,
    81	        *,
    82	        initial_capital: float = 1_000_000.0,
    83	        cost_assumptions: CostAssumptions | None = None,
    84	    ) -> None:
    85	        self.market_data = market_data
    86	        self.initial_capital = _validate_initial_capital(initial_capital)
    87	        self.cost_assumptions = cost_assumptions or CostAssumptions()
    88	        self.cost_model = WeightDeltaCostModel(self.cost_assumptions)
    89
    90	    def run(
    91	        self,
    92	        target_weights: pd.DataFrame,
    93	        *,
    94	        end_time: datetime | pd.Timestamp | None = None,
    95	        run_label: str = "stage3_kernel",
    96	    ) -> BacktestRunResult:
    97	        """Execute a target-weight schedule using completed-bar, next-open timing.
    98
    99	        The schedule index identifies the completed signal bar start. For a daily
   100	        bar, the broker uses :func:`build_daily_research_clock`, so no fill can
   101	        occur at the signal bar close or any earlier open.
   102	        """
   103	        schedule = _normalize_schedule(target_weights)
   104	        execution_schedule: dict[pd.Timestamp, pd.Series] = {}
   105	        for bar_start, row in schedule.iterrows():
   106	            clock = build_daily_research_clock(bar_start.to_pydatetime())
   107	            execution_schedule[pd.Timestamp(clock.execution_time)] = row
   108
   109	        start_time = min(schedule.index.min(), min(execution_schedule))
   110	        final_time = (
   111	            pd.Timestamp(end_time).tz_convert("UTC")
   112	            if end_time is not None
   113	            else max(execution_schedule)
   114	        )
   115	        all_open_times = self.market_data.open_times
   116	        missing_execution_times = sorted(set(execution_schedule).difference(set(all_open_times)))
   117	        if missing_execution_times:
   118	            first_missing = missing_execution_times[0]
   119	            msg = f"missing execution open at {first_missing.isoformat()}"
   120	            raise MissingPriceError(msg)
   121	        open_times = all_open_times[(all_open_times >= start_time) & (all_open_times <= final_time)]
   122	        if open_times.empty:
   123	            msg = "market data contains no opens covering the target-weight schedule"
   124	            raise MissingPriceError(msg)
   125
   126	        holdings = pd.Series(dtype="float64")
   127	        cash = self.initial_capital
   128	        equity_rows: list[dict[str, object]] = []
   129	        weight_rows: list[dict[str, object]] = []
   130	        order_rows: list[dict[str, object]] = []
   131	        fill_rows: list[dict[str, object]] = []
   132	        order_number = 0
   133
   134	        for timestamp in open_times:
   135	            active_symbols = sorted(
   136	                set(holdings[holdings.abs() > 1e-15].index)
   137	                | set(execution_schedule.get(timestamp, pd.Series(dtype="float64")).index)
   138	            )
   139	            prices = self.market_data.open_prices(timestamp, active_symbols, reason="valuation")
   140	            nav_before = self._nav(cash, holdings, prices)
   141	            turnover = 0.0
   142	            fees = 0.0
   143	            slippage = 0.0
   144	            trade_count = 0
   145
   146	            if timestamp in execution_schedule:
   147	                target = execution_schedule[timestamp].copy()
   148	                symbols = target.index.union(holdings.index)
   149	                target = target.reindex(symbols, fill_value=0.0)
   150	                holdings = holdings.reindex(symbols, fill_value=0.0)
   151	                prices = self.market_data.open_prices(timestamp, symbols, reason="execution")
   152	                current_values = holdings * prices
   153	                nav_before = self._nav(cash, holdings, prices)
   154	                pretrade_weights = current_values / nav_before
   155	                costs = self.cost_model.estimate_from_weight_deltas(
   156	                    target,
   157	                    pretrade_weights,
   158	                    nav_before,
   159	                )
   160	                turnover = costs.reporting_turnover
   161	                (
   162	                    cash,
   163	                    holdings,
   164	                    new_order_rows,
   165	                    new_fill_rows,
   166	                    trade_count,
   167	                    fees,
   168	                    slippage,
   169	                    order_number,
   170	                ) = self._execute_rebalance(
   171	                    cash=cash,
   172	                    holdings=holdings,
   173	                    prices=prices,
   174	                    target=target,
   175	                    nav=nav_before,
   176	                    timestamp=timestamp,
   177	                    order_number=order_number,
   178	                    run_label=run_label,
   179	                )
   180	                order_rows.extend(new_order_rows)
   181	                fill_rows.extend(new_fill_rows)
   182
   183	            prices = self.market_data.open_prices(timestamp, holdings.index, reason="valuation")
   184	            nav_after = self._nav(cash, holdings, prices)
   185	            risky_value = float((holdings * prices).sum())
   186	            exposure = risky_value / nav_after if nav_after > 0 else 0.0
   187	            equity_rows.append(
   188	                {
   189	                    "timestamp": timestamp,
   190	                    "cash": cash,
   191	                    "risky_value": risky_value,
   192	                    "nav": nav_after,
   193	                    "turnover": turnover,
   194	                    "fees": fees,
   195	                    "slippage": slippage,
   196	                    "total_cost": fees + slippage,
   197	                    "exposure": exposure,
   198	                    "trade_count": trade_count,
   199	                    "run_label": run_label,
   200	                }
   201	            )
   202	            weight_row: dict[str, object] = {
   203	                "timestamp": timestamp,
   204	                "cash_weight": cash / nav_after,
   205	                "run_label": run_label,
   206	            }
   207	            for symbol in holdings.index:
   208	                weight_row[symbol] = (holdings[symbol] * prices[symbol]) / nav_after
   209	            weight_rows.append(weight_row)
   210
   211	        return BacktestRunResult(
   212	            equity=pd.DataFrame(equity_rows),
   213	            weights=pd.DataFrame(weight_rows).fillna(0.0),
   214	            orders=pd.DataFrame(order_rows, columns=self._order_columns()),
   215	            fills=pd.DataFrame(fill_rows, columns=self._fill_columns()),
   216	        )
   217
   218	    def _execute_rebalance(
   219	        self,
   220	        *,
   221	        cash: float,
   222	        holdings: pd.Series,
   223	        prices: pd.Series,
   224	        target: pd.Series,
   225	        nav: float,
   226	        timestamp: pd.Timestamp,
   227	        order_number: int,
   228	        run_label: str,
   229	    ) -> tuple[
   230	        float,
   231	        pd.Series,
   232	        list[dict[str, object]],
   233	        list[dict[str, object]],
   234	        int,
   235	        float,
   236	        float,
   237	        int,
   238	    ]:
   239	        current_values = holdings * prices
   240	        target_values = target * nav
   241	        delta_values = target_values - current_values
   242	        rows: list[dict[str, object]] = []
   243	        fills: list[dict[str, object]] = []
   244	        fees = 0.0
   245	        slippage = 0.0
   246	        trade_count = 0
   247
   248	        for symbol, delta in delta_values[delta_values < -1e-10].items():
   249	            notional = float(-delta)
   250	            order_number += 1
   251	            fee = notional * self.cost_assumptions.fee_rate
   252	            slip = notional * self.cost_assumptions.slippage_rate
   253	            quantity = notional / float(prices[symbol])
   254	            holdings[symbol] -= quantity
   255	            cash += notional - fee - slip
   256	            fees += fee
   257	            slippage += slip
   258	            trade_count += 1
   259	            order_id = f"{run_label}-{order_number:06d}"
   260	            rows.append(
