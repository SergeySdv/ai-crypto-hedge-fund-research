    23	def _dedupe(codes: list[ReasonCode]) -> tuple[ReasonCode, ...]:
    24	    seen: set[ReasonCode] = set()
    25	    ordered: list[ReasonCode] = []
    26	    for code in codes:
    27	        if code not in seen:
    28	            ordered.append(code)
    29	            seen.add(code)
    30	    return tuple(ordered) or (ReasonCode.OK,)
    31
