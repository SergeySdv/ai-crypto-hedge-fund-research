    33	class RiskActionResolutionError(ValueError):
    34	    """Raised when a risk action cannot produce executable target weights."""
    35
    36	    def __init__(self, message: str, reason_codes: tuple[ReasonCode, ...]) -> None:
    37	        super().__init__(message)
    38	        self.reason_codes = _dedupe(list(reason_codes))
    39
    40
    41	def resolve_risk_approval_targets(
    42	    approval: RiskApproval,
    43	    context: AgentContext,
    44	) -> ExecutableTargetWeights:
    45	    """Resolve post-risk action semantics before any broker/order integration.
    46
    47	    The action field is authoritative. Safe fallbacks with ``approved=False`` must
    48	    still produce explicit target weights instead of being skipped by callers.
    49	    """
    50
    51	    try:
    52	        action = RiskAction(approval.action)
    53	    except ValueError as exc:
    54	        raise RiskActionResolutionError(
    55	            f"unsupported risk action: {approval.action}",
    56	            (*approval.reason_codes, ReasonCode.INVALID_DATA),
    57	        ) from exc
    58
    59	    if action in {RiskAction.APPROVE, RiskAction.CAP}:
    60	        return ExecutableTargetWeights(
    61	            risky_weights=approval.approved_weights,
    62	            cash_weight=approval.cash_weight,
    63	            action=action.value,
    64	            reason_codes=approval.reason_codes,
    65	            metadata={"approved": approval.approved, **dict(approval.metadata)},
    66	        )
    67	    if action is RiskAction.CASH:
    68	        return ExecutableTargetWeights(
    69	            risky_weights={},
    70	            cash_weight=1.0,
    71	            action=action.value,
    72	            reason_codes=approval.reason_codes,
    73	            metadata={"approved": approval.approved, **dict(approval.metadata)},
    74	        )
    75	    if action is RiskAction.PRIOR_WEIGHTS:
    76	        risky_weights, cash_weight = _current_context_targets(context)
    77	        return ExecutableTargetWeights(
    78	            risky_weights=risky_weights,
    79	            cash_weight=cash_weight,
    80	            action=action.value,
    81	            reason_codes=approval.reason_codes,
    82	            metadata={"approved": approval.approved, **dict(approval.metadata)},
    83	        )
    84
    85	    raise RiskActionResolutionError(
    86	        f"risk action {action.value!r} is not executable",
    87	        (*approval.reason_codes, ReasonCode.INVALID_DATA),
    88	    )
    89
    90
    91	def _current_context_targets(context: AgentContext) -> tuple[dict[str, float], float]:
    92	    risky_weights = {
    93	        str(symbol): _finite_non_negative_weight(symbol, weight)
    94	        for symbol, weight in context.current_weights.items()
    95	        if str(symbol).lower() != "cash"
    96	    }
    97	    risky_sum = sum(risky_weights.values())
    98	    if risky_sum > 1.0 + 1e-8:
    99	        raise RiskActionResolutionError(
   100	            f"current risky weights sum above 1.0: {risky_sum}",
   101	            (ReasonCode.WEIGHT_RECONCILIATION_FAILURE,),
   102	        )
   103	    return risky_weights, max(0.0, 1.0 - risky_sum)
   104
   105
   106	def _finite_non_negative_weight(symbol: object, weight: object) -> float:
   107	    value = float(weight)
   108	    if not math.isfinite(value) or value < 0:
   109	        raise RiskActionResolutionError(
   110	            f"current weight for {symbol} must be finite and non-negative",
   111	            (ReasonCode.WEIGHT_RECONCILIATION_FAILURE,),
   112	        )
   113	    return value
   114
   115
   116	def _cash_approval(reason: ReasonCode, metadata: dict[str, Any] | None = None) -> RiskApproval:
   117	    return RiskApproval(
   118	        approved=False,
   119	        approved_weights={},
   120	        cash_weight=1.0,
   121	        action=RiskAction.CASH.value,
   122	        reason_codes=(reason,),
   123	        metadata=metadata or {},
   124	    )
   125
   126
   127	def _prior_weights_approval(context: AgentContext, reason: ReasonCode) -> RiskApproval:
   128	    try:
   129	        risky, cash_weight = _current_context_targets(context)
   130	    except RiskActionResolutionError:
   131	        return _cash_approval(ReasonCode.WEIGHT_RECONCILIATION_FAILURE)
   132	    return RiskApproval(
   133	        approved=False,
   134	        approved_weights=risky,
   135	        cash_weight=cash_weight,
   136	        action=RiskAction.PRIOR_WEIGHTS.value,
   137	        reason_codes=(reason,),
   138	    )
