  1241	def _peak_rss_mb() -> float:
  1242	    usage = resource.getrusage(resource.RUSAGE_SELF).ru_maxrss
  1243	    if sys.platform == "darwin":
  1244	        return float(usage / (1024.0 * 1024.0))
  1245	    return float(usage / 1024.0)
