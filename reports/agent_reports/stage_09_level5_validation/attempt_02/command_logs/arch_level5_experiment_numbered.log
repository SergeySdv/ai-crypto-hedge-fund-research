   442	def _allocator(config: dict[str, Any]) -> InverseVolatilityAllocator:
   443	    name = str(_level5_config(config).get("allocator", "inverse_volatility"))
   444	    if name != "inverse_volatility":
   445	        msg = f"unsupported Level 5 allocator: {name}"
   446	        raise ValueError(msg)
   447	    return InverseVolatilityAllocator(min_periods=20)
   448
