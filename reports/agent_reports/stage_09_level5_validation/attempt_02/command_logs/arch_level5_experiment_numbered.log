   702	def _skipped_reason(rebalance: Any) -> str:
   703	    if ReasonCode.TURNOVER_LIMIT in rebalance.reason_codes:
   704	        return "turnover_or_cost_control"
   705	    if "minimum_trade_not_met" in rebalance.trigger_codes:
   706	        return "minimum_trade_not_met"
   707	    if "no_trigger" in rebalance.trigger_codes:
   708	        return "no_rebalance_trigger"
   709	    return "held_prior_weights"
   710
