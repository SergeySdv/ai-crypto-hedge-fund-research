   518	def _signals_from_scores(
   519	    score_frame: pd.DataFrame,
   520	    clock: Any,
   521	) -> tuple[tuple[AgentSignal, ...], tuple[AggregatedSignal, ...]]:
   522	    signals: list[AgentSignal] = []
   523	    aggregated: list[AggregatedSignal] = []
   524	    for row in score_frame.itertuples(index=False):
   525	        reason = ReasonCode(str(row.reason_codes))
   526	        signal = AgentSignal(
   527	            symbol=str(row.symbol),
   528	            agent="level5_cross_sectional_ranker",
   529	            score=float(row.score),
   530	            confidence=float(row.confidence),
   531	            horizon_open_days=int(row.horizon_open_days),
   532	            fit_cutoff=clock.feature_cutoff,
   533	            feature_cutoff=clock.feature_cutoff,
   534	            reason_codes=(reason,),
   535	            metadata={
   536	                "selected_top_k": bool(row.selected_top_k),
   537	                "data_quality_flag": str(row.data_quality_flag),
   538	                "trailing_median_dollar_volume": float(row.trailing_median_dollar_volume),
   539	            },
   540	        )
   541	        signals.append(signal)
   542	        aggregated.append(
   543	            AggregatedSignal(
   544	                symbol=str(row.symbol),
   545	                score=float(row.score),
   546	                confidence=float(row.confidence),
   547	                contributions={"level5_cross_sectional_ranker": float(row.score)},
   548	                disagreement=0.0,
   549	                reason_codes=(reason,),
   550	            )
   551	        )
   552	    return tuple(signals), tuple(aggregated)
