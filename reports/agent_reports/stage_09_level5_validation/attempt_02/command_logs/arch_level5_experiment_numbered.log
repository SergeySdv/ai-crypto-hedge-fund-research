   555	def _snapshot_with_capacity(
   556	    frame: pd.DataFrame,
   557	    symbols: tuple[str, ...],
   558	    decision_bar: pd.Timestamp,
   559	    config: dict[str, Any],
   560	) -> pd.DataFrame:
   561	    snapshot = frame.loc[
   562	        (frame["bar_start_utc"] == decision_bar) & (frame["symbol"].isin(symbols))
   563	    ].copy()
   564	    snapshot["feature_cutoff"] = snapshot["bar_end_utc"]
   565	    capacity = _capacity_weights(frame, symbols, decision_bar, config)
   566	    snapshot["max_weight_by_liquidity"] = snapshot["symbol"].map(capacity).fillna(0.0)
   567	    return snapshot
