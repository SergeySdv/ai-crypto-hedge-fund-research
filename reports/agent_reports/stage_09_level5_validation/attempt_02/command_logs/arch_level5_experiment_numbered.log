  1207	def _write_json_artifact(
  1208	    path: Path,
  1209	    payload: dict[str, Any],
  1210	    provenance: ArtifactProvenance,
  1211	) -> Path:
  1212	    path.parent.mkdir(parents=True, exist_ok=True)
  1213	    with path.open("w", encoding="utf-8") as handle:
  1214	        json.dump(_json_safe(payload), handle, indent=2, sort_keys=True)
  1215	        handle.write("\n")
  1216	    _write_metadata_sidecar(path, provenance)
  1217	    return path
  1218
  1219
  1220	def _write_metadata_sidecar(path: Path, provenance: ArtifactProvenance) -> None:
  1221	    sidecar = path.with_suffix(f"{path.suffix}.metadata.json")
  1222	    with sidecar.open("w", encoding="utf-8") as handle:
  1223	        json.dump(provenance.metadata(), handle, indent=2, sort_keys=True)
  1224	        handle.write("\n")
  1225
  1226
  1227	def _json_safe(value: Any) -> Any:
  1228	    if isinstance(value, dict):
  1229	        return {str(key): _json_safe(item) for key, item in value.items()}
  1230	    if isinstance(value, list | tuple):
  1231	        return [_json_safe(item) for item in value]
  1232	    if isinstance(value, pd.Timestamp):
  1233	        return value.isoformat()
  1234	    if hasattr(value, "isoformat"):
  1235	        return value.isoformat()
  1236	    if hasattr(value, "item"):
  1237	        return value.item()
  1238	    return value
  1239
