   570	def _capacity_weights(
   571	    frame: pd.DataFrame,
   572	    symbols: tuple[str, ...],
   573	    decision_bar: pd.Timestamp,
   574	    config: dict[str, Any],
   575	) -> pd.Series:
   576	    lookback = int(config["liquidity"]["adv_lookback_days"])
   577	    start = decision_bar - pd.Timedelta(days=lookback - 1)
   578	    liquidity = frame.loc[
   579	        (frame["bar_start_utc"] >= start)
   580	        & (frame["bar_start_utc"] <= decision_bar)
   581	        & (frame["symbol"].isin(symbols)),
   582	        ["symbol", "dollar_volume"],
   583	    ]
   584	    adv = liquidity.groupby("symbol")["dollar_volume"].mean()
   585	    aum = float(config["liquidity"]["assumed_aum_usd"])
   586	    max_participation = float(config["liquidity"]["max_participation"])
   587	    return (adv * max_participation / aum).clip(lower=0.0)
   588
   589
   590	def _current_weights(
   591	    frame: pd.DataFrame,
   592	    *,
   593	    symbols: tuple[str, ...],
   594	    previous_target: pd.Series,
   595	    previous_execution_time: pd.Timestamp | None,
   596	    decision_bar: pd.Timestamp,
   597	) -> pd.Series:
   598	    if previous_target.empty or float(previous_target.sum()) <= 0:
   599	        return pd.Series(dict.fromkeys(symbols, 0.0), dtype="float64")
   600	    held = tuple(str(symbol) for symbol, weight in previous_target.items() if float(weight) > 1e-12)
   601	    if not held:
   602	        return pd.Series(dict.fromkeys(symbols, 0.0), dtype="float64")
   603	    drifted = _drifted_current_weights(
   604	        frame,
   605	        symbols=held,
   606	        previous_target=previous_target.reindex(held, fill_value=0.0),
   607	        previous_execution_time=previous_execution_time,
   608	        decision_bar=decision_bar,
   609	    )
   610	    return drifted.reindex(symbols, fill_value=0.0).astype("float64")
   611
