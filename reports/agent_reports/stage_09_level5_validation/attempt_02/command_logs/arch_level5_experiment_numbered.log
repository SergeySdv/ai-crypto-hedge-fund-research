   613	def _proposal_with_metadata(
   614	    proposal: PortfolioProposal,
   615	    *,
   616	    score_series: pd.Series,
   617	    risk_trigger_active: bool,
   618	    realized_volatility: float,
   619	    score_frame: pd.DataFrame,
   620	    config: dict[str, Any],
   621	) -> PortfolioProposal:
   622	    weights = pd.Series(proposal.target_weights, dtype="float64")
   623	    expected_score = float((weights * score_series.reindex(weights.index).fillna(0.0)).sum())
   624	    cap = float(_level5_config(config)["max_weight"])
   625	    capacity_breaches = [
   626	        str(symbol)
   627	        for symbol, weight in weights.items()
   628	        if weight > cap + 1e-12
   629	        or weight
   630	        > float(score_frame.set_index("symbol")["max_weight_by_liquidity"].get(symbol, 0.0)) + 1e-12
   631	    ]
   632	    metadata = {
   633	        **dict(proposal.metadata),
   634	        "expected_gross_benefit": max(0.0, expected_score)
   635	        * float(_level5_config(config)["expected_benefit_scale"]),
   636	        "weighted_signal_score": expected_score,
   637	        "risk_trigger_active": risk_trigger_active,
   638	        "realized_volatility": realized_volatility,
   639	        "capacity_breach_symbols": capacity_breaches,
   640	        "capacity_breach": bool(capacity_breaches),
   641	    }
   642	    return PortfolioProposal(
   643	        decision_time=proposal.decision_time,
   644	        target_weights=dict(proposal.target_weights),
   645	        cash_weight=proposal.cash_weight,
   646	        optimizer_status=proposal.optimizer_status,
   647	        expected_turnover=proposal.expected_turnover,
   648	        objective_value=proposal.objective_value,
   649	        reason_codes=proposal.reason_codes,
   650	        metadata=metadata,
   651	    )
   652
