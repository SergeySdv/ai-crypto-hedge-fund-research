   450	def _rebalance_policy(config: dict[str, Any]) -> DynamicRebalancePolicy:
   451	    level_config = _level5_config(config)
   452	    cost_rate = (
   453	        float(config["backtest"]["fee_bps_one_way"])
   454	        + float(config["backtest"]["slippage_bps_one_way"])
   455	    ) / 10_000.0
   456	    return DynamicRebalancePolicy(
   457	        name="level5_large_universe_dynamic",
   458	        calendar=str(level_config["rebalance_calendar"]),
   459	        drift_threshold_abs=float(config["rebalance"]["drift_threshold_abs"]),
   460	        score_change_threshold=float(level_config["score_change_threshold"]),
   461	        risk_trigger=True,
   462	        min_trade_abs=float(level_config["min_trade_abs"]),
   463	        turnover_cap=float(level_config["turnover_cap"]),
   464	        one_way_cost_rate=cost_rate,
   465	    )
   466
   467
   468	def _pre_risk(config: dict[str, Any]) -> PreAllocationRiskPolicy:
   469	    level_config = _level5_config(config)
   470	    return PreAllocationRiskPolicy(
   471	        max_gross_exposure=float(config["portfolio"]["max_gross_exposure"]),
   472	        max_per_asset_weight=float(level_config["max_weight"]),
   473	        cost_buffer_weight=float(level_config["cost_buffer_weight"]),
   474	        min_dollar_volume=float(level_config["min_dollar_volume"]),
   475	        max_stale_data_days=0,
   476	        max_model_age_days=1,
   477	        max_agent_disagreement=float(config["risk"]["max_agent_disagreement"]),
   478	        volatility_target=None,
   479	        turnover_cap=float(level_config["turnover_cap"]),
   480	    )
   481
   482
   483	def _post_risk(config: dict[str, Any]) -> PostAllocationRiskPolicy:
   484	    return PostAllocationRiskPolicy(
   485	        max_drawdown_stop=float(config["risk"]["max_drawdown_stop"]),
   486	        high_volatility_threshold=float(config["risk"]["high_volatility_threshold_annual"]),
   487	        min_cash_buffer=float(_level5_config(config)["min_cash_buffer"]),
   488	        annualization_periods=int(config["backtest"]["annualization_periods"]),
   489	    )
   490
   491
   492	def _mark_top_k_and_capacity(
   493	    score_frame: pd.DataFrame,
   494	    frame: pd.DataFrame,
   495	    decision_bar: pd.Timestamp,
   496	    config: dict[str, Any],
   497	) -> pd.DataFrame:
   498	    output = score_frame.copy()
   499	    top_k = int(_level5_config(config).get("top_k", config["portfolio"]["large_top_k"]))
   500	    ordered = output.sort_values(["score", "confidence", "symbol"], ascending=[False, False, True])
   501	    selected = set(ordered.head(top_k)["symbol"].astype(str))
   502	    output["selected_top_k"] = output["symbol"].astype(str).isin(selected)
   503	    capacity = _capacity_weights(frame, tuple(output["symbol"].astype(str)), decision_bar, config)
   504	    output["max_weight_by_liquidity"] = output["symbol"].map(capacity).fillna(0.0)
   505	    output["configured_max_weight"] = float(_level5_config(config)["max_weight"])
   506	    output["capacity_notional_usd"] = output["max_weight_by_liquidity"] * float(
   507	        config["liquidity"]["assumed_aum_usd"]
   508	    )
   509	    return output
   510
   511
   512	def _allocation_scores(score_frame: pd.DataFrame, config: dict[str, Any]) -> pd.Series:
   513	    scores = score_frame.set_index("symbol")["score"].astype("float64")
   514	    scores.loc[~score_frame.set_index("symbol")["selected_top_k"]] = 0.0
   515	    return scores * score_frame.set_index("symbol")["confidence"].astype("float64")
