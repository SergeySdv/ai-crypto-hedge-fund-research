   414	def _universe_rules(config: dict[str, Any]) -> UniverseRules:
   415	    base = UniverseRules.from_config(config)
   416	    level_config = _level5_config(config)
   417	    return replace(
   418	        base,
   419	        min_history_days=int(level_config.get("universe_min_history_days", base.min_history_days)),
   420	        preferred_history_days=int(
   421	            level_config.get("universe_preferred_history_days", base.preferred_history_days)
   422	        ),
   423	        min_trailing_valid_days=int(
   424	            level_config.get("universe_min_trailing_valid_days", base.min_trailing_valid_days or 1)
   425	        ),
   426	        min_median_dollar_volume=float(level_config.get("min_dollar_volume", 0.0)),
   427	    )
   428
   429
   430	def _scoring_config(config: dict[str, Any]) -> Level5ScoringConfig:
   431	    item = _level5_config(config)
   432	    return Level5ScoringConfig(
   433	        scoring_lookback_days=int(item["scoring_lookback_days"]),
   434	        momentum_short_days=int(item["momentum_short_days"]),
   435	        momentum_long_days=int(item["momentum_long_days"]),
   436	        volatility_days=int(item["volatility_days"]),
   437	        drawdown_days=int(item["drawdown_days"]),
   438	        horizon_open_days=int(item["horizon_open_days"]),
   439	    )
   440
