   228	def build_level_5_target_schedule(
   229	    *,
   230	    frame: pd.DataFrame,
   231	    instruments: pd.DataFrame,
   232	    config: dict[str, Any],
   233	    decision_start: pd.Timestamp,
   234	    decision_end: pd.Timestamp,
   235	) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, list[DecisionTrace]]:
   236	    """Build dynamic large-universe targets from point-in-time scores."""
   237
   238	    normalized = _normalize_market_frame(frame, end=decision_end + pd.Timedelta(days=1))
   239	    rules = _universe_rules(config)
   240	    scoring_config = _scoring_config(config)
   241	    policy = _rebalance_policy(config)
   242	    allocator = _allocator(config)
   243	    minimum_full_scored = int(_level5_config(config)["min_scored_pairs_full"])
   244	    mode = str(config.get("project", {}).get("mode", "full"))
   245	    decision_bars = pd.date_range(decision_start, decision_end, freq="D", tz="UTC")
   246
   247	    all_symbols: set[str] = set()
   248	    last_approved = pd.Series(dtype="float64")
   249	    last_execution_time: pd.Timestamp | None = None
   250	    previous_rebalance_time: pd.Timestamp | None = None
   251	    previous_scores: pd.Series | None = None
   252	    rows: list[pd.Series] = []
   253	    score_frames: list[pd.DataFrame] = []
   254	    log_rows: list[dict[str, object]] = []
   255	    traces: list[DecisionTrace] = []
   256
   257	    for decision_bar in decision_bars:
   258	        clock = build_daily_research_clock(decision_bar.to_pydatetime())
   259	        feature_cutoff = pd.Timestamp(clock.feature_cutoff)
   260	        eligibility = eligible_universe_at(
   261	            normalized,
   262	            instruments,
   263	            decision_cutoff_utc=feature_cutoff,
   264	            rules=rules,
   265	        )
   266	        universe = selected_large_universe(eligibility, rules=rules)
   267	        if mode == "full" and len(universe) < minimum_full_scored:
   268	            msg = (
   269	                f"Level 5 full mode scored {len(universe)} pairs at "
   270	                f"{feature_cutoff.isoformat()}, below required {minimum_full_scored}"
   271	            )
   272	            raise ValueError(msg)
   273
   274	        score_frame = build_level5_score_frame(
   275	            normalized,
   276	            universe,
   277	            decision_bar=decision_bar,
   278	            feature_cutoff=feature_cutoff,
   279	            config=scoring_config,
   280	        )
   281	        score_frame = _mark_top_k_and_capacity(score_frame, normalized, decision_bar, config)
   282	        symbols = tuple(score_frame["symbol"].astype(str).tolist())
   283	        all_symbols.update(symbols)
   284	        current_weights = _current_weights(
   285	            normalized,
   286	            symbols=symbols,
   287	            previous_target=last_approved,
   288	            previous_execution_time=last_execution_time,
   289	            decision_bar=decision_bar,
   290	        )
   291	        score_series = _allocation_scores(score_frame, config)
   292	        returns = _historical_open_returns(
   293	            normalized,
   294	            symbols=symbols,
   295	            start=decision_bar
   296	            - pd.Timedelta(days=int(_level5_config(config)["scoring_lookback_days"])),
   297	            through=decision_bar,
   298	        )
   299	        signals, aggregated = _signals_from_scores(score_frame, clock)
   300	        score_change = (
   301	            1.0
   302	            if previous_scores is None
   303	            else float((score_series - previous_scores.reindex(symbols).fillna(0.0)).abs().max())
   304	        )
   305	        realized_volatility = _realized_volatility(returns, config)
   306	        risk_trigger_active = realized_volatility >= float(
   307	            _level5_config(config)["risk_rebalance_volatility_threshold_annual"]
   308	        )
   309	        context = AgentContext(
   310	            clock=clock,
   311	            symbols=symbols,
   312	            model_fit_cutoff=pd.Timestamp(clock.feature_cutoff).to_pydatetime(),
   313	            portfolio_nav=float(config["backtest"]["initial_capital_usd"]),
   314	            current_weights=current_weights.to_dict(),
   315	            health_state={
   316	                "aggregate_score_change": score_change,
   317	                "risk_trigger_active": risk_trigger_active,
   318	                "realized_volatility": realized_volatility if risk_trigger_active else 0.0,
   319	                "kill_switch": bool(_level5_config(config).get("kill_switch", False)),
   320	            },
   321	            metadata={
   322	                "level": LEVEL_NAME,
   323	                "split": "validation",
   324	                "previous_rebalance_time": previous_rebalance_time,
   325	                "eligible_count": len(universe),
   326	                "scored_count": int(score_frame["scored"].sum()),
   327	            },
   328	        )
   329	        snapshot = _snapshot_with_capacity(normalized, symbols, decision_bar, config)
   330	        constraints = _pre_risk(config).constraints(list(aggregated), context, snapshot)
   331	        proposal = allocator.allocate(score_series, returns, constraints, current_weights)
   332	        proposal = _proposal_with_metadata(
   333	            proposal,
   334	            score_series=score_series,
   335	            risk_trigger_active=risk_trigger_active,
   336	            realized_volatility=realized_volatility,
   337	            score_frame=score_frame,
   338	            config=config,
   339	        )
   340	        rebalance = policy.decide(proposal, current_weights, context)
   341	        approval = _post_risk(config).approve(proposal, rebalance, constraints, context, returns)
   342	        executable = resolve_risk_approval_targets(approval, context)
   343	        approved = pd.Series(
   344	            {symbol: float(executable.risky_weights.get(symbol, 0.0)) for symbol in all_symbols},
   345	            dtype="float64",
   346	        )
   347	        should_submit = executable.action in {"approve", "cap", "cash"} and (
   348	            rebalance.should_rebalance or executable.action == "cash"
   349	        )
   350	        if should_submit:
   351	            rows.append(approved.rename(decision_bar))
   352	            last_approved = approved
   353	            last_execution_time = pd.Timestamp(clock.execution_time)
   354	            previous_rebalance_time = pd.Timestamp(clock.decision_time)
   355	        score_frame["blocked_by_pre_risk"] = score_frame["symbol"].isin(constraints.blocked_symbols)
   356	        score_frame["per_asset_cap"] = score_frame["symbol"].map(constraints.per_asset_caps)
   357	        score_frame["approved_weight"] = score_frame["symbol"].map(approved).fillna(0.0)
   358	        score_frames.append(score_frame)
   359	        log_rows.append(
   360	            _rebalance_log_row(
   361	                decision_bar=decision_bar,
   362	                execution_time=pd.Timestamp(clock.execution_time),
   363	                score_frame=score_frame,
   364	                current_weights=current_weights,
   365	                proposal=proposal,
   366	                rebalance=rebalance,
   367	                approval=approval,
   368	                approved=approved,
   369	                submitted=should_submit,
   370	                score_change=score_change,
   371	                realized_volatility=realized_volatility,
   372	                risk_trigger_active=risk_trigger_active,
   373	                eligibility=eligibility,
   374	            )
   375	        )
   376	        traces.append(
   377	            DecisionTrace(
   378	                clock=clock,
   379	                signals=signals,
   380	                aggregated_signals=aggregated,
   381	                constraints=constraints,
   382	                proposal=proposal,
   383	                approval=approval,
   384	                metadata={
   385	                    "level": LEVEL_NAME,
   386	                    "split": "validation",
   387	                    "execution_time": pd.Timestamp(clock.execution_time).isoformat(),
   388	                    "rebalance_decision": {
   389	                        "should_rebalance": rebalance.should_rebalance,
   390	                        "trigger_codes": list(rebalance.trigger_codes),
   391	                        "reason_codes": [code.value for code in rebalance.reason_codes],
   392	                    },
   393	                    "resolved_action": executable.action,
   394	                },
   395	            )
   396	        )
   397	        previous_scores = score_series.copy()
   398
   399	    if not rows:
   400	        msg = "Level 5 produced no executable schedule"
   401	        raise ValueError(msg)
   402	    schedule = pd.DataFrame(rows).sort_index(kind="mergesort").fillna(0.0)
   403	    schedule.index = pd.DatetimeIndex(schedule.index, tz="UTC")
   404	    return schedule, pd.concat(score_frames, ignore_index=True), pd.DataFrame(log_rows), traces
   405
