   750	def _enrich_equity(
   751	    net_result: BacktestRunResult,
   752	    gross_result: BacktestRunResult,
   753	    benchmark_nav: pd.Series,
   754	) -> BacktestRunResult:
   755	    equity = net_result.equity.copy()
   756	    timestamps = pd.to_datetime(equity["timestamp"], utc=True)
   757	    gross = gross_result.equity.set_index("timestamp")["nav"].rename("gross_nav")
   758	    equity = equity.set_index(timestamps)
   759	    equity["gross_nav"] = gross.reindex(equity.index).to_numpy()
   760	    equity["benchmark_nav"] = benchmark_nav.reindex(equity.index).ffill().bfill().to_numpy()
   761	    equity = equity.reset_index(drop=True)
   762	    return BacktestRunResult(
   763	        equity=equity,
   764	        weights=net_result.weights,
   765	        orders=net_result.orders,
   766	        fills=net_result.fills,
   767	    )
