   712	def _realized_volatility(returns: pd.DataFrame, config: dict[str, Any]) -> float:
   713	    if returns.empty:
   714	        return 0.0
   715	    recent = returns.tail(20).dropna(how="all")
   716	    if recent.empty:
   717	        return 0.0
   718	    equal = recent.mean(axis=1)
   719	    value = float(equal.std(ddof=0) * math.sqrt(int(config["backtest"]["annualization_periods"])))
   720	    return value if math.isfinite(value) else 0.0
   721
   722
   723	def _benchmark_nav(
   724	    frame: pd.DataFrame,
   725	    *,
   726	    start: pd.Timestamp,
   727	    end: pd.Timestamp,
   728	    config: dict[str, Any],
   729	) -> pd.Series:
   730	    initial_capital = float(config["backtest"]["initial_capital_usd"])
   731	    symbol = str(config["level_1"]["symbol"]) if "level_1" in config else "BTC/USDT"
   732	    rows = frame.loc[
   733	        (frame["symbol"] == symbol)
   734	        & (frame["bar_start_utc"] >= start)
   735	        & (frame["bar_start_utc"] <= end),
   736	        ["bar_start_utc", "open"],
   737	    ].sort_values("bar_start_utc", kind="mergesort")
   738	    if rows.empty:
   739	        first_symbol = str(frame["symbol"].iloc[0])
   740	        rows = frame.loc[
   741	            (frame["symbol"] == first_symbol)
   742	            & (frame["bar_start_utc"] >= start)
   743	            & (frame["bar_start_utc"] <= end),
   744	            ["bar_start_utc", "open"],
   745	        ].sort_values("bar_start_utc", kind="mergesort")
   746	    nav = rows.set_index("bar_start_utc")["open"].astype("float64")
   747	    return nav / float(nav.iloc[0]) * initial_capital
   748
