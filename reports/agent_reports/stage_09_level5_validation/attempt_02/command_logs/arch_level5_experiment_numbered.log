    86	def run_level_5_validation(
    87	    *,
    88	    config_path: str | Path = Path("configs/default.yaml"),
    89	    artifacts_dir: str | Path | None = None,
    90	    market_frame: pd.DataFrame | None = None,
    91	    instruments: pd.DataFrame | None = None,
    92	) -> Level5ValidationResult:
    93	    """Run validation-only Level 5 and write large-universe artifacts."""
    94
    95	    started = time.perf_counter()
    96	    config = load_config(config_path, resolve_paths=True)
    97	    level_config = _level5_config(config)
    98	    decision_start = _utc(level_config["validation_decision_start"])
    99	    decision_end = _utc(level_config["validation_decision_end"])
   100	    validation_start = _utc(level_config["validation_evaluation_start"])
   101	    validation_end = _utc(level_config["validation_evaluation_end"])
   102	    test_start = _utc(config["splits"]["test_start"])
   103	    if validation_end >= test_start or decision_end >= test_start:
   104	        msg = "Level 5 validation must end before final-test start"
   105	        raise ValueError(msg)
   106	    if decision_start > decision_end:
   107	        msg = "Level 5 decision start must be on or before decision end"
   108	        raise ValueError(msg)
   109
   110	    output_dir = (
   111	        Path(artifacts_dir) if artifacts_dir is not None else Path(config["paths"]["artifacts"])
   112	    )
   113	    frame = (
   114	        _load_market_frame(config, end=validation_end)
   115	        if market_frame is None
   116	        else _normalize_market_frame(market_frame, end=validation_end)
   117	    )
   118	    instruments_frame = (
   119	        _load_instruments(config) if instruments is None else _normalize_instruments(instruments)
   120	    )
   121	    market = PanelMarketData.from_ohlcv(frame)
   122	    cost_assumptions = _cost_assumptions(config)
   123
   124	    schedule, score_frame, rebalance_log, traces = build_level_5_target_schedule(
   125	        frame=frame,
   126	        instruments=instruments_frame,
   127	        config=config,
   128	        decision_start=decision_start,
   129	        decision_end=decision_end,
   130	    )
   131	    symbols = tuple(str(symbol) for symbol in schedule.columns)
   132	    net_result = _trim_result(
   133	        SimulatedBroker(
   134	            market,
   135	            initial_capital=float(config["backtest"]["initial_capital_usd"]),
   136	            cost_assumptions=cost_assumptions,
   137	        ).run(schedule, end_time=validation_end, run_label=RUN_LABEL),
   138	        start=validation_start,
   139	        end=validation_end,
   140	    )
   141	    gross_result = _trim_result(
   142	        SimulatedBroker(
   143	            market,
   144	            initial_capital=float(config["backtest"]["initial_capital_usd"]),
   145	            cost_assumptions=CostAssumptions(fee_bps_one_way=0.0, slippage_bps_one_way=0.0),
   146	        ).run(schedule, end_time=validation_end, run_label=f"{RUN_LABEL}_gross"),
   147	        start=validation_start,
   148	        end=validation_end,
   149	    )
   150
   151	    benchmark_nav = _benchmark_nav(frame, start=validation_start, end=validation_end, config=config)
   152	    enriched = _enrich_equity(net_result, gross_result, benchmark_nav)
   153	    metrics = _metrics(
   154	        enriched,
   155	        gross_result,
   156	        benchmark_nav=benchmark_nav,
   157	        score_frame=score_frame,
   158	        rebalance_log=rebalance_log,
   159	        config=config,
   160	    )
   161	    runtime_seconds = time.perf_counter() - started
   162	    peak_rss_mb = _peak_rss_mb()
   163	    metrics["runtime_seconds"] = runtime_seconds
   164	    metrics["peak_rss_mb"] = peak_rss_mb
   165	    provenance = _provenance(
   166	        config=config,
   167	        validation_start=validation_start,
   168	        validation_end=validation_end,
   169	        decision_start=decision_start,
   170	        decision_end=decision_end,
   171	        cost_assumptions=cost_assumptions,
   172	        scored_count=int(score_frame.groupby("decision_bar_start")["symbol"].nunique().max()),
   173	        selected_count=int(score_frame.groupby("decision_bar_start")["selected_top_k"].sum().max()),
   174	    )
   175
   176	    artifact_paths = BacktestArtifactWriter(output_dir).write_run(
   177	        enriched,
   178	        metrics,
   179	        provenance,
   180	        level_name=LEVEL_NAME,
   181	    )
   182	    figure_path = _write_equity_figure(enriched, output_dir, provenance)
   183	    score_path = _write_scores(score_frame, output_dir, provenance)
   184	    rebalance_path = _write_rebalance_log(rebalance_log, output_dir, provenance)
   185	    health_path, alerts_path = _write_health_artifacts(
   186	        score_frame,
   187	        rebalance_log,
   188	        output_dir,
   189	        provenance,
   190	        runtime_seconds=runtime_seconds,
   191	        peak_rss_mb=peak_rss_mb,
   192	        config=config,
   193	    )
   194	    proof_path = _write_pair_count_proof(
   195	        score_frame,
   196	        rebalance_log,
   197	        output_dir,
   198	        provenance,
   199	        runtime_seconds=runtime_seconds,
   200	        peak_rss_mb=peak_rss_mb,
   201	        config=config,
   202	    )
   203	    trace_path = _write_decision_trace(
   204	        traces=traces,
   205	        score_frame=score_frame,
   206	        rebalance_log=rebalance_log,
   207	        output_dir=output_dir,
   208	        provenance=provenance,
   209	        config=config,
   210	    )
   211
   212	    return Level5ValidationResult(
   213	        metrics=metrics,
   214	        artifact_paths=artifact_paths,
   215	        figure_path=figure_path,
   216	        pair_count_proof_path=proof_path,
   217	        universe_scores_path=score_path,
   218	        rebalance_log_path=rebalance_path,
   219	        decision_trace_path=trace_path,
   220	        health_summary_path=health_path,
   221	        alerts_path=alerts_path,
   222	        scored_count=int(score_frame.groupby("decision_bar_start")["symbol"].nunique().max()),
   223	        selected_count=int(score_frame.groupby("decision_bar_start")["selected_top_k"].sum().max()),
   224	        symbols=symbols,
   225	    )
