   770	def _metrics(
   771	    net_result: BacktestRunResult,
   772	    gross_result: BacktestRunResult,
   773	    *,
   774	    benchmark_nav: pd.Series,
   775	    score_frame: pd.DataFrame,
   776	    rebalance_log: pd.DataFrame,
   777	    config: dict[str, Any],
   778	) -> dict[str, Any]:
   779	    initial_capital = float(config["backtest"]["initial_capital_usd"])
   780	    net_equity = _with_initial_capital_baseline(net_result.equity, initial_capital)
   781	    gross_equity = _with_initial_capital_baseline(gross_result.equity, initial_capital)
   782	    baseline_time = pd.to_datetime(net_equity["timestamp"], utc=True).iloc[0]
   783	    benchmark = pd.concat(
   784	        [pd.Series([initial_capital], index=[baseline_time]), benchmark_nav]
   785	    ).sort_index()
   786	    net = calculate_performance_metrics(
   787	        net_equity,
   788	        periods_per_year=int(config["backtest"]["annualization_periods"]),
   789	        risk_free_rate=float(config["backtest"]["risk_free_rate"]),
   790	        weights=net_result.weights,
   791	        benchmark_nav=benchmark,
   792	    )
   793	    gross = calculate_performance_metrics(
   794	        gross_equity,
   795	        periods_per_year=int(config["backtest"]["annualization_periods"]),
   796	        risk_free_rate=float(config["backtest"]["risk_free_rate"]),
   797	        weights=gross_result.weights,
   798	        benchmark_nav=benchmark,
   799	    )
   800	    metrics: dict[str, Any] = dict(net)
   801	    metrics.update({f"net_{key}": value for key, value in net.items()})
   802	    metrics.update({f"gross_{key}": value for key, value in gross.items()})
   803	    metrics["gross_to_net_total_return_decay"] = gross["total_return"] - net["total_return"]
   804	    metrics["eligible_count_max"] = float(score_frame.groupby("decision_bar_start").size().max())
   805	    metrics["scored_count_max"] = float(
   806	        score_frame.groupby("decision_bar_start")["scored"].sum().max()
   807	    )
   808	    metrics["selected_count_max"] = float(
   809	        score_frame.groupby("decision_bar_start")["selected_top_k"].sum().max()
   810	    )
   811	    metrics["approved_nonzero_count_max"] = float(rebalance_log["approved_nonzero_count"].max())
   812	    metrics["rebalance_decision_count"] = float(len(rebalance_log))
   813	    metrics["rebalance_submitted_count"] = float(rebalance_log["submitted_to_broker"].sum())
   814	    metrics["final_test_exposure_flag"] = 0.0
   815	    return metrics
   816
