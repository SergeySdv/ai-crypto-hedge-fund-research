"""Rebalance decision helpers."""

from __future__ import annotations

from dataclasses import dataclass
from datetime import datetime

import pandas as pd

from crypto_hedge_fund.types import AgentContext, PortfolioProposal, ReasonCode, RebalanceDecision


@dataclass(frozen=True)
class AlwaysRebalancePolicy:
    """Deterministic policy for Stage 4 plumbing and tests."""

    trigger_code: str = "stage4_always"

    def decide(
        self,
        proposal: PortfolioProposal,
        current_weights: pd.Series,
        context: AgentContext,
    ) -> RebalanceDecision:
        del current_weights
        should_rebalance = proposal.optimizer_status == "ok"
        return RebalanceDecision(
            decision_time=context.clock.decision_time,
            should_rebalance=should_rebalance,
            trigger_codes=(self.trigger_code,) if should_rebalance else (),
            expected_net_benefit=None,
            reason_codes=(ReasonCode.OK,) if should_rebalance else proposal.reason_codes,
        )


@dataclass(frozen=True)
class DynamicRebalancePolicy:
    """Cost-aware Level 4 rebalance policy with auditable trigger reasons."""

    name: str
    calendar: str = "monthly"
    drift_threshold_abs: float = 0.05
    score_change_threshold: float = 0.15
    risk_trigger: bool = True
    min_trade_abs: float = 0.01
    turnover_cap: float = 0.35
    one_way_cost_rate: float = 0.0015
    min_expected_net_benefit: float = -1.0
    require_positive_net_benefit: bool = False

    def decide(
        self,
        proposal: PortfolioProposal,
        current_weights: pd.Series,
        context: AgentContext,
    ) -> RebalanceDecision:
        """Decide whether to execute a candidate target generated from completed bars."""

        if proposal.optimizer_status != "ok":
            return RebalanceDecision(
                decision_time=context.clock.decision_time,
                should_rebalance=False,
                trigger_codes=("optimizer_not_ok",),
                expected_net_benefit=None,
                reason_codes=proposal.reason_codes,
            )

        current = _clean_weight_series(current_weights)
        target = _clean_weight_series(pd.Series(proposal.target_weights, dtype="float64"))
        symbols = current.index.union(target.index)
        current = current.reindex(symbols, fill_value=0.0)
        target = target.reindex(symbols, fill_value=0.0)
        risky_turnover = float((target - current).abs().sum())
        max_drift = float((target - current).abs().max()) if len(symbols) else 0.0

        triggers: list[str] = []
        if _calendar_due(
            self.calendar,
            context.clock.decision_time,
            context.metadata.get("previous_rebalance_time"),
        ):
            triggers.append(f"calendar_{self.calendar}")
        if max_drift >= self.drift_threshold_abs:
            triggers.append("weight_drift")
        score_change = float(context.health_state.get("aggregate_score_change", 0.0))
        if score_change >= self.score_change_threshold:
            triggers.append("signal_change")
        if self.risk_trigger and bool(context.health_state.get("risk_trigger_active", False)):
            triggers.append("risk_trigger")

        estimated_cost = risky_turnover * self.one_way_cost_rate
        expected_gross_benefit = float(proposal.metadata.get("expected_gross_benefit", 0.0))
        expected_net_benefit = expected_gross_benefit - estimated_cost

        if risky_turnover > self.turnover_cap + 1e-12:
            return RebalanceDecision(
                decision_time=context.clock.decision_time,
                should_rebalance=False,
                trigger_codes=(*tuple(triggers), "turnover_cap_exceeded"),
                expected_net_benefit=expected_net_benefit,
                reason_codes=(ReasonCode.TURNOVER_LIMIT,),
            )
        if risky_turnover < self.min_trade_abs and "risk_trigger" not in triggers:
            return RebalanceDecision(
                decision_time=context.clock.decision_time,
                should_rebalance=False,
                trigger_codes=(*tuple(triggers), "minimum_trade_not_met"),
                expected_net_benefit=expected_net_benefit,
                reason_codes=(ReasonCode.OK,),
            )
        if not triggers:
            return RebalanceDecision(
                decision_time=context.clock.decision_time,
                should_rebalance=False,
                trigger_codes=("no_trigger",),
                expected_net_benefit=expected_net_benefit,
                reason_codes=(ReasonCode.OK,),
            )
        if (
            self.require_positive_net_benefit
            and expected_net_benefit < self.min_expected_net_benefit
        ):
            return RebalanceDecision(
                decision_time=context.clock.decision_time,
                should_rebalance=False,
                trigger_codes=(*tuple(triggers), "expected_net_benefit_below_threshold"),
                expected_net_benefit=expected_net_benefit,
                reason_codes=(ReasonCode.TURNOVER_LIMIT,),
            )

        return RebalanceDecision(
            decision_time=context.clock.decision_time,
            should_rebalance=True,
            trigger_codes=tuple(triggers),
            expected_net_benefit=expected_net_benefit,
            reason_codes=(ReasonCode.OK,),
        )


def _clean_weight_series(weights: pd.Series) -> pd.Series:
    clean = weights.astype("float64").copy()
    clean.index = clean.index.astype(str)
    clean = clean.loc[clean.index.str.lower() != "cash"]
    clean[clean.abs() < 1e-15] = 0.0
    return clean


def _calendar_due(
    calendar: str,
    decision_time: datetime,
    previous_rebalance_time: object,
) -> bool:
    if previous_rebalance_time is None:
        return True
    previous = pd.Timestamp(previous_rebalance_time).tz_convert("UTC")
    current = pd.Timestamp(decision_time).tz_convert("UTC")
    name = calendar.lower()
    if name in {"none", "off", "never"}:
        return False
    if name == "daily":
        return current.normalize() > previous.normalize()
    if name == "weekly":
        return current - previous >= pd.Timedelta(days=7)
    if name == "monthly":
        return (current.year, current.month) != (previous.year, previous.month)
    msg = f"unsupported rebalance calendar: {calendar}"
    raise ValueError(msg)
